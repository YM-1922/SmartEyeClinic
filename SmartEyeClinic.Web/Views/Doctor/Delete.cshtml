@model SmartEyeClinic.Models.Doctor
@{
    ViewData["Title"] = $"Delete Dr. {Model.User.FullName} - Smart Eye Clinic";
}

<div class="container-fluid py-4">
    <!-- Breadcrumb -->
    <nav aria-label="breadcrumb" class="mb-4">
        <ol class="breadcrumb">
            <li class="breadcrumb-item"><a asp-controller="Home" asp-action="Index">Dashboard</a></li>
            <li class="breadcrumb-item"><a asp-controller="Doctor" asp-action="Index">Doctors</a></li>
            <li class="breadcrumb-item"><a asp-controller="Doctor" asp-action="Details" asp-route-id="@Model.Id">@Model.User.FullName</a></li>
            <li class="breadcrumb-item active" aria-current="page">Delete</li>
        </ol>
    </nav>

    <div class="row justify-content-center">
        <div class="col-lg-6">
            <div class="card border-0 shadow-sm rounded-4" style="background: var(--card-bg);">
                <div class="card-header bg-transparent border-bottom text-center p-4">
                    <div class="text-danger display-4 mb-3"><i class="fa-solid fa-triangle-exclamation"></i></div>
                    <h4 class="fw-bold text-dark">Confirm Doctor Deletion</h4>
                    <p class="text-muted small mb-0">Are you sure you want to permanently remove this specialist from the clinic system?</p>
                </div>
                <div class="card-body p-4">
                    <div class="alert alert-warning small rounded-3 mb-4">
                        <i class="fa-solid fa-triangle-exclamation me-2"></i><strong>Warning:</strong> Deleting Dr. @Model.User.FullName will remove their user login account. This action cannot be undone. 
                        If they have any associated patient appointments or surgeries, SQL integrity checks will prevent this deletion.
                    </div>

                    <ul class="list-group list-group-flush mb-4">
                        <li class="list-group-item d-flex justify-content-between align-items-center px-0 bg-transparent">
                            <span class="text-muted small">Specialist Name</span>
                            <span class="text-dark fw-bold">Dr. @Model.User.FullName</span>
                        </li>
                        <li class="list-group-item d-flex justify-content-between align-items-center px-0 bg-transparent">
                            <span class="text-muted small">Email Address</span>
                            <span class="text-dark">@Model.User.Email</span>
                        </li>
                        <li class="list-group-item d-flex justify-content-between align-items-center px-0 bg-transparent">
                            <span class="text-muted small">License Number</span>
                            <span class="text-dark">@Model.LicenseNumber</span>
                        </li>
                        <li class="list-group-item d-flex justify-content-between align-items-center px-0 bg-transparent">
                            <span class="text-muted small">Specialization</span>
                            <span class="text-dark">@Model.Specialization.Name</span>
                        </li>
                    </ul>

                    <form asp-action="Delete" method="post">
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="id" value="@Model.Id" />
                        <div class="d-flex gap-2">
                            <button type="submit" class="btn btn-danger w-100 py-2.5" style="border-radius: 8px;">
                                <i class="fa-solid fa-trash me-2"></i> Yes, Delete Doctor
                            </button>
                            <a asp-action="Details" asp-route-id="@Model.Id" class="btn btn-outline-secondary w-100 py-2.5" style="border-radius: 8px;">Cancel</a>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>
