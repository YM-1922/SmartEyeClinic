@model List<SmartEyeClinic.Models.Doctor>00
@{
    ViewData["Title"] = "Doctors - Smart Eye Clinic";
}

<div class="page-header">
    <div class="page-header-left">
        <nav class="breadcrumb-nav">
            <a asp-controller="Home" asp-action="Index">Home</a>
            <span class="separator">/</span>
            <span class="current">Specialist Doctors</span>
        </nav>
        <h3 class="page-title">Specialist Doctors</h3>
        <p class="page-subtitle">Manage medical personnel, clinical licenses, and fee settings</p>
    </div>
    <a asp-action="Create" class="btn btn-primary">
        <i class="fa-solid fa-user-plus"></i> Add Doctor
    </a>
</div>

<div class="table-card">
    <div class="table-card-header">
        <h5 class="table-title">
            <i class="fa-solid fa-user-md text-primary"></i> Medical Staff Register
        </h5>
    </div>
    <div class="card-body-clean p-4">
        @if (!Model.Any())
        {
            <div class="empty-state">
                <div class="empty-state-icon">
                    <i class="fa-solid fa-user-doctor"></i>
                </div>
                <h5>No Doctors Registered</h5>
                <p>Start by adding your first specialist doctor.</p>
                <a asp-action="Create" class="btn btn-primary"><i class="fa-solid fa-user-plus"></i> Add Doctor</a>
            </div>
        }
        else
        {
            <div class="table-responsive-custom">
                <table class="table datatable custom-table">
                    <thead>
                        <tr>
                            <th>Doctor Details</th>
                            <th>Specialization</th>
                            <th>License Number</th>
                            <th>Consultation Fee</th>
                            <th class="text-end">Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var d in Model)
                        {
                            <tr>
                                <td>
                                    <div class="d-flex align-items-center">
                                        <div class="avatar-initials avatar-md me-3 bg-light-primary text-primary-custom" style="background: linear-gradient(135deg, var(--primary), var(--secondary)) !important; color:#fff !important;">
                                            @(d.User?.FullName?.Length > 0 ? d.User.FullName[0].ToString().ToUpper() : "D")
                                        </div>
                                        <div class="d-flex flex-column">
                                            <span class="fw-bold text-dark">Dr. @d.User?.FullName</span>
                                            <span class="text-xs text-muted">@d.User?.Email</span>
                                        </div>
                                    </div>
                                </td>
                                <td>
                                    <span class="badge-status badge-primary">@d.Specialization?.Name</span>
                                </td>
                                <td>
                                    <span class="font-monospace text-secondary-custom fw-600">@d.LicenseNumber</span>
                                </td>
                                <td>
                                    <span class="fw-bold text-success">@d.ConsultationFee.ToString("C")</span>
                                </td>
                                <td class="text-end">
                                    <div class="action-btns justify-content-end">
                                        <a asp-action="Details" asp-route-id="@d.Id" class="btn btn-sm btn-light" title="View Details">
                                            <i class="fa-solid fa-eye text-muted"></i> Details
                                        </a>
                                        <a asp-action="Edit" asp-route-id="@d.Id" class="btn btn-sm btn-light text-primary" title="Edit Doctor Profile">
                                            <i class="fa-solid fa-user-pen"></i> Edit
                                        </a>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
    </div>
</div>
