@{
    ViewData["Title"] = "Add Doctor - Smart Eye Clinic";
    var specializations = ViewBag.Specializations as List<SmartEyeClinic.Models.Specialization>;
}

<div class="mb-4">
    <ul class="breadcrumb-custom mb-1">
        <li><a asp-controller="Home" asp-action="Index">Home</a></li>
        <li><a asp-controller="Doctor" asp-action="Index">Doctors</a></li>
        <li>Add Doctor</li>
    </ul>
    <h3 class="fw-bold text-dark mb-0">Register New Doctor</h3>
</div>

@if (TempData["Error"] != null)
{
    <div class="alert alert-danger alert-custom d-flex align-items-center mb-4">
        <i class="fa-solid fa-circle-exclamation fs-5 me-2"></i> <div>@TempData["Error"]</div>
    </div>
}

<div class="card custom-card" style="max-width:800px; border-radius: var(--radius-md); border: 1px solid var(--border); background: var(--card-bg);">
    <div class="card-header-clean p-4 border-bottom">
        <div class="d-flex align-items-center">
            <i class="fa-solid fa-user-md text-primary me-2 fs-4"></i>
            <h5 class="mb-0 fw-bold">Doctor Account & Clinical Profile</h5>
        </div>
    </div>
    <div class="card-body-clean p-4">
        <form asp-action="Create" method="post" enctype="multipart/form-data" class="needs-validation" novalidate>
            @Html.AntiForgeryToken()
            
            <h6 class="fw-bold text-primary mb-3"><i class="fa-solid fa-key me-2"></i> Account Credentials</h6>
            <div class="row g-3 mb-4">
                <div class="col-md-6">
                    <label class="form-label-custom">Full Name *</label>
                    <div class="input-group">
                        <span class="input-group-text bg-white border-end-0"><i class="fa-solid fa-user text-muted"></i></span>
                        <input type="text" name="fullName" class="form-control border-start-0 ps-0" placeholder="e.g. Dr. John Doe" required />
                    </div>
                </div>
                <div class="col-md-6">
                    <label class="form-label-custom">Email Address (Gmail) *</label>
                    <div class="input-group">
                        <span class="input-group-text bg-white border-end-0"><i class="fa-solid fa-envelope text-muted"></i></span>
                        <input type="email" name="email" class="form-control border-start-0 ps-0" placeholder="e.g. doctor@gmail.com" required />
                    </div>
                </div>
                <div class="col-md-6">
                    <label class="form-label-custom">Password *</label>
                    <div class="input-group">
                        <span class="input-group-text bg-white border-end-0"><i class="fa-solid fa-lock text-muted"></i></span>
                        <input type="password" name="password" class="form-control border-start-0 ps-0" placeholder="Min 6 characters" required />
                    </div>
                </div>
                <div class="col-md-6">
                    <label class="form-label-custom">Phone Number *</label>
                    <div class="input-group">
                        <span class="input-group-text bg-white border-end-0"><i class="fa-solid fa-phone text-muted"></i></span>
                        <input type="tel" name="phoneNumber" class="form-control border-start-0 ps-0" placeholder="e.g. 555-0199" required />
                    </div>
                </div>
                <div class="col-md-12">
                    <label class="form-label-custom">Profile Picture</label>
                    <input type="file" name="profilePicture" class="form-control" accept="image/*" />
                </div>
            </div>

            <h6 class="fw-bold text-primary mb-3"><i class="fa-solid fa-stethoscope me-2"></i> Clinical Profile Details</h6>
            <div class="row g-3 mb-4">
                <div class="col-md-6">
                    <label class="form-label-custom">Specialization *</label>
                    <select name="specializationId" class="form-select select-custom" required>
                        <option value="">Select Specialization...</option>
                        @if (specializations != null)
                        {
                            foreach (var spec in specializations)
                            {
                                <option value="@spec.Id">@spec.Name</option>
                            }
                        }
                    </select>
                </div>
                <div class="col-md-6">
                    <label class="form-label-custom">License Number *</label>
                    <div class="input-group">
                        <span class="input-group-text bg-white border-end-0"><i class="fa-solid fa-id-badge text-muted"></i></span>
                        <input type="text" name="licenseNumber" class="form-control border-start-0 ps-0" placeholder="e.g. LIC-2024-OPH" required />
                    </div>
                </div>
                <div class="col-md-6">
                    <label class="form-label-custom">Consultation Fee (USD) *</label>
                    <div class="input-group">
                        <span class="input-group-text bg-white border-end-0"><i class="fa-solid fa-dollar-sign text-muted"></i></span>
                        <input type="number" step="0.01" name="consultationFee" class="form-control border-start-0 ps-0" placeholder="e.g. 150.00" required />
                    </div>
                </div>
                <div class="col-md-12">
                    <label class="form-label-custom">Doctor Bio / Notes</label>
                    <textarea name="bio" class="form-control" rows="3" placeholder="Brief biography, specialized clinical notes..."></textarea>
                </div>
            </div>

            <h6 class="fw-bold text-primary mb-3"><i class="fa-solid fa-calendar-days me-2"></i> Working Schedules</h6>
            <div class="p-3 bg-light rounded-3 border border-light mb-4">
                <div class="mb-3">
                    <label class="form-label-custom d-block">Select Available Days *</label>
                    <div class="d-flex flex-wrap gap-3">
                        @foreach (var day in new[] { "Monday", "Tuesday", "Wednesday", "Thursday", "Friday", "Saturday", "Sunday" })
                        {
                            <div class="form-check form-check-inline">
                                <input class="form-check-input" type="checkbox" name="workingDays" value="@day" id="day-@day" />
                                <label class="form-check-label text-sm fw-600" for="day-@day">@day</label>
                            </div>
                        }
                    </div>
                </div>
                <div class="row g-3">
                    <div class="col-md-6">
                        <label class="form-label-custom">Working Hours Start Time *</label>
                        <input type="time" name="startTime" class="form-control" value="09:00" required />
                    </div>
                    <div class="col-md-6">
                        <label class="form-label-custom">Working Hours End Time *</label>
                        <input type="time" name="endTime" class="form-control" value="17:00" required />
                    </div>
                </div>
            </div>

            <div class="border-top pt-4 d-flex justify-content-end">
                <a asp-action="Index" class="btn btn-custom btn-custom-secondary me-2" style="border-radius: 8px;"><i class="fa-solid fa-xmark"></i> Cancel</a>
                <button type="submit" class="btn btn-custom btn-custom-primary" style="border-radius: 8px;"><i class="fa-solid fa-floppy-disk"></i> Save Doctor</button>
            </div>
        </form>
    </div>
</div>
