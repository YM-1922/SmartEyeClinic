@{
    ViewData["Title"] = "Add Doctor - Smart Eye Clinic";
}

<div class="mb-4">
    <ul class="breadcrumb-custom mb-1">
        <li><a asp-controller="Home" asp-action="Index">Home</a></li>
        <li><a asp-controller="Doctor" asp-action="Index">Doctors</a></li>
        <li>Add Doctor</li>
    </ul>
    <h3 class="fw-bold text-dark mb-0">Register New Doctor</h3>
</div>

@if (TempData["Error"] != null)
{
    <div class="alert alert-danger alert-custom d-flex align-items-center mb-4">
        <i class="fa-solid fa-circle-exclamation fs-5 me-2"></i> <div>@TempData["Error"]</div>
    </div>
}

<div class="card custom-card" style="max-width:700px;">
    <div class="card-header-clean">
        <div class="d-flex align-items-center">
            <i class="fa-solid fa-user-md text-primary me-2 fs-5"></i>
            <h5 class="mb-0">Doctor Credentials & Profile</h5>
        </div>
    </div>
    <div class="card-body-clean">
        <form asp-action="Create" method="post">
            @Html.AntiForgeryToken()
            <div class="row">
                <div class="col-md-6 mb-3">
                    <label class="form-label-custom">Specialization ID</label>
                    <div class="input-group">
                        <span class="input-group-text bg-white border-end-0"><i class="fa-solid fa-stethoscope text-muted"></i></span>
                        <input type="number" name="specializationId" class="form-control form-control-custom border-start-0 ps-0" placeholder="e.g. 1" required />
                    </div>
                </div>
                <div class="col-md-6 mb-3">
                    <label class="form-label-custom">License Number</label>
                    <div class="input-group">
                        <span class="input-group-text bg-white border-end-0"><i class="fa-solid fa-id-badge text-muted"></i></span>
                        <input type="text" name="licenseNumber" class="form-control form-control-custom border-start-0 ps-0" placeholder="e.g. LIC-2024-00123" required />
                    </div>
                </div>
            </div>
            <div class="row">
                <div class="col-md-6 mb-3">
                    <label class="form-label-custom">Consultation Fee (USD)</label>
                    <div class="input-group">
                        <span class="input-group-text bg-white border-end-0"><i class="fa-solid fa-dollar-sign text-muted"></i></span>
                        <input type="number" step="0.01" name="consultationFee" class="form-control form-control-custom border-start-0 ps-0" placeholder="e.g. 150.00" required />
                    </div>
                </div>
            </div>
            <div class="mb-4">
                <label class="form-label-custom">Doctor Bio / Notes</label>
                <textarea name="bio" class="form-control form-control-custom" rows="3" placeholder="Brief biography, specialization details..."></textarea>
            </div>
            <div class="border-top pt-4 d-flex justify-content-end">
                <a asp-action="Index" class="btn btn-custom btn-custom-secondary me-2"><i class="fa-solid fa-xmark"></i> Cancel</a>
                <button type="submit" class="btn btn-custom btn-custom-primary"><i class="fa-solid fa-floppy-disk"></i> Save Doctor</button>
            </div>
        </form>
    </div>
</div>
