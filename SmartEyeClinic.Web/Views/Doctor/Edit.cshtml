@model SmartEyeClinic.Models.Doctor
@{
    ViewData["Title"] = $"Edit Dr. {Model.User.FullName} - Smart Eye Clinic";
    var specializations = ViewBag.Specializations as List<SmartEyeClinic.Models.Specialization>;
}

<div class="container-fluid py-4">
    <!-- Breadcrumb -->
    <nav aria-label="breadcrumb" class="mb-4">
        <ol class="breadcrumb">
            <li class="breadcrumb-item"><a asp-controller="Home" asp-action="Index">Dashboard</a></li>
            <li class="breadcrumb-item"><a asp-controller="Doctor" asp-action="Index">Doctors</a></li>
            <li class="breadcrumb-item"><a asp-controller="Doctor" asp-action="Details" asp-route-id="@Model.Id">@Model.User.FullName</a></li>
            <li class="breadcrumb-item active" aria-current="page">Edit</li>
        </ol>
    </nav>

    <!-- Header -->
    <div class="mb-4">
        <h3 class="fw-bold text-dark mb-1">Edit Doctor Profile</h3>
        <p class="text-muted small mb-0">Modify information for Dr. @Model.User.FullName.</p>
    </div>

    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show rounded-3 mb-4" role="alert">
            <i class="fa-solid fa-triangle-exclamation me-2"></i> @TempData["Error"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    <div class="card border-0 shadow-sm rounded-4" style="background: var(--card-bg);">
        <div class="card-body p-4">
            <form asp-action="Edit" method="post" class="needs-validation" novalidate>
                @Html.AntiForgeryToken()
                <input type="hidden" name="id" value="@Model.Id" />

                <h5 class="fw-bold text-primary mb-3"><i class="fa-regular fa-user me-2"></i> Account Details</h5>
                <div class="row g-3 mb-4">
                    <div class="col-md-6">
                        <label class="form-label small fw-600">Full Name *</label>
                        <input type="text" name="fullName" class="form-control" value="@Model.User.FullName" required />
                    </div>
                    <div class="col-md-6">
                        <label class="form-label small fw-600">Email Address *</label>
                        <input type="email" name="email" class="form-control" value="@Model.User.Email" required />
                    </div>
                    <div class="col-md-6">
                        <label class="form-label small fw-600">Password *</label>
                        <input type="password" name="password" class="form-control" value="@Model.User.PasswordHash" required minlength="6" />
                    </div>
                    <div class="col-md-6">
                        <label class="form-label small fw-600">Phone Number</label>
                        <input type="tel" name="phoneNumber" class="form-control" value="@Model.User.PhoneNumber" />
                    </div>
                </div>

                <h5 class="fw-bold text-primary mb-3"><i class="fa-solid fa-user-md me-2"></i> Clinical & License Attributes</h5>
                <div class="row g-3 mb-4">
                    <div class="col-md-4">
                        <label class="form-label small fw-600">Specialization *</label>
                        <select name="specializationId" class="form-select" required>
                            <option value="">Select Specialization...</option>
                            @if (specializations != null)
                            {
                                foreach (var spec in specializations)
                                {
                                    if (spec.Id == Model.SpecializationId)
                                    {
                                        <option value="@spec.Id" selected="selected">@spec.Name</option>
                                    }
                                    else
                                    {
                                        <option value="@spec.Id">@spec.Name</option>
                                    }
                                }
                            }
                        </select>
                    </div>
                    <div class="col-md-4">
                        <label class="form-label small fw-600">License Number *</label>
                        <input type="text" name="licenseNumber" class="form-control" value="@Model.LicenseNumber" required />
                    </div>
                    <div class="col-md-4">
                        <label class="form-label small fw-600">Consultation Fee ($) *</label>
                        <input type="number" step="0.01" name="consultationFee" class="form-control" value="@Model.ConsultationFee.ToString("F2")" required />
                    </div>
                    <div class="col-12">
                        <label class="form-label small fw-600">Professional Biography</label>
                        <textarea name="bio" class="form-control" rows="4" placeholder="Brief clinical background...">@Model.Bio</textarea>
                    </div>
                </div>

                <div class="d-flex gap-2">
                    <button type="submit" class="btn btn-primary px-4 py-2 border-0" style="background: var(--primary-color); border-radius: 8px;">
                        <i class="fa-solid fa-check me-1"></i> Save Changes
                    </button>
                    <a asp-action="Details" asp-route-id="@Model.Id" class="btn btn-outline-secondary px-4 py-2" style="border-radius: 8px;">Cancel</a>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        // Form Validation
        (function () {
            'use strict'
            var forms = document.querySelectorAll('.needs-validation')
            Array.prototype.slice.call(forms)
                .forEach(function (form) {
                    form.addEventListener('submit', function (event) {
                        if (!form.checkValidity()) {
                            event.preventDefault()
                            event.stopPropagation()
                        }
                        form.classList.add('was-validated')
                    }, false)
                })
        })()
    </script>
}
