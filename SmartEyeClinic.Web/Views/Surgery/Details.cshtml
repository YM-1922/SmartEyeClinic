@model SmartEyeClinic.Models.Surgery
@{
    ViewData["Title"] = $"Surgery Case #{Model.Id} - Smart Eye Clinic";
}

<div class="container-fluid py-4">
    <!-- Breadcrumb -->
    <nav aria-label="breadcrumb" class="mb-4">
        <ol class="breadcrumb">
            <li class="breadcrumb-item"><a asp-controller="Home" asp-action="Index">Dashboard</a></li>
            <li class="breadcrumb-item"><a asp-controller="Surgery" asp-action="Index">Surgeries</a></li>
            <li class="breadcrumb-item active" aria-current="page">Case Details</li>
        </ol>
    </nav>

    <!-- Header -->
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h3 class="fw-bold text-dark mb-1">Surgery Case Report</h3>
            <p class="text-muted small mb-0">Scheduled surgical procedure parameters and medical logs.</p>
        </div>
        <div class="d-flex gap-2">
            @if (User.IsInRole("Doctor") || User.IsInRole("Admin"))
            {
                <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-primary px-3 py-2 border-0" style="background: var(--primary-color); border-radius: 8px;">
                    <i class="fa-regular fa-pen-to-square me-1"></i> Edit Case
                </a>
            }
            @if (User.IsInRole("Admin"))
            {
                <a asp-action="Delete" asp-route-id="@Model.Id" class="btn btn-danger px-3 py-2 border-0" style="border-radius: 8px;">
                    <i class="fa-solid fa-trash me-1"></i> Delete Case
                </a>
            }
        </div>
    </div>

    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show rounded-3 mb-4" role="alert">
            <i class="fa-solid fa-circle-check me-2"></i> @TempData["Success"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    <div class="row g-4">
        <!-- Main details -->
        <div class="col-lg-8">
            <div class="card border-0 shadow-sm rounded-4 mb-4" style="background: var(--card-bg);">
                <div class="card-header bg-transparent border-bottom p-3 d-flex justify-content-between align-items-center">
                    <h5 class="fw-bold text-dark mb-0"><i class="fa-solid fa-syringe text-primary me-2"></i> Surgical Case Information</h5>
                    <span class="badge @(string.IsNullOrEmpty(Model.Outcome) ? "bg-warning" : Model.Outcome.ToLower().Contains("success") ? "bg-success" : "bg-danger") px-3 py-2 rounded-pill">@(string.IsNullOrEmpty(Model.Outcome) ? "Scheduled" : Model.Outcome)</span>
                </div>
                <div class="card-body p-4">
                    <div class="row g-4 mb-4">
                        <div class="col-md-6">
                            <span class="text-muted small d-block">Scheduled Surgery Date & Time</span>
                            <strong class="text-dark fs-5">@Model.SurgeryDate.ToString("dd MMM yyyy, hh:mm tt")</strong>
                        </div>
                        <div class="col-md-6">
                            <span class="text-muted small d-block">Procedure Type</span>
                            <span class="badge bg-light text-dark fs-6 border px-3 py-2 mt-1">@Model.SurgeryType.Name</span>
                        </div>
                    </div>

                    <hr class="text-muted opacity-25 mb-4" />

                    <div class="mb-4">
                        <h6 class="fw-bold text-primary mb-2"><i class="fa-solid fa-clipboard-check me-2"></i> Surgery Outcome Description</h6>
                        <div class="p-3 bg-light rounded-3 text-muted small">
                            @(string.IsNullOrEmpty(Model.Outcome) ? "The surgery is currently scheduled and pending execution." : Model.Outcome)
                        </div>
                    </div>

                    <div class="mb-0">
                        <h6 class="fw-bold text-primary mb-2"><i class="fa-solid fa-notes-medical me-2"></i> Clinical & Operative Notes</h6>
                        <p class="text-dark mb-0">@(string.IsNullOrEmpty(Model.Notes) ? "No operative notes logged for this surgery case." : Model.Notes)</p>
                    </div>
                </div>
            </div>
        </div>

        <!-- Left Column -->
        <div class="col-lg-4">
            <div class="card border-0 shadow-sm rounded-4 mb-4" style="background: var(--card-bg);">
                <div class="card-header bg-transparent border-bottom p-3">
                    <h5 class="fw-bold text-dark mb-0"><i class="fa-regular fa-id-card text-primary me-2"></i> Medical Associates</h5>
                </div>
                <div class="card-body p-4">
                    <div class="mb-3">
                        <span class="text-muted small d-block">Patient Name</span>
                        <strong class="text-dark">@Model.Patient.User.FullName</strong>
                    </div>
                    <div class="mb-3">
                        <span class="text-muted small d-block">Operating Surgeon</span>
                        <strong class="text-dark">Dr. @Model.Doctor.User.FullName</strong>
                    </div>
                    <div>
                        <span class="text-muted small d-block">Linked Appointment Ref</span>
                        <a asp-controller="Appointment" asp-action="Details" asp-route-id="@Model.AppointmentId" class="text-primary fw-500">Visit #@Model.AppointmentId</a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
