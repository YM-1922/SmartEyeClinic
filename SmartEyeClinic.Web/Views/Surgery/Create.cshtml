@model SmartEyeClinic.Models.Surgery
@{
    ViewData["Title"] = "Schedule Surgery - Smart Eye Clinic";
    var appointments = ViewBag.Appointments as List<SmartEyeClinic.Models.Appointment>;
    var patients = ViewBag.Patients as List<SmartEyeClinic.Models.Patient>;
    var doctors = ViewBag.Doctors as List<SmartEyeClinic.Models.Doctor>;
    var surgeryTypes = ViewBag.SurgeryTypes as List<SmartEyeClinic.Models.SurgeryType>;
}

<div class="container-fluid py-4">
    <!-- Breadcrumb -->
    <nav aria-label="breadcrumb" class="mb-4">
        <ol class="breadcrumb">
            <li class="breadcrumb-item"><a asp-controller="Home" asp-action="Index">Dashboard</a></li>
            <li class="breadcrumb-item"><a asp-controller="Surgery" asp-action="Index">Surgeries</a></li>
            <li class="breadcrumb-item active" aria-current="page">Schedule</li>
        </ol>
    </nav>

    <!-- Header -->
    <div class="mb-4">
        <h3 class="fw-bold text-dark mb-1">Schedule Surgery Case</h3>
        <p class="text-muted small mb-0">Record surgical parameters and link them to clinical visits.</p>
    </div>

    <div class="card border-0 shadow-sm rounded-4" style="background: var(--card-bg);">
        <div class="card-body p-4">
            <form asp-action="Create" method="post" class="needs-validation" novalidate>
                @Html.AntiForgeryToken()

                <div class="row g-3 mb-4">
                    <!-- Visit Reference -->
                    <div class="col-md-12">
                        <label asp-for="AppointmentId" class="form-label small fw-600">Link Clinical Visit *</label>
                        <select asp-for="AppointmentId" class="form-select" required>
                            <option value="">Select Visit Reference...</option>
                            @if (appointments != null)
                            {
                                foreach (var app in appointments)
                                {
                                    <option value="@app.Id">Appt #@app.Id - @app.Patient.User.FullName with Dr. @app.Doctor.User.FullName (@app.AppointmentDateTime.ToString("dd MMM yyyy, hh:mm tt"))</option>
                                }
                            }
                        </select>
                        <span asp-validation-for="AppointmentId" class="text-danger small"></span>
                    </div>

                    <!-- Patient Select -->
                    <div class="col-md-6">
                        <label asp-for="PatientId" class="form-label small fw-600">Patient *</label>
                        <select asp-for="PatientId" class="form-select" required>
                            <option value="">Select Patient...</option>
                            @if (patients != null)
                            {
                                foreach (var pat in patients)
                                {
                                    <option value="@pat.Id">@pat.User.FullName (@pat.User.Email)</option>
                                }
                            }
                        </select>
                        <span asp-validation-for="PatientId" class="text-danger small"></span>
                    </div>

                    <!-- Doctor Select -->
                    <div class="col-md-6">
                        <label asp-for="DoctorId" class="form-label small fw-600">Assigned Surgeon *</label>
                        <select asp-for="DoctorId" class="form-select" required>
                            <option value="">Select Surgeon...</option>
                            @if (doctors != null)
                            {
                                foreach (var doc in doctors)
                                {
                                    <option value="@doc.Id">Dr. @doc.User.FullName (@doc.Specialization.Name)</option>
                                }
                            }
                        </select>
                        <span asp-validation-for="DoctorId" class="text-danger small"></span>
                    </div>

                    <!-- Surgery Type -->
                    <div class="col-md-6">
                        <label asp-for="SurgeryTypeId" class="form-label small fw-600">Procedure Type *</label>
                        <select asp-for="SurgeryTypeId" class="form-select" required>
                            <option value="">Select Procedure...</option>
                            @if (surgeryTypes != null)
                            {
                                foreach (var t in surgeryTypes)
                                {
                                    <option value="@t.Id">@t.Name</option>
                                }
                            }
                        </select>
                        <span asp-validation-for="SurgeryTypeId" class="text-danger small"></span>
                    </div>

                    <!-- Date & Time -->
                    <div class="col-md-6">
                        <label asp-for="SurgeryDate" class="form-label small fw-600">Surgery Date & Time *</label>
                        <input asp-for="SurgeryDate" type="datetime-local" class="form-control" required />
                        <span asp-validation-for="SurgeryDate" class="text-danger small"></span>
                    </div>

                    <!-- Outcome Status -->
                    <div class="col-md-12">
                        <label asp-for="Outcome" class="form-label small fw-600">Outcome Status</label>
                        <input asp-for="Outcome" class="form-control" placeholder="e.g. Pending, Success, Scheduled" />
                        <span asp-validation-for="Outcome" class="text-danger small"></span>
                    </div>

                    <!-- Notes -->
                    <div class="col-12">
                        <label asp-for="Notes" class="form-label small fw-600">Surgical Notes</label>
                        <textarea asp-for="Notes" class="form-control" rows="4" placeholder="Brief surgical protocol or guidelines..."></textarea>
                        <span asp-validation-for="Notes" class="text-danger small"></span>
                    </div>
                </div>

                <div class="d-flex gap-2">
                    <button type="submit" class="btn btn-primary px-4 py-2 border-0" style="background: var(--primary-color); border-radius: 8px;">
                        <i class="fa-solid fa-plus me-1"></i> Schedule Surgery
                    </button>
                    <a asp-action="Index" class="btn btn-outline-secondary px-4 py-2" style="border-radius: 8px;">Cancel</a>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        // Form Validation
        (function () {
            'use strict'
            var forms = document.querySelectorAll('.needs-validation')
            Array.prototype.slice.call(forms)
                .forEach(function (form) {
                    form.addEventListener('submit', function (event) {
                        if (!form.checkValidity()) {
                            event.preventDefault()
                            event.stopPropagation()
                        }
                        form.classList.add('was-validated')
                    }, false)
                })
        })()
    </script>
}
