@model IEnumerable<SmartEyeClinic.Models.Surgery>
@{
    ViewData["Title"] = "Scheduled Surgeries - Smart Eye Clinic";
}

<div class="container-fluid py-4">
    <!-- Breadcrumb -->
    <nav aria-label="breadcrumb" class="mb-4">
        <ol class="breadcrumb">
            <li class="breadcrumb-item"><a asp-controller="Home" asp-action="Index">Dashboard</a></li>
            <li class="breadcrumb-item active" aria-current="page">Surgeries</li>
        </ol>
    </nav>

    <!-- Header -->
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h3 class="fw-bold text-dark mb-1">Scheduled Surgeries</h3>
            <p class="text-muted small mb-0">Track ocular surgical schedules, procedures, and patient outcomes.</p>
        </div>
        @if (User.IsInRole("Doctor") || User.IsInRole("Admin"))
        {
            <a asp-action="Create" class="btn btn-primary px-3 py-2 border-0" style="background: var(--primary-color); border-radius: 8px;">
                <i class="fa-solid fa-plus me-1"></i> Schedule Surgery
            </a>
        }
    </div>

    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show rounded-3 mb-4" role="alert">
            <i class="fa-solid fa-circle-check me-2"></i> @TempData["Success"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }
    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show rounded-3 mb-4" role="alert">
            <i class="fa-solid fa-triangle-exclamation me-2"></i> @TempData["Error"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    <div class="card border-0 shadow-sm rounded-4" style="background: var(--card-bg);">
        <div class="card-body p-4">
            @if (Model == null || !Model.Any())
            {
                <div class="text-center py-5">
                    <i class="fa-solid fa-syringe fs-1 text-muted mb-3 d-block"></i>
                    <h5 class="text-muted fw-normal">No scheduled surgical procedures found.</h5>
                </div>
            }
            else
            {
                <div class="table-responsive">
                    <table class="table custom-table small">
                        <thead>
                            <tr>
                                <th>Ref ID</th>
                                <th>Patient</th>
                                <th>Surgeon</th>
                                <th>Procedure Type</th>
                                <th>Schedule Date</th>
                                <th>Outcome Status</th>
                                <th>Actions</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var item in Model)
                            {
                                <tr>
                                    <td>#@item.Id</td>
                                    <td><strong>@item.Patient.User.FullName</strong></td>
                                    <td>Dr. @item.Doctor.User.FullName</td>
                                    <td><span class="badge bg-light text-dark border px-2.5 py-1.5">@item.SurgeryType.Name</span></td>
                                    <td>@item.SurgeryDate.ToString("dd MMM yyyy, hh:mm tt")</td>
                                    <td>
                                        @if (string.IsNullOrEmpty(item.Outcome))
                                        {
                                            <span class="badge bg-warning-subtle text-warning border border-warning-subtle px-2.5 py-1">Scheduled</span>
                                        }
                                        else if (item.Outcome.ToLower().Contains("success"))
                                        {
                                            <span class="badge bg-success-subtle text-success border border-success-subtle px-2.5 py-1">@item.Outcome</span>
                                        }
                                        else
                                        {
                                            <span class="badge bg-danger-subtle text-danger border border-danger-subtle px-2.5 py-1">@item.Outcome</span>
                                        }
                                    </td>
                                    <td>
                                        <div class="d-flex gap-1">
                                            <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-xs btn-outline-primary">Details</a>
                                            @if (User.IsInRole("Doctor") || User.IsInRole("Admin"))
                                            {
                                                <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-xs btn-outline-secondary"><i class="fa-regular fa-pen-to-square"></i></a>
                                            }
                                            @if (User.IsInRole("Admin"))
                                            {
                                                <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-xs btn-outline-danger"><i class="fa-solid fa-trash"></i></a>
                                            }
                                        </div>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
        </div>
    </div>
</div>
