@model IEnumerable<SmartEyeClinic.Models.Surgery>
@{
    ViewData["Title"] = "Scheduled Surgeries - Smart Eye Clinic";
}

<div class="page-header">
    <div class="page-header-left">
        <nav class="breadcrumb-nav">
            <a asp-controller="Home" asp-action="Index">Dashboard</a>
            <span class="separator">/</span>
            <span class="current">Surgeries</span>
        </nav>
        <h3 class="page-title">Scheduled Surgeries</h3>
        <p class="page-subtitle">Track ocular surgical schedules, procedures, and patient clinical outcomes</p>
    </div>
    @if (User.IsInRole("Doctor") || User.IsInRole("Admin"))
    {
        <a asp-action="Create" class="btn btn-primary">
            <i class="fa-solid fa-plus"></i> Schedule Surgery
        </a>
    }
</div>

<div class="table-card">
    <div class="table-card-header">
        <h5 class="table-title">
            <i class="fa-solid fa-syringe text-primary"></i> Surgery Register
        </h5>
    </div>
    <div class="card-body-clean p-4">
        @if (Model == null || !Model.Any())
        {
            <div class="empty-state">
                <div class="empty-state-icon">
                    <i class="fa-solid fa-syringe"></i>
                </div>
                <h5>No Surgeries Scheduled</h5>
                <p>No ocular surgical schedules or active entries found in the ledger.</p>
                @if (User.IsInRole("Doctor") || User.IsInRole("Admin"))
                {
                    <a asp-action="Create" class="btn btn-primary"><i class="fa-solid fa-plus"></i> Schedule Surgery</a>
                }
            </div>
        }
        else
        {
            <div class="table-responsive-custom">
                <table class="table datatable custom-table">
                    <thead>
                        <tr>
                            <th>Ref ID</th>
                            <th>Patient</th>
                            <th>Surgeon</th>
                            <th>Procedure Type</th>
                            <th>Schedule Date</th>
                            <th>Outcome Status</th>
                            <th class="text-end">Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model)
                        {
                            <tr>
                                <td><span class="text-muted font-monospace small">#@item.Id</span></td>
                                <td>
                                    <div class="d-flex align-items-center">
                                        <div class="avatar-initials avatar-sm me-2 bg-light-danger text-danger">
                                            @(item.Patient?.User?.FullName?.Length > 0 ? item.Patient.User.FullName[0].ToString().ToUpper() : "P")
                                        </div>
                                        <span class="fw-600 text-dark">@item.Patient?.User?.FullName</span>
                                    </div>
                                </td>
                                <td>
                                    <span class="fw-500 text-dark">Dr. @item.Doctor?.User?.FullName</span>
                                </td>
                                <td>
                                    <span class="pill pill-primary">@item.SurgeryType?.Name</span>
                                </td>
                                <td>
                                    <span class="fw-500 d-block">@item.SurgeryDate.ToString("dd MMM yyyy")</span>
                                    <span class="text-xs text-muted">@item.SurgeryDate.ToString("hh:mm tt")</span>
                                </td>
                                <td>
                                    @if (string.IsNullOrEmpty(item.Outcome))
                                    {
                                        <span class="badge-status badge-warning">Scheduled</span>
                                    }
                                    else if (item.Outcome.ToLower().Contains("success"))
                                    {
                                        <span class="badge-status badge-success">@item.Outcome</span>
                                    }
                                    else
                                    {
                                        <span class="badge-status badge-danger">@item.Outcome</span>
                                    }
                                </td>
                                <td class="text-end">
                                    <div class="action-btns justify-content-end">
                                        <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-sm btn-light" title="View Details">
                                            <i class="fa-solid fa-eye text-muted"></i> Details
                                        </a>
                                        @if (User.IsInRole("Doctor") || User.IsInRole("Admin"))
                                        {
                                            <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-light text-primary" title="Edit Surgery Record">
                                                <i class="fa-solid fa-pen-to-square"></i> Edit
                                            </a>
                                        }
                                        @if (User.IsInRole("Admin"))
                                        {
                                            <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-sm btn-custom-danger" title="Delete Surgery Record">
                                                <i class="fa-solid fa-trash-can"></i>
                                            </a>
                                        }
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
    </div>
</div>
