@model IEnumerable<SmartEyeClinic.Models.Branch>
@{
    ViewData["Title"] = "Clinic Branches - Smart Eye Clinic";
}

<div class="page-header">
    <div class="page-header-left">
        <nav class="breadcrumb-nav">
            <a asp-controller="Home" asp-action="Index">Dashboard</a>
            <span class="separator">/</span>
            <span class="current">Branches</span>
        </nav>
        <h3 class="page-title">Clinic Branches</h3>
        <p class="page-subtitle">Configure medical clinics, physical locations, and reception desks</p>
    </div>
    @if (User.IsInRole("Admin"))
    {
        <a asp-action="Create" class="btn btn-primary">
            <i class="fa-solid fa-plus"></i> Add Branch
        </a>
    }
</div>

<div class="row g-4 animate-fade-in-up">
    @foreach (var item in Model)
    {
        <div class="col-xl-4 col-md-6">
            <div class="card custom-card h-100">
                <div class="card-body-clean p-4 d-flex flex-column h-100">
                    <div class="d-flex align-items-center mb-3">
                        <div class="avatar-initials avatar-lg me-3 bg-light-primary text-primary-custom" style="border-radius: var(--radius)">
                            <i class="fa-solid fa-hospital fs-4"></i>
                        </div>
                        <div>
                            <h5 class="fw-bold text-dark mb-0">@item.Name</h5>
                            <span class="text-xs text-muted">Branch Code: #@item.Id</span>
                        </div>
                    </div>

                    <p class="text-muted text-xs mb-4 flex-grow-1">
                        <i class="fa-solid fa-location-dot me-2 text-primary-custom"></i>@item.Address
                    </p>

                    <hr class="text-muted opacity-10 my-3" />

                    <div class="d-flex justify-content-between align-items-center mt-auto">
                        <div>
                            <span class="text-muted text-xs d-block">Receptionist Staff</span>
                            <strong class="text-dark font-size-sm">@item.Receptionists.Count Assigned</strong>
                        </div>
                        <div class="action-btns">
                            <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-sm btn-light" title="View details">
                                <i class="fa-solid fa-eye text-muted"></i> Details
                            </a>
                            @if (User.IsInRole("Admin"))
                            {
                                <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-light text-primary" title="Edit branch settings">
                                    <i class="fa-solid fa-pen-to-square"></i>
                                </a>
                                <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-sm btn-custom-danger" title="Delete branch">
                                    <i class="fa-solid fa-trash-can"></i>
                                </a>
                            }
                        </div>
                    </div>
                </div>
            </div>
        </div>
    }
</div>
