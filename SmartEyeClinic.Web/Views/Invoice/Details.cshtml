@model SmartEyeClinic.Models.Invoice
@{
    ViewData["Title"] = $"Invoice {Model.InvoiceNumber} - Smart Eye Clinic";
}

<div class="container-fluid py-4 no-print">
    <!-- Breadcrumb -->
    <nav aria-label="breadcrumb" class="mb-4">
        <ol class="breadcrumb">
            <li class="breadcrumb-item"><a asp-controller="Home" asp-action="Index">Dashboard</a></li>
            <li class="breadcrumb-item"><a asp-controller="Invoice" asp-action="Index">Invoices</a></li>
            <li class="breadcrumb-item active" aria-current="page">Details</li>
        </ol>
    </nav>

    <!-- Header / Actions -->
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h3 class="fw-bold text-dark mb-1">Billing Invoice</h3>
            <p class="text-muted small mb-0">Manage billing invoice receipts and settlements.</p>
        </div>
        <div class="d-flex gap-2">
            <button onclick="window.print()" class="btn btn-outline-dark px-3 py-2" style="border-radius: 8px;">
                <i class="fa-solid fa-print me-1"></i> Print Invoice
            </button>
            @if (Model.Status != "Paid" && (User.IsInRole("Admin") || User.IsInRole("Receptionist")))
            {
                <a asp-controller="Payment" asp-action="Create" asp-route-invoiceId="@Model.Id" class="btn btn-success px-3 py-2 border-0" style="border-radius: 8px;">
                    <i class="fa-solid fa-credit-card me-1"></i> Receive Payment
                </a>
            }
            @if (User.IsInRole("Admin") || User.IsInRole("Receptionist"))
            {
                <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-primary px-3 py-2 border-0" style="background: var(--primary-color); border-radius: 8px;">
                    <i class="fa-regular fa-pen-to-square me-1"></i> Edit
                </a>
            }
            @if (User.IsInRole("Admin"))
            {
                <a asp-action="Delete" asp-route-id="@Model.Id" class="btn btn-danger px-3 py-2 border-0" style="border-radius: 8px;">
                    <i class="fa-solid fa-trash me-1"></i> Delete
                </a>
            }
        </div>
    </div>

    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show rounded-3 mb-4" role="alert">
            <i class="fa-solid fa-circle-check me-2"></i> @TempData["Success"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }
</div>

<!-- Invoice Document Sheet -->
<div class="container py-2">
    <div class="card border-0 shadow-sm rounded-4 p-5 invoice-print-card" style="background: var(--card-bg);">
        <!-- Invoice Header -->
        <div class="row mb-5">
            <div class="col-sm-6">
                <div class="d-flex align-items-center mb-3">
                    <i class="fa-solid fa-house-medical fa-2x text-primary me-2"></i>
                    <h3 class="fw-bold text-dark mb-0">Smart Eye Clinic</h3>
                </div>
                <p class="text-muted small mb-0">120 Clinical Road, Healthcare District</p>
                <p class="text-muted small mb-0">Phone: +1 (555) 234-5678 | billing@@smarteyeclinic.com</p>
            </div>
            <div class="col-sm-6 text-sm-end mt-4 mt-sm-0">
                <h4 class="text-primary fw-bold text-uppercase mb-2">Invoice</h4>
                <div class="small mb-1"><span class="text-muted">Invoice No:</span> <strong class="text-dark">@Model.InvoiceNumber</strong></div>
                <div class="small mb-1"><span class="text-muted">Issued Date:</span> <strong class="text-dark">@(Model.IssuedAt.HasValue ? Model.IssuedAt.Value.ToString("dd MMM yyyy") : "N/A")</strong></div>
                <div class="small"><span class="text-muted">Status:</span> 
                    @if (Model.Status == "Paid")
                    {
                        <span class="badge bg-success-subtle text-success border border-success-subtle px-2.5 py-1">Paid</span>
                    }
                    else if (Model.Status == "Partial")
                    {
                        <span class="badge bg-warning-subtle text-warning border border-warning-subtle px-2.5 py-1">Partial</span>
                    }
                    else
                    {
                        <span class="badge bg-danger-subtle text-danger border border-danger-subtle px-2.5 py-1">Unpaid</span>
                    }
                </div>
            </div>
        </div>

        <hr class="my-4 text-muted opacity-25" />

        <!-- Bill To / Consult Details -->
        <div class="row mb-5">
            <div class="col-sm-6">
                <h6 class="text-muted text-uppercase fw-bold small mb-2">Patient Bill To</h6>
                <h5 class="fw-bold text-dark mb-1">@Model.Patient.User.FullName</h5>
                <p class="text-muted small mb-1">Email: @Model.Patient.User.Email</p>
                <p class="text-muted small mb-0">Phone: @(string.IsNullOrEmpty(Model.Patient.User.PhoneNumber) ? "N/A" : Model.Patient.User.PhoneNumber)</p>
            </div>
            <div class="col-sm-6 text-sm-end mt-4 mt-sm-0">
                <h6 class="text-muted text-uppercase fw-bold small mb-2">Clinical Visit Reference</h6>
                <div class="small mb-1"><span class="text-muted">Attending Specialist:</span> <strong class="text-dark">Dr. @Model.Appointment.Doctor.User.FullName</strong></div>
                <div class="small mb-1"><span class="text-muted">Branch Site:</span> <strong class="text-dark">@Model.Appointment.Branch.Name</strong></div>
                <div class="small"><span class="text-muted">Appointment ID:</span> <strong class="text-dark">#@Model.AppointmentId</strong></div>
            </div>
        </div>

        <!-- Line Items Table -->
        <div class="table-responsive mb-4">
            <table class="table custom-table table-bordered">
                <thead class="bg-light text-uppercase small font-size-xs">
                    <tr>
                        <th style="width: 10%">#</th>
                        <th style="width: 60%">Item & Description</th>
                        <th class="text-end" style="width: 30%">Amount</th>
                    </tr>
                </thead>
                <tbody>
                    <tr>
                        <td>1</td>
                        <td>
                            <strong>Clinical Consultation Fee</strong>
                            <span class="d-block text-muted small">Comprehensive vision examination and intraocular tonometry.</span>
                        </td>
                        <td class="text-end fw-bold">$@Model.TotalAmount.ToString("F2")</td>
                    </tr>
                </tbody>
            </table>
        </div>

        <!-- Summary Totals -->
        <div class="row justify-content-end mb-4">
            <div class="col-md-5">
                <table class="table table-borderless small">
                    <tbody>
                        <tr>
                            <td class="text-muted">Subtotal:</td>
                            <td class="text-end fw-bold">$@Model.TotalAmount.ToString("F2")</td>
                        </tr>
                        @if (Model.Tax.HasValue && Model.Tax.Value > 0)
                        {
                            <tr>
                                <td class="text-muted">Tax Add-on:</td>
                                <td class="text-end text-danger fw-bold">+$@Model.Tax.Value.ToString("F2")</td>
                            </tr>
                        }
                        @if (Model.Discount.HasValue && Model.Discount.Value > 0)
                        {
                            <tr>
                                <td class="text-muted">Discount Applied:</td>
                                <td class="text-end text-success fw-bold">-$@Model.Discount.Value.ToString("F2")</td>
                            </tr>
                        }
                        @{
                            decimal finalTotal = Model.TotalAmount + (Model.Tax ?? 0) - (Model.Discount ?? 0);
                            decimal remaining = Math.Max(0, finalTotal - (Model.PaidAmount ?? 0));
                        }
                        <tr class="border-top">
                            <td class="fs-6 fw-bold text-dark">Grand Total:</td>
                            <td class="fs-6 fw-bold text-primary text-end">$@finalTotal.ToString("F2")</td>
                        </tr>
                        <tr>
                            <td class="text-muted">Paid to Date:</td>
                            <td class="text-end text-success fw-bold">$@(Model.PaidAmount?.ToString("F2") ?? "0.00")</td>
                        </tr>
                        <tr class="bg-light">
                            <td class="fw-bold text-dark">Outstanding Balance:</td>
                            <td class="fw-bold text-danger text-end">$@remaining.ToString("F2")</td>
                        </tr>
                    </tbody>
                </table>
            </div>
        </div>

        <!-- Payments Log -->
        @if (Model.Payments != null && Model.Payments.Any())
        {
            <div class="mt-4">
                <h6 class="fw-bold text-dark mb-3"><i class="fa-solid fa-list-check me-2"></i> Payment History Transactions</h6>
                <div class="table-responsive">
                    <table class="table table-sm table-striped small">
                        <thead>
                            <tr>
                                <th>Ref #</th>
                                <th>Settled Date</th>
                                <th>Method</th>
                                <th>Reference</th>
                                <th class="text-end">Amount</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var p in Model.Payments)
                            {
                                <tr>
                                    <td>#@p.Id</td>
                                    <td>@(p.PaidAt.HasValue ? p.PaidAt.Value.ToString("dd MMM yyyy, hh:mm tt") : "N/A")</td>
                                    <td>@p.PaymentMethod.Name</td>
                                    <td>@(string.IsNullOrEmpty(p.TransactionRef) ? "-" : p.TransactionRef)</td>
                                    <td class="text-end fw-bold text-success">$@p.Amount.ToString("F2")</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        }

        <hr class="my-5 text-muted opacity-25" />

        <!-- Document Footer -->
        <div class="text-center text-muted small">
            <p class="mb-1">Thank you for choosing Smart Eye Clinic.</p>
            <p class="small text-muted mb-0">For medical insurance questions, please contact billing department at billing@@smarteyeclinic.com.</p>
        </div>
    </div>
</div>

<style>
    @@media print {
        .no-print {
            display: none !important;
        }
        body {
            background-color: #ffffff !important;
            color: #000000 !important;
        }
        .invoice-print-card {
            box-shadow: none !important;
            padding: 0 !important;
            border: none !important;
            background: transparent !important;
        }
        #sidebar, .top-navbar, footer {
            display: none !important;
        }
        #content {
            margin-left: 0 !important;
            padding: 0 !important;
            width: 100% !important;
        }
    }
</style>
