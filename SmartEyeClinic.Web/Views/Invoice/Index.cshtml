@model List<SmartEyeClinic.Models.Invoice>
@{
    ViewData["Title"] = "Invoices - Smart Eye Clinic";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <ul class="breadcrumb-custom mb-1">
            <li><a asp-controller="Home" asp-action="Index">Home</a></li>
            <li>Invoices</li>
        </ul>
        <h3 class="fw-bold text-dark mb-0">Billing & Invoices</h3>
    </div>
    <a asp-action="Create" class="btn btn-custom btn-custom-primary">
        <i class="fa-solid fa-file-invoice-dollar"></i> Create Invoice
    </a>
</div>

@if (TempData["Success"] != null)
{
    <div class="alert alert-success alert-custom d-flex align-items-center mb-4">
        <i class="fa-solid fa-circle-check fs-5 me-2"></i> <div>@TempData["Success"]</div>
    </div>
}
@if (TempData["Error"] != null)
{
    <div class="alert alert-danger alert-custom d-flex align-items-center mb-4">
        <i class="fa-solid fa-circle-exclamation fs-5 me-2"></i> <div>@TempData["Error"]</div>
    </div>
}

<div class="card custom-card">
    <div class="card-header-clean">
        <div class="d-flex align-items-center">
            <i class="fa-solid fa-file-invoice-dollar text-primary me-2 fs-5"></i>
            <h5 class="mb-0">Invoice Register</h5>
        </div>
        <div class="text-muted small">Total: @Model.Count invoices</div>
    </div>
    <div class="card-body-clean">
        @if (!Model.Any())
        {
            <div class="text-center py-5">
                <i class="fa-solid fa-file-invoice text-muted fs-1 mb-3 d-block"></i>
                <h5 class="fw-bold text-dark mb-2">No Invoices Found</h5>
                <p class="text-muted small mb-4">Create the first invoice for a patient appointment.</p>
                <a asp-action="Create" class="btn btn-custom btn-custom-primary"><i class="fa-solid fa-file-invoice-dollar"></i> Create Invoice</a>
            </div>
        }
        else
        {
            <div class="table-responsive-custom">
                <table class="table custom-table">
                    <thead>
                        <tr>
                            <th>Invoice #</th>
                            <th>Patient</th>
                            <th>Total Amount</th>
                            <th>Paid Amount</th>
                            <th>Status</th>
                            <th>Issued Date</th>
                            <th>Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var i in Model)
                        {
                            <tr>
                                <td><span class="font-monospace fw-bold text-primary">@i.InvoiceNumber</span></td>
                                <td>
                                    <div class="d-flex align-items-center">
                                        <div class="me-2 text-white fw-bold text-center rounded-circle" style="width:32px;height:32px;line-height:32px;font-size:0.8rem;background:#00B4D8;">
                                            @(i.Patient?.User?.FullName?.Length > 0 ? i.Patient.User.FullName[0].ToString().ToUpper() : "P")
                                        </div>
                                        <span>@i.Patient?.User?.FullName</span>
                                    </div>
                                </td>
                                <td><span class="fw-bold text-dark">@i.TotalAmount.ToString("C")</span></td>
                                <td><span class="text-success">@(i.PaidAmount?.ToString("C") ?? "—")</span></td>
                                <td>
                                    @if (i.Status == "Paid")
                                    { <span class="badge-custom badge-custom-success">Paid</span> }
                                    else if (i.Status == "Partial")
                                    { <span class="badge-custom badge-custom-warning">Partial</span> }
                                    else
                                    { <span class="badge-custom badge-custom-danger">@i.Status</span> }
                                </td>
                                <td><span class="text-muted">@i.IssuedAt?.ToString("dd MMM yyyy")</span></td>
                                <td>
                                    <a asp-controller="Payment" asp-action="Create" asp-route-invoiceId="@i.Id" class="btn btn-sm btn-custom btn-custom-primary" style="padding:5px 12px;">
                                        <i class="fa-solid fa-credit-card"></i> Pay
                                    </a>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
    </div>
</div>
