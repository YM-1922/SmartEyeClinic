@model SmartEyeClinic.Models.Invoice
@{
    ViewData["Title"] = $"Delete Invoice {Model.InvoiceNumber} - Smart Eye Clinic";
}

<div class="container-fluid py-4">
    <!-- Breadcrumb -->
    <nav aria-label="breadcrumb" class="mb-4">
        <ol class="breadcrumb">
            <li class="breadcrumb-item"><a asp-controller="Home" asp-action="Index">Dashboard</a></li>
            <li class="breadcrumb-item"><a asp-controller="Invoice" asp-action="Index">Invoices</a></li>
            <li class="breadcrumb-item"><a asp-controller="Invoice" asp-action="Details" asp-route-id="@Model.Id">@Model.InvoiceNumber</a></li>
            <li class="breadcrumb-item active" aria-current="page">Delete</li>
        </ol>
    </nav>

    <div class="row justify-content-center">
        <div class="col-lg-6">
            <div class="card border-0 shadow-sm rounded-4" style="background: var(--card-bg);">
                <div class="card-header bg-transparent border-bottom text-center p-4">
                    <div class="text-danger display-4 mb-3"><i class="fa-solid fa-triangle-exclamation"></i></div>
                    <h4 class="fw-bold text-dark">Confirm Invoice Deletion</h4>
                    <p class="text-muted small mb-0">Are you sure you want to permanently delete this billing invoice record?</p>
                </div>
                <div class="card-body p-4">
                    @if (TempData["Error"] != null)
                    {
                        <div class="alert alert-danger small rounded-3 mb-4">
                            <i class="fa-solid fa-triangle-exclamation me-2"></i> @TempData["Error"]
                        </div>
                    }
                    else
                    {
                        <div class="alert alert-warning small rounded-3 mb-4">
                            <i class="fa-solid fa-triangle-exclamation me-2"></i><strong>Warning:</strong> Deleting this invoice will permanently remove the billing statement. If there are active payments registered against this invoice, database foreign key constraints will prevent this deletion.
                        </div>
                    }

                    <ul class="list-group list-group-flush mb-4">
                        <li class="list-group-item d-flex justify-content-between align-items-center px-0 bg-transparent">
                            <span class="text-muted small">Invoice Number</span>
                            <span class="text-dark fw-bold">@Model.InvoiceNumber</span>
                        </li>
                        <li class="list-group-item d-flex justify-content-between align-items-center px-0 bg-transparent">
                            <span class="text-muted small">Patient Name</span>
                            <span class="text-dark fw-bold">@Model.Patient.User.FullName</span>
                        </li>
                        <li class="list-group-item d-flex justify-content-between align-items-center px-0 bg-transparent">
                            <span class="text-muted small">Grand Total</span>
                            <span class="text-dark fw-bold">$@((Model.TotalAmount + (Model.Tax ?? 0) - (Model.Discount ?? 0)).ToString("F2"))</span>
                        </li>
                        <li class="list-group-item d-flex justify-content-between align-items-center px-0 bg-transparent">
                            <span class="text-muted small">Settled Status</span>
                            <span class="text-dark">@Model.Status</span>
                        </li>
                    </ul>

                    <form asp-action="Delete" method="post">
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="id" value="@Model.Id" />
                        <div class="d-flex gap-2">
                            <button type="submit" class="btn btn-danger w-100 py-2.5" style="border-radius: 8px;">
                                <i class="fa-solid fa-trash me-2"></i> Yes, Delete Invoice
                            </button>
                            <a asp-action="Details" asp-route-id="@Model.Id" class="btn btn-outline-secondary w-100 py-2.5" style="border-radius: 8px;">Cancel</a>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>
