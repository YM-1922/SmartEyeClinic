@model List<SmartEyeClinic.Models.Examination>
@{
    ViewData["Title"] = "Examinations - Smart Eye Clinic";
}

<div class="page-header">
    <div class="page-header-left">
        <nav class="breadcrumb-nav">
            <a asp-controller="Home" asp-action="Index">Home</a>
            <span class="separator">/</span>
            <span class="current">Clinical Examinations</span>
        </nav>
        <h3 class="page-title">Clinical Examinations</h3>
        <p class="page-subtitle">View and record visual acuity sheets and ophthalmic diagnostics</p>
    </div>
    @if (User.IsInRole("Doctor") || User.IsInRole("Admin"))
    {
        <a asp-action="Create" class="btn btn-primary">
            <i class="fa-solid fa-notes-medical"></i> Record Examination
        </a>
    }
</div>

<div class="table-card">
    <div class="table-card-header">
        <h5 class="table-title">
            <i class="fa-solid fa-notes-medical text-primary"></i> Examination Records
        </h5>
    </div>
    <div class="card-body-clean p-4">
        @if (!Model.Any())
        {
            <div class="empty-state">
                <div class="empty-state-icon">
                    <i class="fa-solid fa-notes-medical"></i>
                </div>
                <h5>No Examination Records</h5>
                <p>Start recording patient examinations.</p>
                @if (User.IsInRole("Doctor") || User.IsInRole("Admin"))
                {
                    <a asp-action="Create" class="btn btn-primary"><i class="fa-solid fa-notes-medical"></i> Record First</a>
                }
            </div>
        }
        else
        {
            <div class="table-responsive-custom">
                <table class="table datatable custom-table">
                    <thead>
                        <tr>
                            <th>#</th>
                            <th>Patient</th>
                            <th>Doctor</th>
                            <th>Diagnosis</th>
                            <th>Examined At</th>
                            <th class="text-end">Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var e in Model)
                        {
                            <tr>
                                <td><span class="text-muted font-monospace small">#@e.Id</span></td>
                                <td>
                                    <div class="d-flex align-items-center">
                                        <div class="avatar-initials avatar-sm me-2 bg-light-info text-info">
                                            @(e.Appointment?.Patient?.User?.FullName?.Length > 0 ? e.Appointment.Patient.User.FullName[0].ToString().ToUpper() : "P")
                                        </div>
                                        <div class="d-flex flex-column">
                                            <span class="fw-600 text-dark">@e.Appointment?.Patient?.User?.FullName</span>
                                            <span class="text-xs text-muted">ID: #@e.Appointment?.PatientId</span>
                                        </div>
                                    </div>
                                </td>
                                <td>
                                    <span class="fw-500 text-dark">Dr. @e.Appointment?.Doctor?.User?.FullName</span>
                                </td>
                                <td>
                                    <span class="text-dark font-size-sm" title="@e.Diagnosis">
                                        @(e.Diagnosis?.Length > 50 ? e.Diagnosis.Substring(0, 50) + "..." : e.Diagnosis)
                                    </span>
                                </td>
                                <td>
                                    <span class="d-block fw-500">@e.ExaminedAt?.ToString("dd MMM yyyy")</span>
                                    <span class="text-xs text-muted">@e.ExaminedAt?.ToString("hh:mm tt")</span>
                                </td>
                                <td class="text-end">
                                    <div class="action-btns justify-content-end">
                                        <a asp-action="Details" asp-route-id="@e.Id" class="btn btn-sm btn-light" title="View details">
                                            <i class="fa-solid fa-eye text-muted"></i> Details
                                        </a>
                                        @if (User.IsInRole("Doctor") || User.IsInRole("Admin"))
                                        {
                                            <a asp-action="Edit" asp-route-id="@e.Id" class="btn btn-sm btn-light text-primary" title="Edit Examination">
                                                <i class="fa-solid fa-pen-to-square"></i> Edit
                                            </a>
                                        }
                                        @if (User.IsInRole("Admin"))
                                        {
                                            <form asp-action="Delete" asp-route-id="@e.Id" method="post" class="d-inline" data-confirm="Are you sure you want to delete this examination record?" data-item="Examination #@e.Id">
                                                @Html.AntiForgeryToken()
                                                <button type="submit" class="btn btn-sm btn-custom-danger" title="Delete">
                                                    <i class="fa-solid fa-trash-can"></i>
                                                </button>
                                            </form>
                                        }
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
    </div>
</div>
