@model List<SmartEyeClinic.Models.Examination>
@{
    ViewData["Title"] = "Examinations - Smart Eye Clinic";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <ul class="breadcrumb-custom mb-1">
            <li><a asp-controller="Home" asp-action="Index">Home</a></li>
            <li>Examinations</li>
        </ul>
        <h3 class="fw-bold text-dark mb-0">Clinical Examinations</h3>
    </div>
    <a asp-action="Create" class="btn btn-custom btn-custom-primary">
        <i class="fa-solid fa-notes-medical"></i> Record Examination
    </a>
</div>

@if (TempData["Success"] != null)
{
    <div class="alert alert-success alert-custom d-flex align-items-center mb-4">
        <i class="fa-solid fa-circle-check fs-5 me-2"></i> <div>@TempData["Success"]</div>
    </div>
}
@if (TempData["Error"] != null)
{
    <div class="alert alert-danger alert-custom d-flex align-items-center mb-4">
        <i class="fa-solid fa-circle-exclamation fs-5 me-2"></i> <div>@TempData["Error"]</div>
    </div>
}

<div class="card custom-card">
    <div class="card-header-clean">
        <div class="d-flex align-items-center">
            <i class="fa-solid fa-notes-medical text-primary me-2 fs-5"></i>
            <h5 class="mb-0">Examination Records</h5>
        </div>
        <div class="text-muted small">Total: @Model.Count records</div>
    </div>
    <div class="card-body-clean">
        @if (!Model.Any())
        {
            <div class="text-center py-5">
                <i class="fa-solid fa-notes-medical text-muted fs-1 mb-3 d-block"></i>
                <h5 class="fw-bold text-dark mb-2">No Examination Records</h5>
                <p class="text-muted small mb-4">Start recording patient examinations.</p>
                <a asp-action="Create" class="btn btn-custom btn-custom-primary"><i class="fa-solid fa-notes-medical"></i> Record First</a>
            </div>
        }
        else
        {
            <div class="table-responsive-custom">
                <table class="table custom-table">
                    <thead>
                        <tr>
                            <th>#</th>
                            <th>Patient</th>
                            <th>Doctor</th>
                            <th>Diagnosis</th>
                            <th>Examined At</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var e in Model)
                        {
                            <tr>
                                <td><span class="text-muted font-monospace small">#@e.Id</span></td>
                                <td>
                                    <div class="d-flex align-items-center">
                                        <div class="me-2 text-white fw-bold text-center rounded-circle" style="width:32px;height:32px;line-height:32px;font-size:0.8rem;background:#4CC9F0;">
                                            @(e.Appointment?.Patient?.User?.FullName?.Length > 0 ? e.Appointment.Patient.User.FullName[0].ToString().ToUpper() : "P")
                                        </div>
                                        <span class="fw-500">@e.Appointment?.Patient?.User?.FullName</span>
                                    </div>
                                </td>
                                <td><span class="text-dark">Dr. @e.Appointment?.Doctor?.User?.FullName</span></td>
                                <td>
                                    <span class="text-muted" title="@e.Diagnosis">
                                        @(e.Diagnosis?.Length > 50 ? e.Diagnosis.Substring(0, 50) + "..." : e.Diagnosis)
                                    </span>
                                </td>
                                <td>
                                    <span class="d-block">@e.ExaminedAt?.ToString("dd MMM yyyy")</span>
                                    <span class="text-muted small">@e.ExaminedAt?.ToString("hh:mm tt")</span>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
    </div>
</div>
