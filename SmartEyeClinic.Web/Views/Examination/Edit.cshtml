@model SmartEyeClinic.Models.Examination
@{
    ViewData["Title"] = $"Edit Examination Report #{Model.Id} - Smart Eye Clinic";
    var appointments = ViewBag.Appointments as List<SmartEyeClinic.Models.Appointment>;
}

<div class="container-fluid py-4">
    <!-- Breadcrumb -->
    <nav aria-label="breadcrumb" class="mb-4">
        <ol class="breadcrumb">
            <li class="breadcrumb-item"><a asp-controller="Home" asp-action="Index">Dashboard</a></li>
            <li class="breadcrumb-item"><a asp-controller="Examination" asp-action="Index">Examinations</a></li>
            <li class="breadcrumb-item"><a asp-controller="Examination" asp-action="Details" asp-route-id="@Model.Id">Report #@Model.Id</a></li>
            <li class="breadcrumb-item active" aria-current="page">Edit</li>
        </ol>
    </nav>

    <!-- Header -->
    <div class="mb-4">
        <h3 class="fw-bold text-dark mb-1">Edit Examination Report</h3>
        <p class="text-muted small mb-0">Modify clinical diagnostic data, vision measurements, and treatment plans for report #@Model.Id.</p>
    </div>

    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show rounded-3 mb-4" role="alert">
            <i class="fa-solid fa-triangle-exclamation me-2"></i> @TempData["Error"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    <div class="card border-0 shadow-sm rounded-4" style="background: var(--card-bg);">
        <div class="card-body p-4">
            <form asp-action="Edit" method="post" class="needs-validation" novalidate>
                @Html.AntiForgeryToken()
                <input type="hidden" name="id" value="@Model.Id" />

                <h5 class="fw-bold text-primary mb-3"><i class="fa-regular fa-calendar-check me-2"></i> Visit Association</h5>
                <div class="row g-3 mb-4">
                    <div class="col-md-12">
                        <label class="form-label small fw-600">Select Appointment *</label>
                        <select name="appointmentId" class="form-select" required>
                            <option value="">Select Appointment...</option>
                            @if (appointments != null)
                            {
                                foreach (var app in appointments)
                                {
                                    if (app.Id == Model.AppointmentId)
                                    {
                                        <option value="@app.Id" selected="selected">Appt #@app.Id - @app.Patient.User.FullName with Dr. @app.Doctor.User.FullName (@app.AppointmentDateTime.ToString("dd MMM yyyy, hh:mm tt"))</option>
                                    }
                                    else
                                    {
                                        <option value="@app.Id">Appt #@app.Id - @app.Patient.User.FullName with Dr. @app.Doctor.User.FullName (@app.AppointmentDateTime.ToString("dd MMM yyyy, hh:mm tt"))</option>
                                    }
                                }
                            }
                        </select>
                    </div>
                </div>

                <h5 class="fw-bold text-primary mb-3"><i class="fa-solid fa-eye me-2"></i> Vision Metrics & Measurements</h5>
                <div class="row g-3 mb-4">
                    <div class="col-md-4">
                        <label class="form-label small fw-600">Visual Acuity (Left - OS)</label>
                        <input type="text" name="visualAcuityLeft" class="form-control" value="@Model.VisualAcuityLeft" placeholder="e.g. 20/20, 6/6" />
                    </div>
                    <div class="col-md-4">
                        <label class="form-label small fw-600">Visual Acuity (Right - OD)</label>
                        <input type="text" name="visualAcuityRight" class="form-control" value="@Model.VisualAcuityRight" placeholder="e.g. 20/20, 6/6" />
                    </div>
                    <div class="col-md-4">
                        <label class="form-label small fw-600">Intraocular Pressure (mmHg)</label>
                        <input type="text" name="intraocularPressure" class="form-control" value="@Model.IntraocularPressure" placeholder="e.g. 14, 18" />
                    </div>
                </div>

                <h5 class="fw-bold text-primary mb-3"><i class="fa-solid fa-notes-medical me-2"></i> Clinical Notes</h5>
                <div class="row g-3 mb-4">
                    <div class="col-12">
                        <label class="form-label small fw-600">Presenting Symptoms</label>
                        <textarea name="symptoms" class="form-control" rows="3" placeholder="Enter patient complaints or symptoms...">@Model.Symptoms</textarea>
                    </div>
                    <div class="col-12">
                        <label class="form-label small fw-600">Diagnosis Description *</label>
                        <textarea name="diagnosis" class="form-control" rows="3" placeholder="Enter diagnosis (e.g., Cataract, Glaucoma)..." required>@Model.Diagnosis</textarea>
                    </div>
                    <div class="col-12">
                        <label class="form-label small fw-600">Treatment Plan</label>
                        <textarea name="treatmentPlan" class="form-control" rows="3" placeholder="Enter recommended treatment plan...">@Model.TreatmentPlan</textarea>
                    </div>
                </div>

                <div class="d-flex gap-2">
                    <button type="submit" class="btn btn-primary px-4 py-2 border-0" style="background: var(--primary-color); border-radius: 8px;">
                        <i class="fa-solid fa-check me-1"></i> Save Changes
                    </button>
                    <a asp-action="Details" asp-route-id="@Model.Id" class="btn btn-outline-secondary px-4 py-2" style="border-radius: 8px;">Cancel</a>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        // Form Validation
        (function () {
            'use strict'
            var forms = document.querySelectorAll('.needs-validation')
            Array.prototype.slice.call(forms)
                .forEach(function (form) {
                    form.addEventListener('submit', function (event) {
                        if (!form.checkValidity()) {
                            event.preventDefault()
                            event.stopPropagation()
                        }
                        form.classList.add('was-validated')
                    }, false)
                })
        })()
    </script>
}
