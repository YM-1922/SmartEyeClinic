@model SmartEyeClinic.Models.Examination
@{
    ViewData["Title"] = $"Delete Examination Report #{Model.Id} - Smart Eye Clinic";
}

<div class="container-fluid py-4">
    <!-- Breadcrumb -->
    <nav aria-label="breadcrumb" class="mb-4">
        <ol class="breadcrumb">
            <li class="breadcrumb-item"><a asp-controller="Home" asp-action="Index">Dashboard</a></li>
            <li class="breadcrumb-item"><a asp-controller="Examination" asp-action="Index">Examinations</a></li>
            <li class="breadcrumb-item"><a asp-controller="Examination" asp-action="Details" asp-route-id="@Model.Id">Report #@Model.Id</a></li>
            <li class="breadcrumb-item active" aria-current="page">Delete</li>
        </ol>
    </nav>

    <div class="row justify-content-center">
        <div class="col-lg-6">
            <div class="card border-0 shadow-sm rounded-4" style="background: var(--card-bg);">
                <div class="card-header bg-transparent border-bottom text-center p-4">
                    <div class="text-danger display-4 mb-3"><i class="fa-solid fa-triangle-exclamation"></i></div>
                    <h4 class="fw-bold text-dark">Confirm Examination Deletion</h4>
                    <p class="text-muted small mb-0">Are you sure you want to permanently delete this clinical examination record?</p>
                </div>
                <div class="card-body p-4">
                    @if (TempData["Error"] != null)
                    {
                        <div class="alert alert-danger small rounded-3 mb-4">
                            <i class="fa-solid fa-triangle-exclamation me-2"></i> @TempData["Error"]
                        </div>
                    }
                    else
                    {
                        <div class="alert alert-warning small rounded-3 mb-4">
                            <i class="fa-solid fa-triangle-exclamation me-2"></i><strong>Warning:</strong> Deleting this examination will permanently remove its medical notes. If there are dependent drug prescriptions or surgeries linked to this examination, database references will prevent this deletion.
                        </div>
                    }

                    <ul class="list-group list-group-flush mb-4">
                        <li class="list-group-item d-flex justify-content-between align-items-center px-0 bg-transparent">
                            <span class="text-muted small">Patient Name</span>
                            <span class="text-dark fw-bold">@Model.Appointment.Patient.User.FullName</span>
                        </li>
                        <li class="list-group-item d-flex justify-content-between align-items-center px-0 bg-transparent">
                            <span class="text-muted small">Ophthalmologist</span>
                            <span class="text-dark">Dr. @Model.Appointment.Doctor.User.FullName</span>
                        </li>
                        <li class="list-group-item d-flex justify-content-between align-items-center px-0 bg-transparent">
                            <span class="text-muted small">Date Examined</span>
                            <span class="text-dark">@(Model.ExaminedAt.HasValue ? Model.ExaminedAt.Value.ToString("dd MMM yyyy, hh:mm tt") : "N/A")</span>
                        </li>
                        <li class="list-group-item d-flex justify-content-between align-items-center px-0 bg-transparent">
                            <span class="text-muted small">Diagnosis</span>
                            <span class="text-dark font-monospace">@Model.Diagnosis</span>
                        </li>
                    </ul>

                    <form asp-action="Delete" method="post">
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="id" value="@Model.Id" />
                        <div class="d-flex gap-2">
                            <button type="submit" class="btn btn-danger w-100 py-2.5" style="border-radius: 8px;">
                                <i class="fa-solid fa-trash me-2"></i> Yes, Delete Record
                            </button>
                            <a asp-action="Details" asp-route-id="@Model.Id" class="btn btn-outline-secondary w-100 py-2.5" style="border-radius: 8px;">Cancel</a>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>
