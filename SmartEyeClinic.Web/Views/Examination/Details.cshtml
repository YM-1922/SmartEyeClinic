@model SmartEyeClinic.Models.Examination
@{
    ViewData["Title"] = $"Examination Report #{Model.Id} - Smart Eye Clinic";
}

<div class="container-fluid py-4">
    <!-- Breadcrumb -->
    <nav aria-label="breadcrumb" class="mb-4">
        <ol class="breadcrumb">
            <li class="breadcrumb-item"><a asp-controller="Home" asp-action="Index">Dashboard</a></li>
            <li class="breadcrumb-item"><a asp-controller="Examination" asp-action="Index">Examinations</a></li>
            <li class="breadcrumb-item active" aria-current="page">Clinical Details</li>
        </ol>
    </nav>

    <!-- Header -->
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h3 class="fw-bold text-dark mb-1">Clinical Examination Report</h3>
            <p class="text-muted small mb-0">Detailed ophthalmologist measurements logged on @(Model.ExaminedAt.HasValue ? Model.ExaminedAt.Value.ToString("dd MMM yyyy, hh:mm tt") : "N/A").</p>
        </div>
        <div class="d-flex gap-2">
            @if (User.IsInRole("Doctor") || User.IsInRole("Admin"))
            {
                <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-primary px-3 py-2 border-0" style="background: var(--primary-color); border-radius: 8px;">
                    <i class="fa-regular fa-pen-to-square me-1"></i> Edit Report
                </a>
            }
            @if (User.IsInRole("Admin"))
            {
                <a asp-action="Delete" asp-route-id="@Model.Id" class="btn btn-danger px-3 py-2 border-0" style="border-radius: 8px;">
                    <i class="fa-solid fa-trash me-1"></i> Delete
                </a>
            }
        </div>
    </div>

    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show rounded-3 mb-4" role="alert">
            <i class="fa-solid fa-circle-check me-2"></i> @TempData["Success"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    <div class="row g-4">
        <!-- Measurement Details -->
        <div class="col-lg-8">
            <!-- Vision Metric Board -->
            <div class="card border-0 shadow-sm rounded-4 mb-4" style="background: var(--card-bg);">
                <div class="card-header bg-transparent border-bottom p-3">
                    <h5 class="fw-bold text-dark mb-0"><i class="fa-solid fa-eye text-primary me-2"></i> Visual Acuity & Tonometry</h5>
                </div>
                <div class="card-body p-4">
                    <div class="row text-center g-3">
                        <div class="col-6 col-md-4">
                            <div class="p-3 bg-light rounded-4 border">
                                <span class="text-muted small d-block mb-1">Visual Acuity (Left - OS)</span>
                                <strong class="text-dark fs-3">@(string.IsNullOrEmpty(Model.VisualAcuityLeft) ? "N/A" : Model.VisualAcuityLeft)</strong>
                            </div>
                        </div>
                        <div class="col-6 col-md-4">
                            <div class="p-3 bg-light rounded-4 border">
                                <span class="text-muted small d-block mb-1">Visual Acuity (Right - OD)</span>
                                <strong class="text-dark fs-3">@(string.IsNullOrEmpty(Model.VisualAcuityRight) ? "N/A" : Model.VisualAcuityRight)</strong>
                            </div>
                        </div>
                        <div class="col-12 col-md-4">
                            <div class="p-3 bg-light rounded-4 border">
                                <span class="text-muted small d-block mb-1">Intraocular Pressure (IOP)</span>
                                <strong class="text-dark fs-3">@(string.IsNullOrEmpty(Model.IntraocularPressure) ? "N/A" : Model.IntraocularPressure) <span class="fs-6 text-muted">mmHg</span></strong>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Diagnosis & Symptoms -->
            <div class="card border-0 shadow-sm rounded-4 mb-4" style="background: var(--card-bg);">
                <div class="card-body p-4">
                    <div class="mb-4">
                        <h6 class="fw-bold text-primary mb-2"><i class="fa-solid fa-clipboard-question me-2"></i> Presenting Symptoms</h6>
                        <p class="text-dark">@(string.IsNullOrEmpty(Model.Symptoms) ? "No symptoms recorded." : Model.Symptoms)</p>
                    </div>

                    <hr class="text-muted opacity-25" />

                    <div class="mb-4">
                        <h6 class="fw-bold text-primary mb-2"><i class="fa-solid fa-stethoscope me-2"></i> Clinical Diagnosis</h6>
                        <div class="p-3 rounded-3" style="background: rgba(15, 76, 129, 0.05); border-left: 4px solid var(--primary-color);">
                            <p class="text-dark mb-0 fw-500">@Model.Diagnosis</p>
                        </div>
                    </div>

                    <hr class="text-muted opacity-25" />

                    <div class="mb-0">
                        <h6 class="fw-bold text-primary mb-2"><i class="fa-solid fa-receipt me-2"></i> Treatment & Management Plan</h6>
                        <p class="text-dark mb-0">@(string.IsNullOrEmpty(Model.TreatmentPlan) ? "No special treatment actions registered." : Model.TreatmentPlan)</p>
                    </div>
                </div>
            </div>

            <!-- Prescription Action Panel -->
            @if (User.IsInRole("Doctor") || User.IsInRole("Admin"))
            {
                <div class="card border-0 shadow-sm rounded-4" style="background: var(--card-bg);">
                    <div class="card-header bg-transparent border-bottom p-3">
                        <h5 class="fw-bold text-dark mb-0"><i class="fa-solid fa-pills text-primary me-2"></i> Clinical Prescriptions</h5>
                    </div>
                    <div class="card-body p-4">
                        <div class="d-flex align-items-center justify-content-between">
                            <div>
                                <h6 class="fw-bold mb-1">Issue Pharmacological Prescription</h6>
                                <p class="text-muted small mb-0">Write drug prescriptions based on this diagnostic examination report.</p>
                            </div>
                            <a asp-controller="Prescription" asp-action="Create" asp-route-examinationId="@Model.Id" class="btn btn-primary px-4 py-2 border-0" style="background: var(--primary-color); border-radius: 8px;">
                                <i class="fa-solid fa-file-prescription me-2"></i> Prescribe Medicine
                            </a>
                        </div>
                    </div>
                </div>
            }
        </div>

        <!-- Right Side Panel -->
        <div class="col-lg-4">
            <!-- Patient / Doctor Info Cards -->
            <div class="card border-0 shadow-sm rounded-4 mb-4" style="background: var(--card-bg);">
                <div class="card-header bg-transparent border-bottom p-3">
                    <h5 class="fw-bold text-dark mb-0"><i class="fa-regular fa-address-book text-primary me-2"></i> Consultation Info</h5>
                </div>
                <div class="card-body p-4">
                    <div class="mb-3.5">
                        <span class="text-muted small d-block">Patient</span>
                        <strong class="text-dark">@Model.Appointment.Patient.User.FullName</strong>
                    </div>
                    <div class="mb-3.5">
                        <span class="text-muted small d-block">Consulting Doctor</span>
                        <strong class="text-dark">Dr. @Model.Appointment.Doctor.User.FullName</strong>
                    </div>
                    <div class="mb-3.5">
                        <span class="text-muted small d-block">Appointment Ref</span>
                        <a asp-controller="Appointment" asp-action="Details" asp-route-id="@Model.AppointmentId" class="text-primary fw-500">Visit #@Model.AppointmentId</a>
                    </div>
                    <div class="small">
                        <span class="text-muted d-block">Date of Exam</span>
                        <span class="text-dark">@(Model.ExaminedAt.HasValue ? Model.ExaminedAt.Value.ToString("dd MMM yyyy, hh:mm tt") : "N/A")</span>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
