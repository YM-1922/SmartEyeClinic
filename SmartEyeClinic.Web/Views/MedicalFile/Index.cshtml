@model IEnumerable<SmartEyeClinic.Models.MedicalFile>
@{
    ViewData["Title"] = "Medical Files - Smart Eye Clinic";
    var userIdString = User.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier)?.Value;
    int currentUserId = string.IsNullOrEmpty(userIdString) ? 0 : int.Parse(userIdString);
}

<div class="page-header">
    <div class="page-header-left">
        <nav class="breadcrumb-nav">
            <a asp-controller="Home" asp-action="Index">Dashboard</a>
            <span class="separator">/</span>
            <span class="current">Medical Files</span>
        </nav>
        <h3 class="page-title">Patient Medical Files</h3>
        <p class="page-subtitle">Browse, upload, and download patient clinical records, scan files, and OCT charts</p>
    </div>
    @if (!ViewBag.IsPatient)
    {
        <a asp-action="Upload" asp-route-patientId="@ViewBag.PatientId" class="btn btn-primary">
            <i class="fa-solid fa-cloud-arrow-up"></i> Upload File
        </a>
    }
</div>

<div class="table-card">
    <div class="table-card-header">
        <h5 class="table-title">
            <i class="fa-solid fa-folder-open text-primary"></i> Patient Medical Records
        </h5>
    </div>
    <div class="card-body-clean p-4">
        @if (Model == null || !Model.Any())
        {
            <div class="empty-state">
                <div class="empty-state-icon">
                    <i class="fa-solid fa-folder-open"></i>
                </div>
                <h5>No Medical Files Found</h5>
                <p>No scans, clinical notes, or visual acuity charts have been uploaded yet.</p>
                @if (!ViewBag.IsPatient)
                {
                    <a asp-action="Upload" asp-route-patientId="@ViewBag.PatientId" class="btn btn-primary"><i class="fa-solid fa-cloud-arrow-up"></i> Upload File</a>
                }
            </div>
        }
        else
        {
            <div class="table-responsive-custom">
                <table class="table datatable custom-table">
                    <thead>
                        <tr>
                            <th>File ID</th>
                            <th>Patient Name</th>
                            <th>File Type</th>
                            <th>File Size</th>
                            <th>Uploaded At</th>
                            <th>Uploader</th>
                            <th class="text-end">Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model)
                        {
                            <tr>
                                <td><span class="text-muted font-monospace small">#@item.Id</span></td>
                                <td>
                                    <div class="d-flex align-items-center">
                                        <div class="avatar-initials avatar-sm me-2 bg-light-primary text-primary-custom">
                                            @(item.Patient?.User?.FullName?.Length > 0 ? item.Patient.User.FullName[0].ToString().ToUpper() : "P")
                                        </div>
                                        <span class="fw-600 text-dark">@item.Patient?.User?.FullName</span>
                                    </div>
                                </td>
                                <td>
                                    <span class="pill pill-info font-monospace fw-bold">@item.FileType</span>
                                </td>
                                <td>
                                    @if (item.FileSize.HasValue)
                                    {
                                        <span class="fw-500">@((item.FileSize.Value / 1024.0).ToString("F1")) KB</span>
                                    }
                                    else
                                    {
                                        <span class="text-muted">-</span>
                                    }
                                </td>
                                <td>
                                    <span class="fw-500 d-block">@(item.UploadedAt.HasValue ? item.UploadedAt.Value.ToString("dd MMM yyyy") : "-")</span>
                                    <span class="text-xs text-muted">@(item.UploadedAt.HasValue ? item.UploadedAt.Value.ToString("hh:mm tt") : "-")</span>
                                </td>
                                <td>
                                    <span class="text-dark">@(item.Uploader != null ? item.Uploader.FullName : "-")</span>
                                </td>
                                <td class="text-end">
                                    <div class="action-btns justify-content-end">
                                        <a href="@item.FilePath" target="_blank" class="btn btn-sm btn-light" title="View or Download File">
                                            <i class="fa-solid fa-cloud-arrow-down text-muted"></i> Download
                                        </a>
                                        @if (User.IsInRole("Admin") || (!User.IsInRole("Patient") && item.UploadedBy == currentUserId))
                                        {
                                            <form asp-action="Delete" asp-route-id="@item.Id" method="post" class="d-inline" data-confirm="Are you sure you want to delete this medical file?" data-item="Medical File #@item.Id">
                                                @Html.AntiForgeryToken()
                                                <button type="submit" class="btn btn-sm btn-custom-danger" title="Delete File">
                                                    <i class="fa-solid fa-trash-can"></i>
                                                </button>
                                            </form>
                                        }
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
    </div>
</div>
