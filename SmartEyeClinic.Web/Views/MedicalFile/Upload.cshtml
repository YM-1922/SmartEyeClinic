@{
    ViewData["Title"] = "Upload Medical Document - Smart Eye Clinic";
    var patients = ViewBag.Patients as List<SmartEyeClinic.Models.Patient>;
    var appointments = ViewBag.Appointments as List<SmartEyeClinic.Models.Appointment>;
    int? selectedPatientId = ViewBag.PatientId;
    int? selectedAppointmentId = ViewBag.AppointmentId;
}

<div class="container-fluid py-4">
    <!-- Breadcrumb -->
    <nav aria-label="breadcrumb" class="mb-4">
        <ol class="breadcrumb">
            <li class="breadcrumb-item"><a asp-controller="Home" asp-action="Index">Dashboard</a></li>
            <li class="breadcrumb-item"><a asp-controller="MedicalFile" asp-action="Index">Medical Files</a></li>
            <li class="breadcrumb-item active" aria-current="page">Upload</li>
        </ol>
    </nav>

    <!-- Header -->
    <div class="mb-4">
        <h3 class="fw-bold text-dark mb-1">Upload Medical Document</h3>
        <p class="text-muted small mb-0">Upload clinical reports, diagnostic scanner outcomes, or prescriptions.</p>
    </div>

    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show rounded-3 mb-4" role="alert">
            <i class="fa-solid fa-triangle-exclamation me-2"></i> @TempData["Error"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    <div class="card border-0 shadow-sm rounded-4" style="background: var(--card-bg);">
        <div class="card-body p-4">
            <form asp-action="Upload" method="post" enctype="multipart/form-data" class="needs-validation" novalidate>
                @Html.AntiForgeryToken()

                <div class="row g-3 mb-4">
                    <!-- Patient Select -->
                    @if (User.IsInRole("Patient"))
                    {
                        var currentPatient = patients?.FirstOrDefault(p => p.Id == selectedPatientId);
                        <div class="col-md-6">
                            <label class="form-label small fw-600">Patient</label>
                            <input type="text" class="form-control" value="@(currentPatient?.User?.FullName ?? "Me")" readonly disabled />
                            <input type="hidden" name="patientId" value="@selectedPatientId" />
                        </div>
                    }
                    else
                    {
                        <div class="col-md-6">
                            <label class="form-label small fw-600">Patient *</label>
                            <select name="patientId" class="form-select" required>
                                <option value="">Select Patient...</option>
                                @if (patients != null)
                                {
                                    foreach (var pat in patients)
                                    {
                                        if (pat.Id == selectedPatientId)
                                        {
                                            <option value="@pat.Id" selected="selected">@pat.User.FullName (@pat.User.Email)</option>
                                        }
                                        else
                                        {
                                            <option value="@pat.Id">@pat.User.FullName (@pat.User.Email)</option>
                                        }
                                    }
                                }
                            </select>
                            <span class="text-danger small"></span>
                        </div>
                    }

                    <!-- Visit Select -->
                    <div class="col-md-6">
                        <label class="form-label small fw-600">Link Clinical Visit Reference</label>
                        <select name="appointmentId" class="form-select">
                            <option value="">None (General file upload)</option>
                            @if (appointments != null)
                            {
                                foreach (var app in appointments)
                                {
                                    if (app.Id == selectedAppointmentId)
                                    {
                                        <option value="@app.Id" selected="selected">Appt #@app.Id - @app.Patient.User.FullName with Dr. @app.Doctor.User.FullName (@app.AppointmentDateTime.ToString("dd MMM yyyy"))</option>
                                    }
                                    else
                                    {
                                        <option value="@app.Id">Appt #@app.Id - @app.Patient.User.FullName with Dr. @app.Doctor.User.FullName (@app.AppointmentDateTime.ToString("dd MMM yyyy"))</option>
                                    }
                                }
                            }
                        </select>
                    </div>

                    <!-- File Select -->
                    <div class="col-md-12">
                        <label class="form-label small fw-600">Select File Document *</label>
                        <input type="file" name="file" class="form-control" required />
                        <span class="text-muted font-size-xs">Allowed formats: PDF, PNG, JPG, JPEG, DOCX. Max file size: 10MB.</span>
                    </div>
                </div>

                <div class="d-flex gap-2">
                    <button type="submit" class="btn btn-primary px-4 py-2 border-0" style="background: var(--primary-color); border-radius: 8px;">
                        <i class="fa-solid fa-cloud-arrow-up me-1"></i> Start Upload
                    </button>
                    <a asp-action="Index" class="btn btn-outline-secondary px-4 py-2" style="border-radius: 8px;">Cancel</a>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        // Form Validation
        (function () {
            'use strict'
            var forms = document.querySelectorAll('.needs-validation')
            Array.prototype.slice.call(forms)
                .forEach(function (form) {
                    form.addEventListener('submit', function (event) {
                        if (!form.checkValidity()) {
                            event.preventDefault()
                            event.stopPropagation()
                        }
                        form.classList.add('was-validated')
                    }, false)
                })
        })()
    </script>
}
