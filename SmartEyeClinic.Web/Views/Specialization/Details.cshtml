@model SmartEyeClinic.Models.Specialization
@{
    ViewData["Title"] = $"{Model.Name} - Smart Eye Clinic";
}

<div class="container-fluid py-4">
    <!-- Breadcrumb -->
    <nav aria-label="breadcrumb" class="mb-4">
        <ol class="breadcrumb">
            <li class="breadcrumb-item"><a asp-controller="Home" asp-action="Index">Dashboard</a></li>
            <li class="breadcrumb-item"><a asp-controller="Specialization" asp-action="Index">Specializations</a></li>
            <li class="breadcrumb-item active" aria-current="page">Details</li>
        </ol>
    </nav>

    <!-- Header -->
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h3 class="fw-bold text-dark mb-1">@Model.Name Department</h3>
            <p class="text-muted small mb-0">Overview of ophthalmology specialization department #@Model.Id.</p>
        </div>
        <div class="d-flex gap-2">
            @if (User.IsInRole("Admin"))
            {
                <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-primary px-3 py-2 border-0" style="background: var(--primary-color); border-radius: 8px;">
                    <i class="fa-regular fa-pen-to-square me-1"></i> Edit
                </a>
                <a asp-action="Delete" asp-route-id="@Model.Id" class="btn btn-danger px-3 py-2 border-0" style="border-radius: 8px;">
                    <i class="fa-solid fa-trash me-1"></i> Delete
                </a>
            }
        </div>
    </div>

    <div class="row g-4">
        <!-- Dept Profile Card -->
        <div class="col-lg-4">
            <div class="card border-0 shadow-sm rounded-4 p-4 mb-4" style="background: var(--card-bg);">
                <div class="text-center">
                    <span class="bg-light-primary text-primary rounded-circle px-3.5 py-3 d-inline-block mb-3"><i class="fa-solid fa-tags fs-3"></i></span>
                    <h5 class="fw-bold mb-1">@Model.Name</h5>
                    <span class="text-muted small">Specialization Code: #@Model.Id</span>
                </div>
                <hr class="text-muted opacity-25 my-4" />
                <p class="text-muted small mb-0">@(string.IsNullOrEmpty(Model.Description) ? "No specialization description has been filled out." : Model.Description)</p>
            </div>
        </div>

        <!-- Doctors Assigned Card -->
        <div class="col-lg-8">
            <div class="card border-0 shadow-sm rounded-4" style="background: var(--card-bg);">
                <div class="card-header bg-transparent border-bottom p-3">
                    <h5 class="fw-bold text-dark mb-0"><i class="fa-solid fa-user-md text-primary me-2"></i> Specialists Assigned</h5>
                </div>
                <div class="card-body p-4">
                    @if (Model.Doctors == null || !Model.Doctors.Any())
                    {
                        <div class="text-center py-4">
                            <i class="fa-solid fa-user-minus fs-1 text-muted mb-2 d-block"></i>
                            <span class="text-muted small">No specialized doctors are registered under this department yet.</span>
                        </div>
                    }
                    else
                    {
                        <div class="table-responsive">
                            <table class="table custom-table small">
                                <thead>
                                    <tr>
                                        <th>Doctor Name</th>
                                        <th>License Number</th>
                                        <th>Consultation Fee</th>
                                        <th>Actions</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var doc in Model.Doctors)
                                    {
                                        <tr>
                                            <td>
                                                <div class="d-flex align-items-center">
                                                    <img src="@(string.IsNullOrEmpty(doc.User.ProfilePicture) ? "https://images.unsplash.com/photo-1622253692010-333f2da6031d?q=80&w=48&auto=format&fit=crop" : doc.User.ProfilePicture)" class="rounded-circle me-2" style="width: 32px; height: 32px; object-fit: cover;" />
                                                    <strong>Dr. @doc.User.FullName</strong>
                                                </div>
                                            </td>
                                            <td>@doc.LicenseNumber</td>
                                            <td>$@doc.ConsultationFee.ToString("F2")</td>
                                            <td>
                                                <a asp-controller="Doctor" asp-action="Details" asp-route-id="@doc.Id" class="btn btn-xs btn-outline-primary">Profile</a>
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>
</div>
