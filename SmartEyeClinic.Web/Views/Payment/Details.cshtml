@model SmartEyeClinic.Models.Payment
@{
    ViewData["Title"] = $"Payment Receipt #{Model.Id} - Smart Eye Clinic";
}

<div class="container-fluid py-4">
    <!-- Breadcrumb -->
    <nav aria-label="breadcrumb" class="mb-4">
        <ol class="breadcrumb">
            <li class="breadcrumb-item"><a asp-controller="Home" asp-action="Index">Dashboard</a></li>
            <li class="breadcrumb-item"><a asp-controller="Payment" asp-action="Index">Payments</a></li>
            <li class="breadcrumb-item active" aria-current="page">Receipt #@Model.Id</li>
        </ol>
    </nav>

    <!-- Header / Actions -->
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h3 class="fw-bold text-dark mb-1">Payment Receipt</h3>
            <p class="text-muted small mb-0">Official transactional record for payment #@Model.Id.</p>
        </div>
        <div class="d-flex gap-2">
            <button onclick="window.print()" class="btn btn-outline-dark px-3 py-2" style="border-radius: 8px;">
                <i class="fa-solid fa-print me-1"></i> Print Receipt
            </button>
            @if (User.IsInRole("Admin"))
            {
                <a asp-action="Delete" asp-route-id="@Model.Id" class="btn btn-danger px-3 py-2 border-0" style="border-radius: 8px;">
                    <i class="fa-solid fa-rotate-left me-1"></i> Reverse Payment
                </a>
            }
        </div>
    </div>

    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show rounded-3 mb-4" role="alert">
            <i class="fa-solid fa-circle-check me-2"></i> @TempData["Success"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    <div class="row g-4">
        <!-- Receipt Details Sheet -->
        <div class="col-lg-6">
            <div class="card border-0 shadow-sm rounded-4 p-5 receipt-print-card" style="background: var(--card-bg);">
                <div class="text-center mb-4">
                    <div class="text-success display-5 mb-2"><i class="fa-solid fa-circle-check"></i></div>
                    <h4 class="fw-bold text-dark mb-1">Transaction Successful</h4>
                    <span class="text-muted small">Payment Ref: #@Model.Id</span>
                </div>

                <hr class="my-4 text-muted opacity-25" />

                <div class="mb-4">
                    <div class="d-flex justify-content-between mb-2">
                        <span class="text-muted small">Date & Time:</span>
                        <strong class="text-dark">@(Model.PaidAt.HasValue ? Model.PaidAt.Value.ToString("dd MMM yyyy, hh:mm tt") : "N/A")</strong>
                    </div>
                    <div class="d-flex justify-content-between mb-2">
                        <span class="text-muted small">Payment Method:</span>
                        <span class="badge bg-light text-dark px-2.5 py-1.5 border">@Model.PaymentMethod.Name</span>
                    </div>
                    <div class="d-flex justify-content-between mb-2">
                        <span class="text-muted small">Transaction Ref:</span>
                        <strong class="text-dark font-monospace">@(string.IsNullOrEmpty(Model.TransactionRef) ? "-" : Model.TransactionRef)</strong>
                    </div>
                    <div class="d-flex justify-content-between mb-2">
                        <span class="text-muted small">Paid By Patient:</span>
                        <strong class="text-dark">@Model.Invoice.Patient.User.FullName</strong>
                    </div>
                    <div class="d-flex justify-content-between">
                        <span class="text-muted small">Invoice Link:</span>
                        <a asp-controller="Invoice" asp-action="Details" asp-route-id="@Model.InvoiceId" class="text-primary fw-500">@Model.Invoice.InvoiceNumber</a>
                    </div>
                </div>

                <div class="p-3 bg-light rounded-4 text-center">
                    <span class="text-muted small d-block">Amount Received</span>
                    <strong class="text-primary fs-3">$@Model.Amount.ToString("F2")</strong>
                </div>

                <hr class="my-4 text-muted opacity-25" />

                <div class="text-center text-muted small">
                    <span>Smart Eye Clinic ERP System. Thank you for your payment.</span>
                </div>
            </div>
        </div>
    </div>
</div>

<style>
    @@media print {
        body {
            background-color: #ffffff !important;
            color: #000000 !important;
        }
        .receipt-print-card {
            box-shadow: none !important;
            padding: 0 !important;
            border: none !important;
            background: transparent !important;
        }
        #sidebar, .top-navbar, footer, .no-print, nav {
            display: none !important;
        }
        #content {
            margin-left: 0 !important;
            padding: 0 !important;
            width: 100% !important;
        }
    }
</style>
