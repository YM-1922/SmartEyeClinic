@model List<SmartEyeClinic.Models.Payment>
@{
    ViewData["Title"] = "Payments - Smart Eye Clinic";
}

<div class="page-header">
    <div class="page-header-left">
        <nav class="breadcrumb-nav">
            <a asp-controller="Home" asp-action="Index">Home</a>
            <span class="separator">/</span>
            <span class="current">Payments</span>
        </nav>
        <h3 class="page-title">Payment Transactions</h3>
        <p class="page-subtitle">Track ledger deposits, refunds, and financial transaction references</p>
    </div>
    <div class="d-flex gap-2">
        @if (User.IsInRole("Admin") || User.IsInRole("Receptionist"))
        {
            <a asp-action="Methods" class="btn btn-light">
                <i class="fa-solid fa-list-check"></i> Payment Methods
            </a>
            <a asp-action="Create" class="btn btn-primary">
                <i class="fa-solid fa-credit-card"></i> Record Payment
            </a>
        }
    </div>
</div>

<div class="table-card">
    <div class="table-card-header">
        <h5 class="table-title">
            <i class="fa-solid fa-credit-card text-primary"></i> Transaction Ledger
        </h5>
    </div>
    <div class="card-body-clean p-4">
        @if (!Model.Any())
        {
            <div class="empty-state">
                <div class="empty-state-icon">
                    <i class="fa-solid fa-credit-card"></i>
                </div>
                <h5>No Payments Recorded</h5>
                <p>Record deposits against outstanding diagnostic/consultation invoices.</p>
                @if (User.IsInRole("Admin") || User.IsInRole("Receptionist"))
                {
                    <a asp-action="Create" class="btn btn-primary"><i class="fa-solid fa-credit-card"></i> Record Payment</a>
                }
            </div>
        }
        else
        {
            <div class="table-responsive-custom">
                <table class="table datatable custom-table">
                    <thead>
                        <tr>
                            <th>#</th>
                            <th>Invoice #</th>
                            <th>Patient</th>
                            <th>Method</th>
                            <th>Amount</th>
                            <th>Date</th>
                            <th class="text-end">Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var p in Model)
                        {
                            <tr>
                                <td><span class="text-muted font-monospace small">#@p.Id</span></td>
                                <td><span class="fw-bold text-primary-custom font-monospace">@p.Invoice?.InvoiceNumber</span></td>
                                <td>
                                    <div class="d-flex align-items-center">
                                        <div class="avatar-initials avatar-sm me-2 bg-light-success text-success">
                                            @(p.Invoice?.Patient?.User?.FullName?.Length > 0 ? p.Invoice.Patient.User.FullName[0].ToString().ToUpper() : "P")
                                        </div>
                                        <div class="d-flex flex-column">
                                            <span class="fw-600 text-dark">@p.Invoice?.Patient?.User?.FullName</span>
                                            <span class="text-xs text-muted">ID: #@p.Invoice?.PatientId</span>
                                        </div>
                                    </div>
                                </td>
                                <td>
                                    <span class="pill pill-primary">
                                        <i class="fa-solid fa-money-bill-wave me-1"></i>@p.PaymentMethod?.Name
                                    </span>
                                </td>
                                <td><span class="fw-bold text-success fs-6">@p.Amount.ToString("C")</span></td>
                                <td>
                                    <span class="d-block fw-500">@p.PaidAt?.ToString("dd MMM yyyy")</span>
                                    <span class="text-xs text-muted">@p.PaidAt?.ToString("hh:mm tt")</span>
                                </td>
                                <td class="text-end">
                                    <div class="action-btns justify-content-end">
                                        <a asp-action="Details" asp-route-id="@p.Id" class="btn btn-sm btn-light" title="View Details">
                                            <i class="fa-solid fa-eye text-muted"></i> Details
                                        </a>
                                        @if (User.IsInRole("Admin"))
                                        {
                                            <form asp-action="Delete" asp-route-id="@p.Id" method="post" class="d-inline" data-confirm="Are you sure you want to reverse and delete this payment record? This will adjust the linked invoice balance." data-item="Payment #@p.Id">
                                                @Html.AntiForgeryToken()
                                                <button type="submit" class="btn btn-sm btn-custom-danger" title="Reverse Payment">
                                                    <i class="fa-solid fa-arrow-rotate-left"></i> Revert
                                                </button>
                                            </form>
                                        }
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
    </div>
</div>
