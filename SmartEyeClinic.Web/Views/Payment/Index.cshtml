@model List<SmartEyeClinic.Models.Payment>
@{
    ViewData["Title"] = "Payments - Smart Eye Clinic";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <ul class="breadcrumb-custom mb-1">
            <li><a asp-controller="Home" asp-action="Index">Home</a></li>
            <li>Payments</li>
        </ul>
        <h3 class="fw-bold text-dark mb-0">Payment Transactions</h3>
    </div>
    <div class="d-flex gap-2">
        <a asp-action="Methods" class="btn btn-custom btn-custom-secondary">
            <i class="fa-solid fa-list"></i> Payment Methods
        </a>
        <a asp-action="Create" class="btn btn-custom btn-custom-primary">
            <i class="fa-solid fa-credit-card"></i> Record Payment
        </a>
    </div>
</div>

@if (TempData["Success"] != null)
{
    <div class="alert alert-success alert-custom d-flex align-items-center mb-4">
        <i class="fa-solid fa-circle-check fs-5 me-2"></i> <div>@TempData["Success"]</div>
    </div>
}
@if (TempData["Error"] != null)
{
    <div class="alert alert-danger alert-custom d-flex align-items-center mb-4">
        <i class="fa-solid fa-circle-exclamation fs-5 me-2"></i> <div>@TempData["Error"]</div>
    </div>
}

<div class="card custom-card">
    <div class="card-header-clean">
        <div class="d-flex align-items-center">
            <i class="fa-solid fa-credit-card text-primary me-2 fs-5"></i>
            <h5 class="mb-0">Transaction Ledger</h5>
        </div>
        <div class="text-muted small">Total: @Model.Count transactions</div>
    </div>
    <div class="card-body-clean">
        @if (!Model.Any())
        {
            <div class="text-center py-5">
                <i class="fa-solid fa-credit-card text-muted fs-1 mb-3 d-block"></i>
                <h5 class="fw-bold text-dark mb-2">No Payments Recorded</h5>
                <p class="text-muted small mb-4">Record payments against outstanding invoices.</p>
                <a asp-action="Create" class="btn btn-custom btn-custom-primary"><i class="fa-solid fa-credit-card"></i> Record First Payment</a>
            </div>
        }
        else
        {
            <div class="table-responsive-custom">
                <table class="table custom-table">
                    <thead>
                        <tr>
                            <th>#</th>
                            <th>Invoice #</th>
                            <th>Patient</th>
                            <th>Method</th>
                            <th>Amount</th>
                            <th>Date</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var p in Model)
                        {
                            <tr>
                                <td><span class="text-muted font-monospace small">#@p.Id</span></td>
                                <td><span class="fw-bold text-primary font-monospace">@p.Invoice?.InvoiceNumber</span></td>
                                <td>
                                    <div class="d-flex align-items-center">
                                        <div class="me-2 text-white fw-bold text-center rounded-circle" style="width:32px;height:32px;line-height:32px;font-size:0.8rem;background:#22C55E;">
                                            @(p.Invoice?.Patient?.User?.FullName?.Length > 0 ? p.Invoice.Patient.User.FullName[0].ToString().ToUpper() : "P")
                                        </div>
                                        <span>@p.Invoice?.Patient?.User?.FullName</span>
                                    </div>
                                </td>
                                <td>
                                    <span class="badge-custom" style="background:rgba(15,76,129,0.08);color:#0F4C81;">
                                        <i class="fa-solid fa-money-bill-wave me-1"></i>@p.PaymentMethod?.Name
                                    </span>
                                </td>
                                <td><span class="fw-bold text-success fs-6">@p.Amount.ToString("C")</span></td>
                                <td>
                                    <span class="d-block">@p.PaidAt?.ToString("dd MMM yyyy")</span>
                                    <span class="text-muted small">@p.PaidAt?.ToString("hh:mm tt")</span>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
    </div>
</div>
