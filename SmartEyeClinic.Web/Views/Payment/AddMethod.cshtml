@{
    ViewData["Title"] = "Add Payment Method - Smart Eye Clinic";
}

<div class="mb-4">
    <ul class="breadcrumb-custom mb-1">
        <li><a asp-controller="Home" asp-action="Index">Home</a></li>
        <li><a asp-controller="Payment" asp-action="Index">Payments</a></li>
        <li><a asp-action="Methods">Payment Methods</a></li>
        <li>Add Method</li>
    </ul>
    <h3 class="fw-bold text-dark mb-0">Add Payment Method</h3>
</div>

@if (TempData["Error"] != null)
{
    <div class="alert alert-danger alert-custom d-flex align-items-center mb-4">
        <i class="fa-solid fa-circle-exclamation fs-5 me-2"></i> <div>@TempData["Error"]</div>
    </div>
}

<div class="card custom-card" style="max-width:500px;">
    <div class="card-header-clean">
        <div class="d-flex align-items-center">
            <i class="fa-solid fa-plus text-primary me-2 fs-5"></i>
            <h5 class="mb-0">New Payment Method Details</h5>
        </div>
    </div>
    <div class="card-body-clean">
        <form asp-action="AddMethod" method="post">
            @Html.AntiForgeryToken()
            <div class="mb-4">
                <label class="form-label-custom">Method Name (e.g. Cash, Visa, Insurance)</label>
                <div class="input-group">
                    <span class="input-group-text bg-white border-end-0"><i class="fa-solid fa-credit-card text-muted"></i></span>
                    <input type="text" name="name" class="form-control form-control-custom border-start-0 ps-0" placeholder="e.g. Visa Card" required />
                </div>
            </div>
            <div class="border-top pt-4 d-flex justify-content-end">
                <a asp-action="Methods" class="btn btn-custom btn-custom-secondary me-2"><i class="fa-solid fa-xmark"></i> Cancel</a>
                <button type="submit" class="btn btn-custom btn-custom-primary"><i class="fa-solid fa-floppy-disk"></i> Save Method</button>
            </div>
        </form>
    </div>
</div>
