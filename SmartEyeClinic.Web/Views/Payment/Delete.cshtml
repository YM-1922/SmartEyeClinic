@model SmartEyeClinic.Models.Payment
@{
    ViewData["Title"] = $"Reverse Payment #{Model.Id} - Smart Eye Clinic";
}

<div class="container-fluid py-4">
    <!-- Breadcrumb -->
    <nav aria-label="breadcrumb" class="mb-4">
        <ol class="breadcrumb">
            <li class="breadcrumb-item"><a asp-controller="Home" asp-action="Index">Dashboard</a></li>
            <li class="breadcrumb-item"><a asp-controller="Payment" asp-action="Index">Payments</a></li>
            <li class="breadcrumb-item"><a asp-controller="Payment" asp-action="Details" asp-route-id="@Model.Id">Receipt #@Model.Id</a></li>
            <li class="breadcrumb-item active" aria-current="page">Reverse</li>
        </ol>
    </nav>

    <div class="row justify-content-center">
        <div class="col-lg-6">
            <div class="card border-0 shadow-sm rounded-4" style="background: var(--card-bg);">
                <div class="card-header bg-transparent border-bottom text-center p-4">
                    <div class="text-danger display-4 mb-3"><i class="fa-solid fa-rotate-left"></i></div>
                    <h4 class="fw-bold text-dark">Reverse Payment Transaction</h4>
                    <p class="text-muted small mb-0">Are you sure you want to reverse this payment and refund the patient?</p>
                </div>
                <div class="card-body p-4">
                    <div class="alert alert-warning small rounded-3 mb-4">
                        <i class="fa-solid fa-triangle-exclamation me-2"></i><strong>Warning:</strong> Reversing payment #@Model.Id will deduct $@Model.Amount.ToString("F2") from the settled paid amount on Invoice <strong class="text-dark">@Model.Invoice.InvoiceNumber</strong>. The invoice status will revert to "Partial" or "Unpaid". This action cannot be undone.
                    </div>

                    <ul class="list-group list-group-flush mb-4">
                        <li class="list-group-item d-flex justify-content-between align-items-center px-0 bg-transparent">
                            <span class="text-muted small">Payment ID</span>
                            <span class="text-dark fw-bold">#@Model.Id</span>
                        </li>
                        <li class="list-group-item d-flex justify-content-between align-items-center px-0 bg-transparent">
                            <span class="text-muted small">Patient Name</span>
                            <span class="text-dark fw-bold">@Model.Invoice.Patient.User.FullName</span>
                        </li>
                        <li class="list-group-item d-flex justify-content-between align-items-center px-0 bg-transparent">
                            <span class="text-muted small">Linked Invoice</span>
                            <span class="text-dark fw-bold">@Model.Invoice.InvoiceNumber</span>
                        </li>
                        <li class="list-group-item d-flex justify-content-between align-items-center px-0 bg-transparent">
                            <span class="text-muted small">Reversal Amount</span>
                            <span class="text-danger fw-bold">-$@Model.Amount.ToString("F2")</span>
                        </li>
                    </ul>

                    <form asp-action="Delete" method="post">
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="id" value="@Model.Id" />
                        <div class="d-flex gap-2">
                            <button type="submit" class="btn btn-danger w-100 py-2.5" style="border-radius: 8px;">
                                <i class="fa-solid fa-rotate-left me-2"></i> Confirm Reversal
                            </button>
                            <a asp-action="Details" asp-route-id="@Model.Id" class="btn btn-outline-secondary w-100 py-2.5" style="border-radius: 8px;">Cancel</a>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>
