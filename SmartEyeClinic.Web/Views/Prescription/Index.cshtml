@model List<SmartEyeClinic.Models.PrescriptionItem>
@{
    ViewData["Title"] = "Prescriptions - Smart Eye Clinic";
    var doctorIdString = User.FindFirst("DoctorId")?.Value;
}

<div class="page-header">
    <div class="page-header-left">
        <nav class="breadcrumb-nav">
            <a asp-controller="Home" asp-action="Index">Home</a>
            <span class="separator">/</span>
            <span class="current">Prescriptions</span>
        </nav>
        <h3 class="page-title">Patient Prescriptions</h3>
        <p class="page-subtitle">View and generate drug prescriptions linked to clinical visual examinations</p>
    </div>
    @if (User.IsInRole("Doctor") || User.IsInRole("Admin"))
    {
        <a asp-action="Create" class="btn btn-primary">
            <i class="fa-solid fa-file-prescription"></i> Create Prescription
        </a>
    }
</div>

<div class="table-card">
    <div class="table-card-header">
        <h5 class="table-title">
            <i class="fa-solid fa-file-prescription text-primary"></i> Prescription History
        </h5>
    </div>
    <div class="card-body-clean p-4">
        @if (!Model.Any())
        {
            <div class="empty-state">
                <div class="empty-state-icon">
                    <i class="fa-solid fa-file-prescription"></i>
                </div>
                <h5>No Prescriptions Found</h5>
                <p>Create prescriptions following clinical examinations.</p>
                @if (User.IsInRole("Doctor") || User.IsInRole("Admin"))
                {
                    <a asp-action="Create" class="btn btn-primary"><i class="fa-solid fa-file-prescription"></i> Create Prescription</a>
                }
            </div>
        }
        else
        {
            <div class="table-responsive-custom">
                <table class="table datatable custom-table">
                    <thead>
                        <tr>
                            <th>#</th>
                            <th>Patient</th>
                            <th>Doctor</th>
                            <th>Medicine</th>
                            <th>Dosage</th>
                            <th>Duration</th>
                            <th class="text-end">Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var p in Model)
                        {
                            <tr>
                                <td><span class="text-muted font-monospace small">#@p.Id</span></td>
                                <td>
                                    <div class="d-flex align-items-center">
                                        <div class="avatar-initials avatar-sm me-2 bg-light-primary text-primary-custom">
                                            @(p.PrescriptionHeader?.Examination?.Appointment?.Patient?.User?.FullName?.Length > 0 ? p.PrescriptionHeader.Examination.Appointment.Patient.User.FullName[0].ToString().ToUpper() : "P")
                                        </div>
                                        <div class="d-flex flex-column">
                                            <span class="fw-600 text-dark">@p.PrescriptionHeader?.Examination?.Appointment?.Patient?.User?.FullName</span>
                                            <span class="text-xs text-muted">ID: #@p.PrescriptionHeader?.Examination?.Appointment?.PatientId</span>
                                        </div>
                                    </div>
                                </td>
                                <td>
                                    <span class="fw-500 text-dark">Dr. @p.PrescriptionHeader?.Examination?.Appointment?.Doctor?.User?.FullName</span>
                                </td>
                                <td>
                                    <div class="d-flex align-items-center">
                                        <i class="fa-solid fa-capsules text-warning me-2"></i>
                                        <span class="fw-600 text-dark">@p.Medicine?.Name</span>
                                    </div>
                                </td>
                                <td><span class="pill pill-success">@p.Dosage</span></td>
                                <td>
                                    @if (p.DurationDays.HasValue)
                                    {
                                        <span class="text-dark fw-500"><i class="fa-regular fa-clock me-1 text-muted"></i>@p.DurationDays days</span>
                                    }
                                    else
                                    { <span class="text-muted">—</span> }
                                </td>
                                <td class="text-end">
                                    <div class="action-btns justify-content-end">
                                        <a asp-action="Details" asp-route-id="@p.PrescriptionId" class="btn btn-sm btn-light" title="View Print RX Sheet">
                                            <i class="fa-solid fa-print text-muted"></i> Rx Sheet
                                        </a>
                                        @if (User.IsInRole("Admin") || (User.IsInRole("Doctor") && doctorIdString == p.PrescriptionHeader?.Examination?.Appointment?.DoctorId.ToString()))
                                        {
                                            <form asp-action="Delete" asp-route-id="@p.PrescriptionId" method="post" class="d-inline" data-confirm="Are you sure you want to delete this prescription?" data-item="Prescription Header #@p.PrescriptionId">
                                                @Html.AntiForgeryToken()
                                                <button type="submit" class="btn btn-sm btn-custom-danger" title="Delete">
                                                    <i class="fa-solid fa-trash-can"></i>
                                                </button>
                                            </form>
                                        }
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
    </div>
</div>
