@model SmartEyeClinic.Models.PrescriptionHeader
@{
    ViewData["Title"] = $"Prescription Rx #{Model.Id} - Smart Eye Clinic";
    var dob = Model.Examination?.Appointment?.Patient?.DateOfBirth;
    var ageStr = dob.HasValue ? (DateTime.Now.Year - dob.Value.Year).ToString() : "N/A";
}

<div class="container-fluid py-4 no-print">
    <!-- Breadcrumb -->
    <nav aria-label="breadcrumb" class="mb-4">
        <ol class="breadcrumb">
            <li class="breadcrumb-item"><a asp-controller="Home" asp-action="Index">Dashboard</a></li>
            <li class="breadcrumb-item"><a asp-controller="Prescription" asp-action="Index">Prescriptions</a></li>
            <li class="breadcrumb-item active" aria-current="page">Rx Sheet</li>
        </ol>
    </nav>

    <!-- Header / Actions -->
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h3 class="fw-bold text-dark mb-1">Prescription Details</h3>
            <p class="text-muted small mb-0">View or print official drug prescription sheets.</p>
        </div>
        <div class="d-flex gap-2">
            <button onclick="window.print()" class="btn btn-outline-dark px-3 py-2" style="border-radius: 8px;">
                <i class="fa-solid fa-print me-1"></i> Print Rx Script
            </button>
            @if (User.IsInRole("Admin"))
            {
                <a asp-action="Delete" asp-route-id="@Model.Id" class="btn btn-danger px-3 py-2 border-0" style="border-radius: 8px;">
                    <i class="fa-solid fa-trash me-1"></i> Delete
                </a>
            }
        </div>
    </div>
</div>

<!-- Prescription Sheet -->
<div class="container py-2">
    <div class="card border-0 shadow-sm rounded-4 p-5 prescription-print-card" style="background: var(--card-bg);">
        <!-- Rx Clinic Header -->
        <div class="row mb-5">
            <div class="col-sm-6">
                <div class="d-flex align-items-center mb-3">
                    <i class="fa-solid fa-house-medical fa-2x text-primary me-2"></i>
                    <h3 class="fw-bold text-dark mb-0">Smart Eye Clinic</h3>
                </div>
                <p class="text-muted small mb-0">120 Clinical Road, Healthcare District</p>
                <p class="text-muted small mb-0">Phone: +1 (555) 234-5678 | info@@smarteyeclinic.com</p>
            </div>
            <div class="col-sm-6 text-sm-end mt-4 mt-sm-0">
                <h2 class="text-primary fw-bold mb-1" style="font-family: 'Georgia', serif;">Rx</h2>
                <div class="small mb-1"><span class="text-muted">Prescription ID:</span> <strong class="text-dark">#@Model.Id</strong></div>
                <div class="small"><span class="text-muted">Issued Date:</span> <strong class="text-dark">@(Model.CreatedAt.HasValue ? Model.CreatedAt.Value.ToString("dd MMM yyyy") : "N/A")</strong></div>
            </div>
        </div>

        <hr class="my-4 text-muted opacity-25" />

        <!-- Doctor / Patient Row -->
        <div class="row mb-5">
            <div class="col-6">
                <h6 class="text-muted text-uppercase fw-bold small mb-2">Patient</h6>
                <h5 class="fw-bold text-dark mb-1">@Model.Examination?.Appointment?.Patient?.User?.FullName</h5>
                <span class="text-muted small d-block">Age: @ageStr</span>
                <span class="text-muted small d-block">Gender: @Model.Examination?.Appointment?.Patient?.Gender</span>
            </div>
            <div class="col-6 text-end">
                <h6 class="text-muted text-uppercase fw-bold small mb-2">Prescribing Ophthalmologist</h6>
                <h5 class="fw-bold text-dark mb-1">Dr. @Model.Examination?.Appointment?.Doctor?.User?.FullName</h5>
                <span class="text-muted small d-block">License: @Model.Examination?.Appointment?.Doctor?.LicenseNumber</span>
                <span class="text-muted small d-block">Specialization: @Model.Examination?.Appointment?.Doctor?.Specialization?.Name</span>
            </div>
        </div>

        <!-- Prescribed Medicines -->
        <div class="table-responsive mb-5">
            <table class="table custom-table table-bordered">
                <thead class="bg-light text-uppercase small font-size-xs">
                    <tr>
                        <th style="width: 5%">#</th>
                        <th style="width: 35%">Medicine Name</th>
                        <th style="width: 20%">Dosage</th>
                        <th style="width: 15%">Duration</th>
                        <th style="width: 25%">Instructions</th>
                    </tr>
                </thead>
                <tbody>
                    @{ int i = 1; }
                    @foreach (var item in Model.PrescriptionItems)
                    {
                        <tr>
                            <td>@(i++)</td>
                            <td>
                                <strong>@item.Medicine.Name</strong>
                                <span class="d-block text-muted small">@item.Medicine.Description</span>
                            </td>
                            <td>@item.Dosage</td>
                            <td>@item.DurationDays Days</td>
                            <td>@item.Instructions</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>

        <!-- Signature Area -->
        <div class="row justify-content-end mt-5 pt-4">
            <div class="col-sm-5 text-center">
                <div class="border-bottom pb-4 mb-2" style="border-bottom-style: dashed !important;">
                    <!-- Placeholder digital signature or clinic stamp -->
                    <span class="text-muted font-italic small opacity-50">[Doctor Digital Signature]</span>
                </div>
                <span class="text-muted small">Authorized Doctor Stamp / Signature</span>
            </div>
        </div>
    </div>
</div>

<style>
    @@media print {
        .no-print {
            display: none !important;
        }
        body {
            background-color: #ffffff !important;
            color: #000000 !important;
        }
        .prescription-print-card {
            box-shadow: none !important;
            padding: 0 !important;
            border: none !important;
            background: transparent !important;
        }
        #sidebar, .top-navbar, footer {
            display: none !important;
        }
        #content {
            margin-left: 0 !important;
            padding: 0 !important;
            width: 100% !important;
        }
    }
</style>
