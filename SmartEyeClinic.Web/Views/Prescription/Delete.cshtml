@model SmartEyeClinic.Models.PrescriptionHeader
@{
    ViewData["Title"] = $"Delete Prescription Rx #{Model.Id} - Smart Eye Clinic";
}

<div class="container-fluid py-4">
    <!-- Breadcrumb -->
    <nav aria-label="breadcrumb" class="mb-4">
        <ol class="breadcrumb">
            <li class="breadcrumb-item"><a asp-controller="Home" asp-action="Index">Dashboard</a></li>
            <li class="breadcrumb-item"><a asp-controller="Prescription" asp-action="Index">Prescriptions</a></li>
            <li class="breadcrumb-item"><a asp-controller="Prescription" asp-action="Details" asp-route-id="@Model.Id">Rx #@Model.Id</a></li>
            <li class="breadcrumb-item active" aria-current="page">Delete</li>
        </ol>
    </nav>

    <div class="row justify-content-center">
        <div class="col-lg-6">
            <div class="card border-0 shadow-sm rounded-4" style="background: var(--card-bg);">
                <div class="card-header bg-transparent border-bottom text-center p-4">
                    <div class="text-danger display-4 mb-3"><i class="fa-solid fa-triangle-exclamation"></i></div>
                    <h4 class="fw-bold text-dark">Confirm Prescription Deletion</h4>
                    <p class="text-muted small mb-0">Are you sure you want to permanently delete this drug prescription script?</p>
                </div>
                <div class="card-body p-4">
                    <div class="alert alert-warning small rounded-3 mb-4">
                        <i class="fa-solid fa-triangle-exclamation me-2"></i><strong>Warning:</strong> Deleting this prescription will permanently erase all prescribed medicine items linked to it from the patient's medical history. This action cannot be undone.
                    </div>

                    <ul class="list-group list-group-flush mb-4">
                        <li class="list-group-item d-flex justify-content-between align-items-center px-0 bg-transparent">
                            <span class="text-muted small">Prescription ID</span>
                            <span class="text-dark fw-bold">#@Model.Id</span>
                        </li>
                        <li class="list-group-item d-flex justify-content-between align-items-center px-0 bg-transparent">
                            <span class="text-muted small">Patient Name</span>
                            <span class="text-dark fw-bold">@Model.Examination.Appointment.Patient.User.FullName</span>
                        </li>
                        <li class="list-group-item d-flex justify-content-between align-items-center px-0 bg-transparent">
                            <span class="text-muted small">Prescribing Doctor</span>
                            <span class="text-dark">Dr. @Model.Examination.Appointment.Doctor.User.FullName</span>
                        </li>
                        <li class="list-group-item d-flex justify-content-between align-items-center px-0 bg-transparent">
                            <span class="text-muted small">Created Date</span>
                            <span class="text-dark">@(Model.CreatedAt.HasValue ? Model.CreatedAt.Value.ToString("dd MMM yyyy, hh:mm tt") : "N/A")</span>
                        </li>
                    </ul>

                    <form asp-action="Delete" method="post">
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="id" value="@Model.Id" />
                        <div class="d-flex gap-2">
                            <button type="submit" class="btn btn-danger w-100 py-2.5" style="border-radius: 8px;">
                                <i class="fa-solid fa-trash me-2"></i> Yes, Delete Prescription
                            </button>
                            <a asp-action="Details" asp-route-id="@Model.Id" class="btn btn-outline-secondary w-100 py-2.5" style="border-radius: 8px;">Cancel</a>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>
