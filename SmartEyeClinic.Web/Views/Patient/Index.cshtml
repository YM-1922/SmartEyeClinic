@model List<SmartEyeClinic.Models.Patient>
@{
    ViewData["Title"] = "Patients Directory - Smart Eye Clinic";
}

<!-- Page Header -->
<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <ul class="breadcrumb-custom mb-1">
            <li><a asp-controller="Home" asp-action="Index">Home</a></li>
            <li>Patients Directory</li>
        </ul>
        <h3 class="fw-bold text-dark mb-0">Patients Directory</h3>
    </div>
    <div>
        <a asp-action="Create" class="btn btn-custom btn-custom-primary">
            <i class="fa-solid fa-user-plus"></i> Add New Patient
        </a>
    </div>
</div>

<!-- Alerts -->
@if (TempData["Success"] != null)
{
    <div class="alert alert-success alert-custom d-flex align-items-center mb-4" role="alert">
        <i class="fa-solid fa-circle-check fs-5 me-2"></i>
        <div>@TempData["Success"]</div>
    </div>
}
@if (TempData["Error"] != null)
{
    <div class="alert alert-danger alert-custom d-flex align-items-center mb-4" role="alert">
        <i class="fa-solid fa-circle-exclamation fs-5 me-2"></i>
        <div>@TempData["Error"]</div>
    </div>
}

<!-- Directory Card -->
<div class="card custom-card">
    <div class="card-header-clean">
        <div class="d-flex align-items-center">
            <i class="fa-solid fa-hospital-user text-primary me-2 fs-5"></i>
            <h5 class="mb-0">Patient Register List</h5>
        </div>
        <div class="text-muted small">Total: @Model.Count registered</div>
    </div>
    <div class="card-body-clean">
        @if (Model == null || !Model.Any())
        {
            <div class="text-center py-5">
                <div class="p-3 bg-light-primary text-primary rounded-circle d-inline-flex mb-3" style="width: 70px; height: 70px; align-items: center; justify-content: center;">
                    <i class="fa-solid fa-users-slash fs-1"></i>
                </div>
                <h5 class="fw-bold text-dark mb-2">No Patients Found</h5>
                <p class="text-muted small mb-4">The patient register is currently empty.</p>
                <a asp-action="Create" class="btn btn-custom btn-custom-primary">
                    <i class="fa-solid fa-user-plus"></i> Register First Patient
                </a>
            </div>
        }
        else
        {
            <div class="table-responsive-custom">
                <table class="table custom-table">
                    <thead>
                        <tr>
                            <th>Patient Details</th>
                            <th>National ID</th>
                            <th>Gender</th>
                            <th>Address</th>
                            <th class="text-end">Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var p in Model)
                        {
                            <tr>
                                <td>
                                    <div class="d-flex align-items-center">
                                        <div class="avatar-circle me-3 bg-light-primary text-primary fw-bold text-center" style="width: 40px; height: 40px; border-radius: 50%; line-height: 40px; font-size: 0.95rem; background-color: #E0F2FE;">
                                            @(p.User?.FullName?.Length > 0 ? p.User.FullName[0].ToString().ToUpper() : "P")
                                        </div>
                                        <div>
                                            <a asp-action="Details" asp-route-id="@p.Id" class="fw-bold text-dark d-block text-decoration-none" style="transition:color 0.2s;" onmouseover="this.style.color='#0F4C81'" onmouseout="this.style.color=''">@p.User?.FullName</a>
                                            <span class="text-muted small">@p.User?.Email</span>
                                        </div>
                                    </div>
                                </td>
                                <td>
                                    <span class="font-monospace text-secondary">@p.NationalId</span>
                                </td>
                                <td>
                                    @if (p.Gender == "Male")
                                    {
                                        <span class="badge-custom badge-custom-success"><i class="fa-solid fa-mars me-1"></i> Male</span>
                                    }
                                    else if (p.Gender == "Female")
                                    {
                                        <span class="badge-custom" style="background: rgba(236, 72, 153, 0.1); color: #EC4899;"><i class="fa-solid fa-venus me-1"></i> Female</span>
                                    }
                                    else
                                    {
                                        <span class="badge-custom badge-custom-warning">@p.Gender</span>
                                    }
                                </td>
                                <td>
                                    <span class="text-muted">@(string.IsNullOrEmpty(p.Address) ? "No Address Recorded" : p.Address)</span>
                                </td>
                                <td class="text-end">
                                    <div class="d-inline-flex gap-2">
                                        <a asp-action="Details" asp-route-id="@p.Id" class="btn btn-custom btn-custom-primary btn-sm" title="View Patient 360" style="padding: 6px 12px;">
                                            <i class="fa-solid fa-eye me-0"></i> <span class="d-none d-md-inline ms-1">View</span>
                                        </a>
                                        <a asp-action="Edit" asp-route-id="@p.Id" class="btn btn-custom btn-custom-secondary btn-sm" title="Edit Profile" style="padding: 6px 12px;">
                                            <i class="fa-solid fa-user-pen me-0"></i> <span class="d-none d-md-inline ms-1">Edit</span>
                                        </a>
                                        <a asp-action="Delete" asp-route-id="@p.Id" class="btn btn-custom btn-custom-danger btn-sm" title="Delete Patient" style="padding: 6px 12px;">
                                            <i class="fa-solid fa-trash-can me-0"></i> <span class="d-none d-md-inline ms-1">Delete</span>
                                        </a>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
    </div>
</div>
