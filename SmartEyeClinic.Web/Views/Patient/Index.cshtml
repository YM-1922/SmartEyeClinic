@model List<SmartEyeClinic.Models.Patient>
@{
    ViewData["Title"] = "Patients Directory - Smart Eye Clinic";
}

<div class="page-header">
    <div class="page-header-left">
        <nav class="breadcrumb-nav">
            <a asp-controller="Home" asp-action="Index">Home</a>
            <span class="separator">/</span>
            <span class="current">Patients Directory</span>
        </nav>
        <h3 class="page-title">Patients Directory</h3>
        <p class="page-subtitle">Track, register, and review clinical patient profiles</p>
    </div>
    <a asp-action="Create" class="btn btn-primary">
        <i class="fa-solid fa-user-plus"></i> Register Patient
    </a>
</div>

<div class="table-card">
    <div class="table-card-header">
        <h5 class="table-title">
            <i class="fa-solid fa-hospital-user text-primary"></i> Patient Register
        </h5>
    </div>
    <div class="card-body-clean p-4">
        @if (Model == null || !Model.Any())
        {
            <div class="empty-state">
                <div class="empty-state-icon">
                    <i class="fa-solid fa-users-slash"></i>
                </div>
                <h5>No Patients Found</h5>
                <p>The patient register is currently empty.</p>
                <a asp-action="Create" class="btn btn-primary"><i class="fa-solid fa-user-plus"></i> Register Patient</a>
            </div>
        }
        else
        {
            <div class="table-responsive-custom">
                <table class="table datatable custom-table">
                    <thead>
                        <tr>
                            <th>Patient Details</th>
                            <th>National ID</th>
                            <th>Gender</th>
                            <th>Address</th>
                            <th class="text-end">Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var p in Model)
                        {
                            <tr>
                                <td>
                                    <div class="d-flex align-items-center">
                                        <div class="avatar-initials avatar-md me-3 bg-light-primary text-primary-custom">
                                            @(p.User?.FullName?.Length > 0 ? p.User.FullName[0].ToString().ToUpper() : "P")
                                        </div>
                                        <div class="d-flex flex-column">
                                            <a asp-action="Details" asp-route-id="@p.Id" class="fw-bold text-dark text-decoration-none hover-underline">@p.User?.FullName</a>
                                            <span class="text-xs text-muted">@p.User?.Email</span>
                                        </div>
                                    </div>
                                </td>
                                <td>
                                    <span class="font-monospace text-secondary-custom fw-600">@p.NationalId</span>
                                </td>
                                <td>
                                    @if (p.Gender == "Male")
                                    {
                                        <span class="badge-status badge-success">Male</span>
                                    }
                                    else if (p.Gender == "Female")
                                    {
                                        <span class="badge-status badge-secondary">Female</span>
                                    }
                                    else
                                    {
                                        <span class="badge-status badge-neutral">@p.Gender</span>
                                    }
                                </td>
                                <td>
                                    <span class="text-muted text-xs">@(string.IsNullOrEmpty(p.Address) ? "No Address Recorded" : p.Address)</span>
                                </td>
                                <td class="text-end">
                                    <div class="action-btns justify-content-end">
                                        <a asp-action="Details" asp-route-id="@p.Id" class="btn btn-sm btn-light" title="View Patient Details">
                                            <i class="fa-solid fa-eye text-muted"></i> Details
                                        </a>
                                        <a asp-action="Edit" asp-route-id="@p.Id" class="btn btn-sm btn-light text-primary" title="Edit Patient">
                                            <i class="fa-solid fa-user-pen"></i> Edit
                                        </a>
                                        <a asp-action="Delete" asp-route-id="@p.Id" class="btn btn-sm btn-custom-danger" title="Delete Patient">
                                            <i class="fa-solid fa-trash-can"></i>
                                        </a>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
    </div>
</div>
