@model SmartEyeClinic.Models.Patient
@{
    ViewData["Title"] = "Edit Patient - Smart Eye Clinic";
}

<!-- Page Header -->
<div class="mb-4">
    <ul class="breadcrumb-custom mb-1">
        <li><a asp-controller="Home" asp-action="Index">Home</a></li>
        <li><a asp-controller="Patient" asp-action="Index">Patients Directory</a></li>
        <li>Edit Patient</li>
    </ul>
    <h3 class="fw-bold text-dark mb-0">Edit Patient Profile</h3>
</div>

<!-- Alerts -->
@if (TempData["Success"] != null)
{
    <div class="alert alert-success alert-custom d-flex align-items-center mb-4" role="alert">
        <i class="fa-solid fa-circle-check fs-5 me-2"></i>
        <div>@TempData["Success"]</div>
    </div>
}
@if (TempData["Error"] != null)
{
    <div class="alert alert-danger alert-custom d-flex align-items-center mb-4" role="alert">
        <i class="fa-solid fa-circle-exclamation fs-5 me-2"></i>
        <div>@TempData["Error"]</div>
    </div>
}

<div class="card custom-card" style="max-width: 800px;">
    <div class="card-header-clean">
        <div class="d-flex align-items-center">
            <i class="fa-solid fa-user-pen text-primary me-2 fs-5"></i>
            <h5 class="mb-0">Modify Personal & Account Details</h5>
        </div>
        <div class="text-muted small">Patient ID: #@Model.Id</div>
    </div>
    <div class="card-body-clean">
        <form asp-action="Edit" method="post">
            @Html.AntiForgeryToken()
            <input type="hidden" name="id" value="@Model.Id" />

            <div class="row">
                <!-- Full Name -->
                <div class="col-md-6 mb-3">
                    <label class="form-label-custom">Full Name</label>
                    <div class="input-group">
                        <span class="input-group-text bg-white border-end-0"><i class="fa-solid fa-user text-muted"></i></span>
                        <input type="text"
                               name="fullName"
                               class="form-control form-control-custom border-start-0 ps-0"
                               value="@Model.User?.FullName"
                               placeholder="e.g. John Doe"
                               required />
                    </div>
                </div>

                <!-- Email -->
                <div class="col-md-6 mb-3">
                    <label class="form-label-custom">Email Address</label>
                    <div class="input-group">
                        <span class="input-group-text bg-white border-end-0"><i class="fa-solid fa-envelope text-muted"></i></span>
                        <input type="email"
                               name="email"
                               class="form-control form-control-custom border-start-0 ps-0"
                               value="@Model.User?.Email"
                               placeholder="e.g. name@example.com"
                               required />
                    </div>
                </div>
            </div>

            <div class="row">
                <!-- Password -->
                <div class="col-md-6 mb-3">
                    <label class="form-label-custom">Account Password</label>
                    <div class="input-group">
                        <span class="input-group-text bg-white border-end-0"><i class="fa-solid fa-lock text-muted"></i></span>
                        <input type="password"
                               name="password"
                               class="form-control form-control-custom border-start-0 ps-0"
                               value="@Model.User?.PasswordHash"
                               placeholder="••••••••"
                               required />
                    </div>
                </div>

                <!-- Phone Number -->
                <div class="col-md-6 mb-3">
                    <label class="form-label-custom">Phone Number</label>
                    <div class="input-group">
                        <span class="input-group-text bg-white border-end-0"><i class="fa-solid fa-phone text-muted"></i></span>
                        <input type="text"
                               name="phoneNumber"
                               class="form-control form-control-custom border-start-0 ps-0"
                               value="@Model.User?.PhoneNumber"
                               placeholder="e.g. 01012345678"
                               required />
                    </div>
                </div>
            </div>

            <div class="row">
                <!-- National ID -->
                <div class="col-md-6 mb-3">
                    <label class="form-label-custom">National ID Number</label>
                    <div class="input-group">
                        <span class="input-group-text bg-white border-end-0"><i class="fa-solid fa-id-card-clip text-muted"></i></span>
                        <input type="text"
                               name="nationalId"
                               class="form-control form-control-custom border-start-0 ps-0"
                               value="@Model.NationalId"
                               placeholder="14-digit National ID"
                               required />
                    </div>
                </div>

                <!-- Gender -->
                <div class="col-md-6 mb-3">
                    <label class="form-label-custom">Gender</label>
                    <div class="input-group">
                        <span class="input-group-text bg-white border-end-0"><i class="fa-solid fa-venus-mars text-muted"></i></span>
                        <select name="gender" class="form-select form-control-custom border-start-0 ps-0" style="background-image: none; padding-right: 30px; position: relative;">
                            <option value="Male" selected="@(Model.Gender == "Male" ? "selected" : null)">Male</option>
                            <option value="Female" selected="@(Model.Gender == "Female" ? "selected" : null)">Female</option>
                        </select>
                        <span class="position-absolute end-0 top-50 translate-middle-y me-3 pointer-events-none text-muted"><i class="fa-solid fa-chevron-down small"></i></span>
                    </div>
                </div>
            </div>

            <!-- Address -->
            <div class="mb-4">
                <label class="form-label-custom">Home Address</label>
                <div class="input-group">
                    <span class="input-group-text bg-white border-end-0"><i class="fa-solid fa-location-dot text-muted"></i></span>
                    <input type="text"
                           name="address"
                           class="form-control form-control-custom border-start-0 ps-0"
                           value="@Model.Address"
                           placeholder="e.g. 123 Main Street, City" />
                </div>
            </div>

            <!-- Action Buttons -->
            <div class="border-top pt-4 d-flex justify-content-end">
                <a asp-action="Index" class="btn btn-custom btn-custom-secondary me-2">
                    <i class="fa-solid fa-xmark"></i> Cancel
                </a>
                <button type="submit" class="btn btn-custom btn-custom-primary">
                    <i class="fa-solid fa-floppy-disk"></i> Save Changes
                </button>
            </div>
        </form>
    </div>
</div>
