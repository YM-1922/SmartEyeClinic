<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Smart Eye Clinic</title>
    <!-- CSS libraries -->
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <!-- Font Awesome CDN -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" />
    <!-- Custom site CSS -->
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/SmartEyeClinic.Web.styles.css" asp-append-version="true" />
</head>
<body>
    <script>
        (function() {
            const theme = localStorage.getItem("theme");
            if (theme === "dark") {
                document.body.classList.add("dark-theme");
            }
        })();
    </script>

    <div class="app-wrapper">
        <!-- Sidebar -->
        <nav id="sidebar">
            <div class="sidebar-header d-flex align-items-center">
                <i class="fa-solid fa-house-medical fa-lg me-2 text-info"></i>
                <h4 class="mb-0 text-white">Smart<span> Eye Clinic</span></h4>
            </div>

            <ul class="components">
                <li class="@(ViewContext.RouteData.Values["controller"]?.ToString() == "Home" && ViewContext.RouteData.Values["action"]?.ToString() == "Index" ? "active" : "")">
                    <a asp-controller="Home" asp-action="Index">
                        <i class="fa-solid fa-chart-line"></i>
                        <span class="sidebar-text">Dashboard</span>
                    </a>
                </li>

                @if (User.Identity != null && User.Identity.IsAuthenticated)
                {
                    if (User.IsInRole("Admin"))
                    {
                        <li class="@(ViewContext.RouteData.Values["controller"]?.ToString() == "Patient" ? "active" : "")">
                            <a asp-controller="Patient" asp-action="Index">
                                <i class="fa-solid fa-user-injured"></i>
                                <span class="sidebar-text">Patients</span>
                            </a>
                        </li>
                        <li class="@(ViewContext.RouteData.Values["controller"]?.ToString() == "Doctor" ? "active" : "")">
                            <a asp-controller="Doctor" asp-action="Index">
                                <i class="fa-solid fa-user-md"></i>
                                <span class="sidebar-text">Doctors</span>
                            </a>
                        </li>
                        <li class="@(ViewContext.RouteData.Values["controller"]?.ToString() == "Appointment" ? "active" : "")">
                            <a asp-controller="Appointment" asp-action="Index">
                                <i class="fa-solid fa-calendar-check"></i>
                                <span class="sidebar-text">Appointments</span>
                            </a>
                        </li>
                        <li class="@(ViewContext.RouteData.Values["controller"]?.ToString() == "Examination" ? "active" : "")">
                            <a asp-controller="Examination" asp-action="Index">
                                <i class="fa-solid fa-notes-medical"></i>
                                <span class="sidebar-text">Examinations</span>
                            </a>
                        </li>
                        <li class="@(ViewContext.RouteData.Values["controller"]?.ToString() == "Prescription" ? "active" : "")">
                            <a asp-controller="Prescription" asp-action="Index">
                                <i class="fa-solid fa-file-prescription"></i>
                                <span class="sidebar-text">Prescriptions</span>
                            </a>
                        </li>
                        <li class="@(ViewContext.RouteData.Values["controller"]?.ToString() == "Invoice" ? "active" : "")">
                            <a asp-controller="Invoice" asp-action="Index">
                                <i class="fa-solid fa-file-invoice-dollar"></i>
                                <span class="sidebar-text">Invoices</span>
                            </a>
                        </li>
                        <li class="@(ViewContext.RouteData.Values["controller"]?.ToString() == "Payment" ? "active" : "")">
                            <a asp-controller="Payment" asp-action="Index">
                                <i class="fa-solid fa-credit-card"></i>
                                <span class="sidebar-text">Payments</span>
                            </a>
                        </li>
                        <li class="@(ViewContext.RouteData.Values["controller"]?.ToString() == "Branch" ? "active" : "")">
                            <a asp-controller="Branch" asp-action="Index">
                                <i class="fa-solid fa-hospital"></i>
                                <span class="sidebar-text">Branches</span>
                            </a>
                        </li>
                        <li class="@(ViewContext.RouteData.Values["controller"]?.ToString() == "Specialization" ? "active" : "")">
                            <a asp-controller="Specialization" asp-action="Index">
                                <i class="fa-solid fa-tags"></i>
                                <span class="sidebar-text">Specializations</span>
                            </a>
                        </li>
                        <li class="@(ViewContext.RouteData.Values["controller"]?.ToString() == "Medicine" ? "active" : "")">
                            <a asp-controller="Medicine" asp-action="Index">
                                <i class="fa-solid fa-pills"></i>
                                <span class="sidebar-text">Medicines</span>
                            </a>
                        </li>
                        <li class="@(ViewContext.RouteData.Values["controller"]?.ToString() == "Surgery" ? "active" : "")">
                            <a asp-controller="Surgery" asp-action="Index">
                                <i class="fa-solid fa-syringe"></i>
                                <span class="sidebar-text">Surgeries</span>
                            </a>
                        </li>
                        <li class="@(ViewContext.RouteData.Values["controller"]?.ToString() == "MedicalFile" ? "active" : "")">
                            <a asp-controller="MedicalFile" asp-action="Index">
                                <i class="fa-solid fa-folder-open"></i>
                                <span class="sidebar-text">Medical Files</span>
                            </a>
                        </li>
                    }
                    else if (User.IsInRole("Doctor"))
                    {
                        <li class="@(ViewContext.RouteData.Values["controller"]?.ToString() == "Appointment" ? "active" : "")">
                            <a asp-controller="Appointment" asp-action="Index">
                                <i class="fa-solid fa-calendar-check"></i>
                                <span class="sidebar-text">Visits Queue</span>
                            </a>
                        </li>
                        <li class="@(ViewContext.RouteData.Values["controller"]?.ToString() == "Patient" ? "active" : "")">
                            <a asp-controller="Patient" asp-action="Index">
                                <i class="fa-solid fa-user-injured"></i>
                                <span class="sidebar-text">Patient Directory</span>
                            </a>
                        </li>
                        <li class="@(ViewContext.RouteData.Values["controller"]?.ToString() == "Examination" ? "active" : "")">
                            <a asp-controller="Examination" asp-action="Index">
                                <i class="fa-solid fa-notes-medical"></i>
                                <span class="sidebar-text">Examinations</span>
                            </a>
                        </li>
                        <li class="@(ViewContext.RouteData.Values["controller"]?.ToString() == "Prescription" ? "active" : "")">
                            <a asp-controller="Prescription" asp-action="Index">
                                <i class="fa-solid fa-file-prescription"></i>
                                <span class="sidebar-text">Prescriptions</span>
                            </a>
                        </li>
                        <li class="@(ViewContext.RouteData.Values["controller"]?.ToString() == "Surgery" ? "active" : "")">
                            <a asp-controller="Surgery" asp-action="Index">
                                <i class="fa-solid fa-syringe"></i>
                                <span class="sidebar-text">Surgeries</span>
                            </a>
                        </li>
                        <li class="@(ViewContext.RouteData.Values["controller"]?.ToString() == "MedicalFile" ? "active" : "")">
                            <a asp-controller="MedicalFile" asp-action="Index">
                                <i class="fa-solid fa-folder-open"></i>
                                <span class="sidebar-text">Medical Files</span>
                            </a>
                        </li>
                    }
                    else if (User.IsInRole("Patient"))
                    {
                        <li class="@(ViewContext.RouteData.Values["controller"]?.ToString() == "Appointment" ? "active" : "")">
                            <a asp-controller="Appointment" asp-action="Index">
                                <i class="fa-solid fa-calendar-check"></i>
                                <span class="sidebar-text">My Appointments</span>
                            </a>
                        </li>
                        <li class="@(ViewContext.RouteData.Values["controller"]?.ToString() == "Prescription" ? "active" : "")">
                            <a asp-controller="Prescription" asp-action="Index">
                                <i class="fa-solid fa-file-prescription"></i>
                                <span class="sidebar-text">My Prescriptions</span>
                            </a>
                        </li>
                        <li class="@(ViewContext.RouteData.Values["controller"]?.ToString() == "Invoice" ? "active" : "")">
                            <a asp-controller="Invoice" asp-action="Index">
                                <i class="fa-solid fa-file-invoice-dollar"></i>
                                <span class="sidebar-text">My Invoices</span>
                            </a>
                        </li>
                        <li class="@(ViewContext.RouteData.Values["controller"]?.ToString() == "Payment" ? "active" : "")">
                            <a asp-controller="Payment" asp-action="Index">
                                <i class="fa-solid fa-credit-card"></i>
                                <span class="sidebar-text">My Payments</span>
                            </a>
                        </li>
                        <li class="@(ViewContext.RouteData.Values["controller"]?.ToString() == "MedicalFile" ? "active" : "")">
                            <a asp-controller="MedicalFile" asp-action="Index">
                                <i class="fa-solid fa-folder-open"></i>
                                <span class="sidebar-text">My Medical Files</span>
                            </a>
                        </li>
                    }
                    else if (User.IsInRole("Receptionist"))
                    {
                        <li class="@(ViewContext.RouteData.Values["controller"]?.ToString() == "Patient" ? "active" : "")">
                            <a asp-controller="Patient" asp-action="Index">
                                <i class="fa-solid fa-user-injured"></i>
                                <span class="sidebar-text">Patient Directory</span>
                            </a>
                        </li>
                        <li class="@(ViewContext.RouteData.Values["controller"]?.ToString() == "Appointment" ? "active" : "")">
                            <a asp-controller="Appointment" asp-action="Index">
                                <i class="fa-solid fa-calendar-check"></i>
                                <span class="sidebar-text">Appointments</span>
                            </a>
                        </li>
                        <li class="@(ViewContext.RouteData.Values["controller"]?.ToString() == "Invoice" ? "active" : "")">
                            <a asp-controller="Invoice" asp-action="Index">
                                <i class="fa-solid fa-file-invoice-dollar"></i>
                                <span class="sidebar-text">Invoices</span>
                            </a>
                        </li>
                        <li class="@(ViewContext.RouteData.Values["controller"]?.ToString() == "Payment" ? "active" : "")">
                            <a asp-controller="Payment" asp-action="Index">
                                <i class="fa-solid fa-credit-card"></i>
                                <span class="sidebar-text">Payments</span>
                            </a>
                        </li>
                    }
                }

                <li class="@(ViewContext.RouteData.Values["action"]?.ToString() == "Calendar" ? "active" : "")">
                    <a asp-controller="Home" asp-action="Calendar">
                        <i class="fa-solid fa-calendar-days"></i>
                        <span class="sidebar-text">Calendar</span>
                    </a>
                </li>
            </ul>

            @if (User.Identity != null && User.Identity.IsAuthenticated)
            {
                <div class="sidebar-footer">
                    <a asp-controller="Account" asp-action="Logout" class="text-white opacity-75 text-decoration-none">
                        <i class="fa-solid fa-right-from-bracket me-2"></i>
                        <span class="sidebar-text">Logout</span>
                    </a>
                </div>
            }
        </nav>

        <!-- Main Wrapper -->
        <div id="content">
            <!-- Top Navbar -->
            <nav class="top-navbar">
                <div class="d-flex align-items-center">
                    <button type="button" class="sidebar-toggle me-3">
                        <i class="fa-solid fa-bars"></i>
                    </button>
                    <div class="search-box d-none d-md-flex align-items-center bg-light px-3 py-1 rounded-pill">
                        <i class="fa-solid fa-magnifying-glass text-muted me-2"></i>
                        <input type="text" class="form-control border-0 bg-transparent py-1 px-0" placeholder="Search clinic database..." style="outline: none; box-shadow: none; font-size: 0.88rem;" />
                    </div>
                </div>

                <div class="d-flex align-items-center gap-3">
                    <a href="javascript:void(0)" class="text-muted position-relative">
                        <i class="fa-regular fa-bell fa-lg"></i>
                        <span class="position-absolute top-0 start-100 translate-middle badge rounded-pill bg-danger p-1">
                            <span class="visually-hidden">unread alerts</span>
                        </span>
                    </a>

                    @if (User.Identity != null && User.Identity.IsAuthenticated)
                    {
                        var picClaim = User.FindFirst("ProfilePicture")?.Value;
                        var avatarUrl = string.IsNullOrEmpty(picClaim) ? "https://images.unsplash.com/photo-1622253692010-333f2da6031d?q=80&w=120&auto=format&fit=crop" : picClaim;

                        <button type="button" class="btn btn-link nav-link p-1 text-muted me-1 border-0" id="themeToggleBtn" style="outline: none; box-shadow: none;">
                            <i class="fa-regular fa-moon fa-lg" id="themeToggleIcon"></i>
                        </button>

                        <div class="dropdown">
                            <a href="#" class="d-flex align-items-center text-decoration-none dropdown-toggle navbar-user-profile text-dark" id="userProfileDropdown" data-bs-toggle="dropdown" aria-expanded="false">
                                <img src="@avatarUrl" alt="User Avatar" class="me-2" style="width: 32px; height: 32px; border-radius: 50%; object-fit: cover;" />
                                <span class="d-none d-lg-inline fw-500 font-size-sm text-dark">@User.Identity.Name</span>
                            </a>
                            <ul class="dropdown-menu dropdown-menu-end shadow border-0 mt-2" aria-labelledby="userProfileDropdown">
                                <li><a class="dropdown-item py-2" asp-controller="Account" asp-action="Profile"><i class="fa-solid fa-user me-2 text-muted"></i>Profile</a></li>
                                <li><hr class="dropdown-divider"></li>
                                <li><a class="dropdown-item py-2 text-danger" asp-controller="Account" asp-action="Logout"><i class="fa-solid fa-right-from-bracket me-2"></i>Logout</a></li>
                            </ul>
                        </div>
                    }
                    else
                    {
                        <a asp-controller="Account" asp-action="Login" class="btn btn-primary px-3 py-1.5 border-0" style="background: var(--primary-color); border-radius: 8px;">
                            <i class="fa-solid fa-right-to-bracket me-1"></i> Sign In
                        </a>
                    }
                </div>
            </nav>

            <!-- Main Content Area -->
            <main class="main-content">
                @RenderBody()
            </main>

            <!-- Footer -->
            <footer class="bg-white border-top py-3 text-center text-muted font-size-sm mt-auto">
                <div class="container-fluid">
                    <span>&copy; @DateTime.Now.Year - Smart Eye Clinic Hospital ERP. All Rights Reserved.</span>
                </div>
            </footer>
        </div>
    </div>

    <!-- Scripts -->
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)

    <!-- Sidebar Toggler script -->
    <script>
        document.addEventListener("DOMContentLoaded", function () {
            const toggleBtn = document.querySelector(".sidebar-toggle");
            const sidebar = document.getElementById("sidebar");
            
            if (toggleBtn && sidebar) {
                toggleBtn.addEventListener("click", function () {
                    sidebar.classList.toggle("active");
                });
            }
        });
    </script>
</body>
</html>
