@inject SmartEyeClinic.Web.Services.NotificationService NotificationService
<!DOCTYPE html>
<html lang="en" data-theme="light">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content="Smart Eye Clinic — Premium Ophthalmology ERP System" />
    <title>@ViewData["Title"] — Smart Eye Clinic</title>

    <!-- Bootstrap 5 -->
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <!-- Font Awesome 6 -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css" />
    <!-- DataTables -->
    <link rel="stylesheet" href="https://cdn.datatables.net/1.13.6/css/dataTables.bootstrap5.min.css" />
    <!-- Bootstrap Icons -->
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />
    <!-- Custom Design System -->
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/SmartEyeClinic.Web.styles.css" asp-append-version="true" />

    <!-- Inline theme flash prevention -->
    <script>
        (function () {
            try {
                var t = localStorage.getItem('sec-theme');
                if (t === 'dark') {
                    document.documentElement.setAttribute('data-theme', 'dark');
                    document.body && document.body.classList.add('dark-theme');
                }
            } catch (e) {}
        })();
    </script>
    @await RenderSectionAsync("Styles", required: false)
</head>
<body>
    <!-- Sidebar overlay (mobile) -->
    <div class="sidebar-overlay" id="sidebarOverlay"></div>

    <div class="app-wrapper">
        <!-- ═══════════════════════════════════════
             SIDEBAR
             ═══════════════════════════════════════ -->
        <nav id="sidebar">
            <!-- Brand -->
            <a asp-controller="Home" asp-action="Index" class="sidebar-brand">
                <div class="sidebar-brand-icon">
                    <i class="fa-solid fa-eye"></i>
                </div>
                <div class="sidebar-brand-text">
                    <span class="brand-name">SmartEye</span>
                    <span class="brand-subtitle">Clinic ERP</span>
                </div>
            </a>

            <!-- Nav Items -->
            <div class="sidebar-nav">
                @{
                    var ctrl = ViewContext.RouteData.Values["controller"]?.ToString();
                    var act  = ViewContext.RouteData.Values["action"]?.ToString();
                }

                @if (User.Identity != null && User.Identity.IsAuthenticated)
                {
                    <!-- Dashboard link -->
                    <div class="sidebar-section-label">Main</div>
                    <ul>
                        <li class="@(ctrl == "Home" ? "active" : "")">
                            <a asp-controller="Home" asp-action="Index">
                                <i class="fa-solid fa-gauge-high nav-icon"></i>
                                <span class="nav-label">Dashboard</span>
                            </a>
                        </li>
                    </ul>

                    @if (User.IsInRole("Admin"))
                    {
                        <div class="sidebar-section-label">Clinical</div>
                        <ul>
                            <li class="@(ctrl == "Patient" ? "active" : "")">
                                <a asp-controller="Patient" asp-action="Index">
                                    <i class="fa-solid fa-hospital-user nav-icon"></i>
                                    <span class="nav-label">Patients</span>
                                </a>
                            </li>
                            <li class="@(ctrl == "Doctor" ? "active" : "")">
                                <a asp-controller="Doctor" asp-action="Index">
                                    <i class="fa-solid fa-user-doctor nav-icon"></i>
                                    <span class="nav-label">Doctors</span>
                                </a>
                            </li>
                            <li class="@(ctrl == "Appointment" ? "active" : "")">
                                <a asp-controller="Appointment" asp-action="Index">
                                    <i class="fa-solid fa-calendar-check nav-icon"></i>
                                    <span class="nav-label">Appointments</span>
                                </a>
                            </li>
                            <li class="@(ctrl == "Examination" ? "active" : "")">
                                <a asp-controller="Examination" asp-action="Index">
                                    <i class="fa-solid fa-notes-medical nav-icon"></i>
                                    <span class="nav-label">Examinations</span>
                                </a>
                            </li>
                            <li class="@(ctrl == "Prescription" ? "active" : "")">
                                <a asp-controller="Prescription" asp-action="Index">
                                    <i class="fa-solid fa-file-prescription nav-icon"></i>
                                    <span class="nav-label">Prescriptions</span>
                                </a>
                            </li>
                            <li class="@(ctrl == "Surgery" ? "active" : "")">
                                <a asp-controller="Surgery" asp-action="Index">
                                    <i class="fa-solid fa-syringe nav-icon"></i>
                                    <span class="nav-label">Surgeries</span>
                                </a>
                            </li>
                            <li class="@(ctrl == "MedicalFile" ? "active" : "")">
                                <a asp-controller="MedicalFile" asp-action="Index">
                                    <i class="fa-solid fa-folder-open nav-icon"></i>
                                    <span class="nav-label">Medical Files</span>
                                </a>
                            </li>
                        </ul>

                        <div class="sidebar-section-label">Billing</div>
                        <ul>
                            <li class="@(ctrl == "Invoice" ? "active" : "")">
                                <a asp-controller="Invoice" asp-action="Index">
                                    <i class="fa-solid fa-file-invoice-dollar nav-icon"></i>
                                    <span class="nav-label">Invoices</span>
                                </a>
                            </li>
                            <li class="@(ctrl == "Payment" ? "active" : "")">
                                <a asp-controller="Payment" asp-action="Index">
                                    <i class="fa-solid fa-credit-card nav-icon"></i>
                                    <span class="nav-label">Payments</span>
                                </a>
                            </li>
                        </ul>

                        <div class="sidebar-section-label">Administration</div>
                        <ul>
                            <li class="@(ctrl == "Branch" ? "active" : "")">
                                <a asp-controller="Branch" asp-action="Index">
                                    <i class="fa-solid fa-hospital nav-icon"></i>
                                    <span class="nav-label">Branches</span>
                                </a>
                            </li>
                            <li class="@(ctrl == "Specialization" ? "active" : "")">
                                <a asp-controller="Specialization" asp-action="Index">
                                    <i class="fa-solid fa-tags nav-icon"></i>
                                    <span class="nav-label">Specializations</span>
                                </a>
                            </li>
                            <li class="@(ctrl == "Medicine" ? "active" : "")">
                                <a asp-controller="Medicine" asp-action="Index">
                                    <i class="fa-solid fa-pills nav-icon"></i>
                                    <span class="nav-label">Medicines</span>
                                </a>
                            </li>
                            <li class="@(act == "Calendar" ? "active" : "")">
                                <a asp-controller="Home" asp-action="Calendar">
                                    <i class="fa-solid fa-calendar-days nav-icon"></i>
                                    <span class="nav-label">Calendar</span>
                                </a>
                            </li>
                        </ul>
                    }
                    else if (User.IsInRole("Doctor"))
                    {
                        <div class="sidebar-section-label">My Clinic</div>
                        <ul>
                            <li class="@(ctrl == "Appointment" ? "active" : "")">
                                <a asp-controller="Appointment" asp-action="Index">
                                    <i class="fa-solid fa-calendar-check nav-icon"></i>
                                    <span class="nav-label">Visits Queue</span>
                                </a>
                            </li>
                            <li class="@(ctrl == "Patient" ? "active" : "")">
                                <a asp-controller="Patient" asp-action="Index">
                                    <i class="fa-solid fa-hospital-user nav-icon"></i>
                                    <span class="nav-label">My Patients</span>
                                </a>
                            </li>
                            <li class="@(ctrl == "Examination" ? "active" : "")">
                                <a asp-controller="Examination" asp-action="Index">
                                    <i class="fa-solid fa-notes-medical nav-icon"></i>
                                    <span class="nav-label">Examinations</span>
                                </a>
                            </li>
                            <li class="@(ctrl == "Prescription" ? "active" : "")">
                                <a asp-controller="Prescription" asp-action="Index">
                                    <i class="fa-solid fa-file-prescription nav-icon"></i>
                                    <span class="nav-label">Prescriptions</span>
                                </a>
                            </li>
                            <li class="@(ctrl == "Surgery" ? "active" : "")">
                                <a asp-controller="Surgery" asp-action="Index">
                                    <i class="fa-solid fa-syringe nav-icon"></i>
                                    <span class="nav-label">Surgeries</span>
                                </a>
                            </li>
                            <li class="@(ctrl == "MedicalFile" ? "active" : "")">
                                <a asp-controller="MedicalFile" asp-action="Index">
                                    <i class="fa-solid fa-folder-open nav-icon"></i>
                                    <span class="nav-label">Medical Files</span>
                                </a>
                            </li>
                            <li class="@(act == "Calendar" ? "active" : "")">
                                <a asp-controller="Home" asp-action="Calendar">
                                    <i class="fa-solid fa-calendar-days nav-icon"></i>
                                    <span class="nav-label">Calendar</span>
                                </a>
                            </li>
                        </ul>
                    }
                    else if (User.IsInRole("Patient"))
                    {
                        <div class="sidebar-section-label">My Health</div>
                        <ul>
                            <li class="@(ctrl == "Appointment" && act == "Index" ? "active" : "")">
                                <a asp-controller="Appointment" asp-action="Index">
                                    <i class="fa-solid fa-calendar-check nav-icon"></i>
                                    <span class="nav-label">My Appointments</span>
                                </a>
                            </li>
                            <li class="@(ctrl == "Appointment" && act == "Create" ? "active" : "")">
                                <a asp-controller="Appointment" asp-action="Create">
                                    <i class="fa-solid fa-calendar-plus nav-icon text-info"></i>
                                    <span class="nav-label">Book Appointment</span>
                                </a>
                            </li>
                            <li class="@(ctrl == "Examination" ? "active" : "")">
                                <a asp-controller="Examination" asp-action="Index">
                                    <i class="fa-solid fa-notes-medical nav-icon"></i>
                                    <span class="nav-label">My Examinations</span>
                                </a>
                            </li>
                            <li class="@(ctrl == "Prescription" ? "active" : "")">
                                <a asp-controller="Prescription" asp-action="Index">
                                    <i class="fa-solid fa-file-prescription nav-icon"></i>
                                    <span class="nav-label">My Prescriptions</span>
                                </a>
                            </li>
                            <li class="@(ctrl == "Invoice" ? "active" : "")">
                                <a asp-controller="Invoice" asp-action="Index">
                                    <i class="fa-solid fa-file-invoice-dollar nav-icon"></i>
                                    <span class="nav-label">My Invoices</span>
                                </a>
                            </li>
                            <li class="@(ctrl == "Payment" ? "active" : "")">
                                <a asp-controller="Payment" asp-action="Index">
                                    <i class="fa-solid fa-credit-card nav-icon"></i>
                                    <span class="nav-label">My Payments</span>
                                </a>
                            </li>
                            <li class="@(ctrl == "MedicalFile" ? "active" : "")">
                                <a asp-controller="MedicalFile" asp-action="Index">
                                    <i class="fa-solid fa-folder-open nav-icon"></i>
                                    <span class="nav-label">Medical Files</span>
                                </a>
                            </li>
                            <li class="@(ctrl == "Surgery" ? "active" : "")">
                                <a asp-controller="Surgery" asp-action="Index">
                                    <i class="fa-solid fa-syringe nav-icon"></i>
                                    <span class="nav-label">My Surgeries</span>
                                </a>
                            </li>
                        </ul>

                        <div class="sidebar-section-label">Main Site</div>
                        <ul>
                            <li>
                                <a asp-controller="Home" asp-action="Landing">
                                    <i class="fa-solid fa-house nav-icon text-warning"></i>
                                    <span class="nav-label">Homepage</span>
                                </a>
                            </li>
                            <li>
                                <a asp-controller="Home" asp-action="Doctors">
                                    <i class="fa-solid fa-user-md nav-icon text-success"></i>
                                    <span class="nav-label">Our Doctors</span>
                                </a>
                            </li>
                            <li>
                                <a asp-controller="Home" asp-action="About">
                                    <i class="fa-solid fa-info-circle nav-icon text-info"></i>
                                    <span class="nav-label">About Us</span>
                                </a>
                            </li>
                            <li>
                                <a asp-controller="Home" asp-action="Contact">
                                    <i class="fa-solid fa-envelope nav-icon text-primary"></i>
                                    <span class="nav-label">Contact Us</span>
                                </a>
                            </li>
                        </ul>
                    }
                    else if (User.IsInRole("Receptionist"))
                    {
                        <div class="sidebar-section-label">Reception</div>
                        <ul>
                            <li class="@(ctrl == "Patient" ? "active" : "")">
                                <a asp-controller="Patient" asp-action="Index">
                                    <i class="fa-solid fa-hospital-user nav-icon"></i>
                                    <span class="nav-label">Patient Directory</span>
                                </a>
                            </li>
                            <li class="@(ctrl == "Appointment" ? "active" : "")">
                                <a asp-controller="Appointment" asp-action="Index">
                                    <i class="fa-solid fa-calendar-check nav-icon"></i>
                                    <span class="nav-label">Appointments</span>
                                </a>
                            </li>
                        </ul>
                        <div class="sidebar-section-label">Billing</div>
                        <ul>
                            <li class="@(ctrl == "Invoice" ? "active" : "")">
                                <a asp-controller="Invoice" asp-action="Index">
                                    <i class="fa-solid fa-file-invoice-dollar nav-icon"></i>
                                    <span class="nav-label">Invoices</span>
                                </a>
                            </li>
                            <li class="@(ctrl == "Payment" ? "active" : "")">
                                <a asp-controller="Payment" asp-action="Index">
                                    <i class="fa-solid fa-credit-card nav-icon"></i>
                                    <span class="nav-label">Payments</span>
                                </a>
                            </li>
                        </ul>
                    }
                }
            </div>

            <!-- Sidebar Footer -->
            @if (User.Identity != null && User.Identity.IsAuthenticated)
            {
                <div class="sidebar-footer">
                    <a asp-controller="Account" asp-action="Logout">
                        <i class="fa-solid fa-right-from-bracket" style="width:20px;text-align:center;"></i>
                        <span class="footer-label">Sign Out</span>
                    </a>
                </div>
            }
        </nav>

        <!-- ═══════════════════════════════════════
             MAIN CONTENT WRAPPER
             ═══════════════════════════════════════ -->
        <div id="content">
            <!-- TOP NAVBAR -->
            <nav class="top-navbar">
                <div class="d-flex align-items-center gap-3">
                    <!-- Sidebar Toggle -->
                    <button type="button" class="sidebar-toggle-btn" id="sidebarToggleBtn" aria-label="Toggle Sidebar">
                        <i class="fa-solid fa-bars"></i>
                    </button>

                    <!-- Search (Desktop) -->
                    <div class="search-box d-none d-md-flex">
                        <i class="fa-solid fa-magnifying-glass"></i>
                        <input type="text" placeholder="Search patients, appointments..." id="globalSearch" autocomplete="off" />
                    </div>

                    <!-- Quick Navigation (For Patients) -->
                    @if (User.IsInRole("Patient"))
                    {
                        <div class="d-none d-lg-flex align-items-center gap-3 ms-4">
                            <a asp-controller="Home" asp-action="Landing" class="text-decoration-none text-muted fw-bold text-sm" style="transition: color 0.2s;">
                                <i class="fa-solid fa-house me-1 text-primary"></i> Home
                            </a>
                            <a asp-controller="Home" asp-action="Doctors" class="text-decoration-none text-muted fw-bold text-sm" style="transition: color 0.2s;">
                                <i class="fa-solid fa-user-md me-1 text-success"></i> Our Doctors
                            </a>
                        </div>
                    }
                </div>

                <div class="navbar-actions">
                    @if (User.Identity != null && User.Identity.IsAuthenticated)
                    {
                        var picClaim = User.FindFirst("ProfilePicture")?.Value;
                        var hasPhoto = !string.IsNullOrEmpty(picClaim);
                        var userInitial = User.Identity?.Name?.Length > 0 ? User.Identity.Name[0].ToString().ToUpper() : "U";
                        var roleName = User.IsInRole("Admin") ? "Administrator" :
                                      User.IsInRole("Doctor") ? "Doctor" :
                                      User.IsInRole("Patient") ? "Patient" : "Receptionist";

                        int unreadCount = 0;
                        List<SmartEyeClinic.Models.Notification> headerNotifications = new();
                        var userIdClaim = User.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier);
                        if (userIdClaim != null)
                        {
                            var currentUserId = int.Parse(userIdClaim.Value);
                            unreadCount = await NotificationService.GetUnreadNotificationsCountAsync(currentUserId);
                            headerNotifications = await NotificationService.GetNotificationsForUserAsync(currentUserId);
                        }

                        <!-- Theme Toggle -->
                        <button type="button" class="navbar-icon-btn" id="themeToggleBtn" title="Toggle Dark Mode">
                            <i class="fa-regular fa-moon" id="themeIcon"></i>
                        </button>

                        <div class="navbar-divider"></div>

                        <!-- Notifications Dropdown -->
                        <div class="dropdown me-2">
                            <button type="button" class="navbar-icon-btn dropdown-toggle position-relative border-0 bg-transparent" id="notificationsDropdown" data-bs-toggle="dropdown" aria-expanded="false" title="Notifications">
                                <i class="fa-regular fa-bell"></i>
                                @if (unreadCount > 0)
                                {
                                    <span class="position-absolute top-0 start-100 translate-middle badge rounded-pill bg-danger" style="font-size: 0.65rem; padding: 4px 6px;">
                                        @unreadCount
                                    </span>
                                }
                            </button>
                            <ul class="dropdown-menu dropdown-menu-end premium-dropdown mt-2 p-0 shadow-lg" aria-labelledby="notificationsDropdown" style="width: 320px; max-height: 400px; overflow-y: auto; border: 1px solid var(--border);">
                                <li class="p-3 border-bottom d-flex justify-content-between align-items-center bg-light">
                                    <span class="fw-bold text-dark text-sm"><i class="fa-solid fa-bell text-warning me-1"></i> Notifications</span>
                                    @if (unreadCount > 0)
                                    {
                                        <button class="btn btn-link p-0 text-decoration-none text-xs font-weight-bold" onclick="markNotificationsAsRead(event)">Mark all read</button>
                                    }
                                </li>
                                <li class="notification-items-container">
                                    @if (!headerNotifications.Any())
                                    {
                                        <div class="text-center py-4 text-muted small">
                                            <i class="fa-regular fa-bell-slash mb-2 fs-5 d-block"></i>
                                            No notifications yet.
                                        </div>
                                    }
                                    else
                                    {
                                        foreach (var n in headerNotifications)
                                        {
                                            var isUnread = n.IsRead == null || !n.IsRead.Value;
                                            <div class="p-3 border-bottom position-relative" style="font-size: 0.8rem; background: @(isUnread ? "rgba(14,165,233,0.06)" : "transparent");">
                                                <div class="d-flex justify-content-between align-items-center mb-1">
                                                    <span class="fw-bold @(isUnread ? "text-primary" : "text-dark")">@n.Title</span>
                                                    <span class="text-muted" style="font-size:0.68rem;">@n.SentAt?.ToString("g")</span>
                                                </div>
                                                <div class="text-muted text-xs leading-normal">@n.Message</div>
                                            </div>
                                        }
                                    }
                                </li>
                            </ul>
                        </div>

                        <!-- User Dropdown -->
                        <div class="dropdown">
                            <a href="#" class="user-avatar-btn dropdown-toggle" data-bs-toggle="dropdown" aria-expanded="false" id="userDropdown">
                                @if (hasPhoto)
                                {
                                    <img src="@picClaim" alt="Avatar" class="user-avatar" />
                                }
                                else
                                {
                                    <div class="user-initials avatar-sm">@userInitial</div>
                                }
                                <div class="user-info d-none d-lg-flex">
                                    <span class="user-name">@User.Identity!.Name</span>
                                    <span class="user-role">@roleName</span>
                                </div>
                            </a>
                            <ul class="dropdown-menu dropdown-menu-end premium-dropdown mt-2" aria-labelledby="userDropdown">
                                <li>
                                    <div class="dropdown-header px-3 py-2">
                                        <div class="fw-700 text-sm">@User.Identity!.Name</div>
                                        <div class="text-xs" style="color:var(--text-muted)">@roleName</div>
                                    </div>
                                </li>
                                <li><hr class="dropdown-divider"></li>
                                <li>
                                    <a class="dropdown-item" asp-controller="Account" asp-action="Profile">
                                        <i class="fa-solid fa-circle-user text-muted"></i> My Profile
                                    </a>
                                </li>
                                <li><hr class="dropdown-divider"></li>
                                <li>
                                    <a class="dropdown-item text-danger" asp-controller="Account" asp-action="Logout">
                                        <i class="fa-solid fa-right-from-bracket"></i> Sign Out
                                    </a>
                                </li>
                            </ul>
                        </div>
                    }
                    else
                    {
                        <a asp-controller="Account" asp-action="Login" class="btn btn-primary btn-sm">
                            <i class="fa-solid fa-right-to-bracket"></i> Sign In
                        </a>
                    }
                </div>
            </nav>

            <!-- ALERT BANNER -->
            @if (TempData["Success"] != null)
            {
                <div class="alert alert-success alert-dismissible mx-4 mt-3 animate-fade-in-up" role="alert" id="tempAlert">
                    <i class="fa-solid fa-circle-check"></i>
                    <div>@TempData["Success"]</div>
                    <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                </div>
            }
            @if (TempData["Error"] != null)
            {
                <div class="alert alert-danger alert-dismissible mx-4 mt-3 animate-fade-in-up" role="alert" id="tempAlert">
                    <i class="fa-solid fa-circle-xmark"></i>
                    <div>@TempData["Error"]</div>
                    <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                </div>
            }
            @if (TempData["Warning"] != null)
            {
                <div class="alert alert-warning alert-dismissible mx-4 mt-3 animate-fade-in-up" role="alert">
                    <i class="fa-solid fa-triangle-exclamation"></i>
                    <div>@TempData["Warning"]</div>
                    <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                </div>
            }

            <!-- MAIN CONTENT -->
            <main class="main-content">
                @RenderBody()
            </main>

            <!-- FOOTER -->
            <footer class="app-footer">
                <span>&copy; @DateTime.Now.Year Smart Eye Clinic ERP — All Rights Reserved</span>
                <span class="d-none d-md-inline">
                    <i class="fa-solid fa-heart text-danger"></i> Built with care for better eye health
                </span>
            </footer>
        </div>
    </div>

    <!-- Scripts -->
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <!-- DataTables -->
    <script src="https://cdn.datatables.net/1.13.6/js/jquery.dataTables.min.js"></script>
    <script src="https://cdn.datatables.net/1.13.6/js/dataTables.bootstrap5.min.js"></script>
    <!-- DataTables Buttons (export) -->
    <script src="https://cdn.datatables.net/buttons/2.4.1/js/dataTables.buttons.min.js"></script>
    <script src="https://cdn.datatables.net/buttons/2.4.1/js/buttons.bootstrap5.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/jszip/3.10.1/jszip.min.js"></script>
    <script src="https://cdn.datatables.net/buttons/2.4.1/js/buttons.html5.min.js"></script>
    <script src="https://cdn.datatables.net/buttons/2.4.1/js/buttons.print.min.js"></script>
    <!-- SweetAlert2 -->
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <!-- Chart.js placeholder -->
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <!-- Site JS -->
    <script src="~/js/site.js" asp-append-version="true"></script>

    <script>
        document.addEventListener("DOMContentLoaded", function () {

            /* ── Sidebar Toggle ── */
            const toggleBtn = document.getElementById('sidebarToggleBtn');
            const sidebar   = document.getElementById('sidebar');
            const overlay   = document.getElementById('sidebarOverlay');

            if (toggleBtn && sidebar) {
                toggleBtn.addEventListener('click', function () {
                    const isMobile = window.innerWidth < 992;
                    if (isMobile) {
                        sidebar.classList.toggle('mobile-open');
                        overlay.classList.toggle('visible');
                    } else {
                        sidebar.classList.toggle('collapsed');
                        localStorage.setItem('sec-sidebar', sidebar.classList.contains('collapsed') ? '1' : '0');
                    }
                });

                // Restore collapsed state
                if (window.innerWidth >= 992 && localStorage.getItem('sec-sidebar') === '1') {
                    sidebar.classList.add('collapsed');
                }
            }

            if (overlay) {
                overlay.addEventListener('click', function () {
                    sidebar.classList.remove('mobile-open');
                    overlay.classList.remove('visible');
                });
            }

            /* ── Theme Toggle ── */
            const themeBtn  = document.getElementById('themeToggleBtn');
            const themeIcon = document.getElementById('themeIcon');
            const storedTheme = localStorage.getItem('sec-theme');
            if (storedTheme === 'dark') {
                document.body.classList.add('dark-theme');
                if (themeIcon) themeIcon.className = 'fa-solid fa-sun';
            }

            if (themeBtn) {
                themeBtn.addEventListener('click', function () {
                    const isDark = document.body.classList.toggle('dark-theme');
                    if (themeIcon) {
                        themeIcon.className = isDark ? 'fa-solid fa-sun' : 'fa-regular fa-moon';
                    }
                    localStorage.setItem('sec-theme', isDark ? 'dark' : 'light');
                });
            }

            /* ── DataTables Auto-Init ── */
            if (typeof $.fn.DataTable !== 'undefined') {
                $('.datatable').each(function () {
                    if (!$.fn.DataTable.isDataTable(this)) {
                        $(this).DataTable({
                            responsive: true,
                            pageLength: 15,
                            dom: "<'row mb-3'<'col-sm-6'l><'col-sm-6 d-flex justify-content-end gap-2'fB>>" +
                                 "<'row'<'col-12'tr>>" +
                                 "<'row mt-3'<'col-sm-5'i><'col-sm-7'p>>",
                            buttons: [
                                {
                                    extend: 'excel',
                                    className: 'btn btn-sm btn-light border',
                                    text: '<i class="fa-solid fa-file-excel me-1 text-success"></i> Excel',
                                    exportOptions: { columns: ':not(:last-child)' }
                                },
                                {
                                    extend: 'print',
                                    className: 'btn btn-sm btn-light border',
                                    text: '<i class="fa-solid fa-print me-1 text-muted"></i> Print',
                                    exportOptions: { columns: ':not(:last-child)' }
                                }
                            ],
                            language: {
                                search: "",
                                searchPlaceholder: "Search records...",
                                lengthMenu: "Show _MENU_",
                                info: "Showing _START_–_END_ of _TOTAL_",
                                paginate: { first: '«', last: '»', next: '›', previous: '‹' },
                                emptyTable: '<div class="py-4 text-center text-muted"><i class="fa-solid fa-inbox fa-2x mb-2 d-block opacity-40"></i>No records found</div>'
                            }
                        });
                    }
                });
            }

            /* ── SweetAlert2 Delete Confirmations ── */
            document.querySelectorAll('form[data-confirm]').forEach(function (form) {
                form.addEventListener('submit', function (e) {
                    e.preventDefault();
                    const msg = form.getAttribute('data-confirm') || 'This action cannot be undone.';
                    const itemName = form.getAttribute('data-item') || 'this record';
                    Swal.fire({
                        title: 'Delete Confirmation',
                        html: `<p class="text-muted mb-0">You are about to delete <strong>${itemName}</strong>.<br>${msg}</p>`,
                        icon: 'warning',
                        showCancelButton: true,
                        confirmButtonColor: '#EF4444',
                        cancelButtonColor: '#64748B',
                        confirmButtonText: '<i class="fa-solid fa-trash-can me-1"></i> Yes, Delete',
                        cancelButtonText: 'Cancel',
                        customClass: { popup: 'rounded-3 shadow-lg', confirmButton: 'btn btn-danger btn-sm px-3', cancelButton: 'btn btn-secondary btn-sm px-3' },
                        buttonsStyling: false
                    }).then(function (result) {
                        if (result.isConfirmed) { form.submit(); }
                    });
                });
            });

            /* ── Auto-dismiss Alerts ── */
            setTimeout(function () {
                document.querySelectorAll('.alert-dismissible').forEach(function (el) {
                    el.style.transition = 'opacity 0.5s ease, transform 0.5s ease';
                    el.style.opacity = '0';
                    el.style.transform = 'translateY(-8px)';
                    setTimeout(function () { el.remove(); }, 500);
                });
            }, 5000);
        });

        function markNotificationsAsRead(event) {
            if (event) {
                event.preventDefault();
                event.stopPropagation();
            }
            var token = $('#antiForgeryForm input[name="__RequestVerificationToken"]').val();
            $.ajax({
                url: '/Notification/MarkAllAsRead',
                type: 'POST',
                headers: {
                    "RequestVerificationToken": token
                },
                success: function(response) {
                    if (response.success) {
                        window.location.reload();
                    }
                },
                error: function(err) {
                    console.error("Failed to mark notifications read", err);
                }
            });
        }
    </script>
    <form id="antiForgeryForm" style="display:none;">@Html.AntiForgeryToken()</form>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
