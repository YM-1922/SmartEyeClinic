@model List<SmartEyeClinic.Models.Medicine>
@{
    ViewData["Title"] = "Medicines - Smart Eye Clinic";
}

<div class="page-header">
    <div class="page-header-left">
        <nav class="breadcrumb-nav">
            <a asp-controller="Home" asp-action="Index">Home</a>
            <span class="separator">/</span>
            <span class="current">Pharmacy Catalog</span>
        </nav>
        <h3 class="page-title">Pharmacy & Medicines</h3>
        <p class="page-subtitle">Track prescription drug inventory, manufacturers, and usage directions</p>
    </div>
    @if (User.IsInRole("Admin") || User.IsInRole("Doctor"))
    {
        <a asp-action="Create" class="btn btn-primary">
            <i class="fa-solid fa-pills"></i> Add Medicine
        </a>
    }
</div>

<div class="table-card">
    <div class="table-card-header">
        <h5 class="table-title">
            <i class="fa-solid fa-pills text-primary"></i> Medicine Database
        </h5>
    </div>
    <div class="card-body-clean p-4">
        @if (!Model.Any())
        {
            <div class="empty-state">
                <div class="empty-state-icon">
                    <i class="fa-solid fa-capsules"></i>
                </div>
                <h5>No Medicines Cataloged</h5>
                <p>The pharmacy medicine database is currently empty.</p>
                @if (User.IsInRole("Admin") || User.IsInRole("Doctor"))
                {
                    <a asp-action="Create" class="btn btn-primary"><i class="fa-solid fa-pills"></i> Add Medicine</a>
                }
            </div>
        }
        else
        {
            <div class="table-responsive-custom">
                <table class="table datatable custom-table">
                    <thead>
                        <tr>
                            <th>Medicine</th>
                            <th>Manufacturer</th>
                            <th>Description</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var m in Model)
                        {
                            <tr>
                                <td>
                                    <div class="d-flex align-items-center">
                                        <div class="avatar-initials avatar-sm me-3 bg-light-warning text-warning" style="border-radius: var(--radius-sm)">
                                            <i class="fa-solid fa-capsules"></i>
                                        </div>
                                        <span class="fw-bold text-dark">@m.Name</span>
                                    </div>
                                </td>
                                <td>
                                    <span class="fw-500 text-dark">@(m.Manufacturer ?? "—")</span>
                                </td>
                                <td>
                                    <span class="text-muted text-xs" title="@m.Description">
                                        @(m.Description?.Length > 100 ? m.Description.Substring(0, 100) + "..." : (m.Description ?? "—"))
                                    </span>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
    </div>
</div>
