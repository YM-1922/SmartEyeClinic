@{
    ViewData["Title"] = "Add Medicine - Smart Eye Clinic";
}

<div class="mb-4">
    <ul class="breadcrumb-custom mb-1">
        <li><a asp-controller="Home" asp-action="Index">Home</a></li>
        <li><a asp-controller="Medicine" asp-action="Index">Pharmacy Catalog</a></li>
        <li>Add Medicine</li>
    </ul>
    <h3 class="fw-bold text-dark mb-0">Add New Medicine</h3>
</div>

<div class="card custom-card" style="max-width:600px;">
    <div class="card-header-clean">
        <div class="d-flex align-items-center">
            <i class="fa-solid fa-pills text-primary me-2 fs-5"></i>
            <h5 class="mb-0">Medicine Catalog Information</h5>
        </div>
    </div>
    <div class="card-body-clean">
        <form asp-action="Create" method="post">
            @Html.AntiForgeryToken()
            <div class="mb-3">
                <label class="form-label-custom">Medicine Brand Name</label>
                <div class="input-group">
                    <span class="input-group-text bg-white border-end-0"><i class="fa-solid fa-prescription-bottle text-muted"></i></span>
                    <input type="text" name="name" class="form-control form-control-custom border-start-0 ps-0" placeholder="e.g. Vigamox Eye Drops" required />
                </div>
            </div>
            <div class="mb-3">
                <label class="form-label-custom">Pharmaceutical Manufacturer</label>
                <div class="input-group">
                    <span class="input-group-text bg-white border-end-0"><i class="fa-solid fa-industry text-muted"></i></span>
                    <input type="text" name="manufacturer" class="form-control form-control-custom border-start-0 ps-0" placeholder="e.g. Alcon Laboratories" />
                </div>
            </div>
            <div class="mb-4">
                <label class="form-label-custom">Description & Usage Guidelines</label>
                <textarea name="description" class="form-control form-control-custom" rows="3" placeholder="Describe dosage form, indications, active ingredients..."></textarea>
            </div>
            <div class="border-top pt-4 d-flex justify-content-end">
                <a asp-action="Index" class="btn btn-custom btn-custom-secondary me-2"><i class="fa-solid fa-xmark"></i> Cancel</a>
                <button type="submit" class="btn btn-custom btn-custom-primary"><i class="fa-solid fa-floppy-disk"></i> Save Medicine</button>
            </div>
        </form>
    </div>
</div>
