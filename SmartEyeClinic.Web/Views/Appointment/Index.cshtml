@model List<SmartEyeClinic.Models.Appointment>
@{
    ViewData["Title"] = "Appointments - Smart Eye Clinic";
}

<div class="page-header">
    <div class="page-header-left">
        <nav class="breadcrumb-nav">
            <a asp-controller="Home" asp-action="Index">Home</a>
            <span class="separator">/</span>
            <span class="current">Appointments</span>
        </nav>
        <h3 class="page-title">Appointment Schedule</h3>
        <p class="page-subtitle">Track and manage ophthalmic consultations</p>
    </div>
    <a asp-action="Create" class="btn btn-primary">
        <i class="fa-solid fa-calendar-plus"></i> Book Appointment
    </a>
</div>

<div class="table-card">
    <div class="table-card-header">
        <h5 class="table-title">
            <i class="fa-solid fa-calendar-check text-primary"></i> Scheduled Consultations
        </h5>
    </div>
    <div class="card-body-clean p-4">
        @if (!Model.Any())
        {
            <div class="empty-state">
                <div class="empty-state-icon">
                    <i class="fa-regular fa-calendar"></i>
                </div>
                <h5>No Appointments Scheduled</h5>
                <p>Book new consultations for your active patient queue.</p>
                <a asp-action="Create" class="btn btn-primary"><i class="fa-solid fa-calendar-plus"></i> Book Now</a>
            </div>
        }
        else
        {
            <div class="table-responsive-custom">
                <table class="table datatable custom-table">
                    <thead>
                        <tr>
                            <th>#</th>
                            <th>Patient</th>
                            <th>Doctor</th>
                            <th>Date & Time</th>
                            <th>Type</th>
                            <th>Status</th>
                            <th class="text-end">Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var a in Model)
                        {
                            <tr>
                                <td><span class="text-muted font-monospace small">#@a.Id</span></td>
                                <td>
                                    <div class="d-flex align-items-center">
                                        <div class="avatar-initials avatar-sm me-2 bg-light-primary text-primary-custom">
                                            @(a.Patient?.User?.FullName?.Length > 0 ? a.Patient.User.FullName[0].ToString().ToUpper() : "P")
                                        </div>
                                        <div class="d-flex flex-column">
                                            <span class="fw-600 text-dark">@a.Patient?.User?.FullName</span>
                                            <span class="text-xs text-muted">ID: #@a.PatientId</span>
                                        </div>
                                    </div>
                                </td>
                                <td>
                                    <span class="fw-500 text-dark">Dr. @a.Doctor?.User?.FullName</span>
                                </td>
                                <td>
                                    <span class="d-block fw-500">@a.AppointmentDateTime.ToString("dd MMM yyyy")</span>
                                    <span class="text-xs text-muted">@a.AppointmentDateTime.ToString("hh:mm tt")</span>
                                </td>
                                <td>
                                    <span class="pill pill-info">@a.Type</span>
                                </td>
                                <td>
                                    @if (a.Status == "Completed")
                                    { <span class="badge-status badge-success">Completed</span> }
                                    else if (a.Status == "Pending")
                                    { <span class="badge-status badge-warning">Pending</span> }
                                    else if (a.Status == "Cancelled")
                                    { <span class="badge-status badge-danger">Cancelled</span> }
                                    else
                                    { <span class="badge-status badge-neutral">@a.Status</span> }
                                </td>
                                <td class="text-end">
                                    <div class="action-btns justify-content-end">
                                        <a asp-action="Details" asp-route-id="@a.Id" class="btn btn-sm btn-light" title="View details">
                                            <i class="fa-solid fa-eye text-muted"></i> Details
                                        </a>
                                        <a asp-action="Edit" asp-route-id="@a.Id" class="btn btn-sm btn-light text-primary" title="Edit appointment">
                                            <i class="fa-solid fa-pen-to-square"></i> Edit
                                        </a>
                                        <form asp-action="Delete" asp-route-id="@a.Id" method="post" class="d-inline" data-confirm="Are you sure you want to cancel and delete this appointment?" data-item="Appointment #@a.Id">
                                            @Html.AntiForgeryToken()
                                            <button type="submit" class="btn btn-sm btn-custom-danger" title="Cancel/Delete">
                                                <i class="fa-solid fa-trash-can"></i>
                                            </button>
                                        </form>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
    </div>
</div>
