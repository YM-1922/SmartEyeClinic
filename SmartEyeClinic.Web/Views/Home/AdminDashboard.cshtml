@{
    ViewData["Title"] = "Admin Dashboard";
    var audits = ViewBag.RecentAudits as List<SmartEyeClinic.Models.AuditLog>;
    var payments = ViewBag.RecentPayments as List<SmartEyeClinic.Models.Payment>;
    var doctorsList = ViewBag.DoctorsList as List<SmartEyeClinic.Models.Doctor>;
    var patientsList = ViewBag.PatientsList as List<SmartEyeClinic.Models.Patient>;
    var appointmentsList = ViewBag.AppointmentsList as List<SmartEyeClinic.Models.Appointment>;
    var depositsList = ViewBag.DepositsList as List<SmartEyeClinic.Models.Appointment>;
    var notificationsList = ViewBag.RecentNotifications as List<SmartEyeClinic.Models.Notification>;
}

<!-- Page Header -->
<div class="page-header py-4 mb-4 border-bottom">
    <div class="d-flex justify-content-between align-items-center flex-wrap gap-3">
        <div>
            <div class="breadcrumb-nav small text-muted mb-2">
                <a href="/" class="text-decoration-none text-muted"><i class="fa-solid fa-house"></i> Home</a>
                <span class="mx-2">/</span>
                <span class="text-primary font-weight-bold">Administrative Dashboard</span>
            </div>
            <h1 class="page-title fw-800 text-dark mb-1"><i class="fa-solid fa-gauge-high text-primary me-2"></i>Administrative Control Center</h1>
            <p class="text-muted mb-0">Clinic-wide clinical performance, billing audits, system seeder logs, and user roles control.</p>
        </div>
        <div class="d-flex gap-2">
            <a asp-controller="Patient" asp-action="Create" class="btn btn-outline-primary rounded-pill px-4 fw-bold">
                <i class="fa-solid fa-user-plus me-1"></i> New Patient
            </a>
            <a asp-controller="Doctor" asp-action="Create" class="btn btn-primary rounded-pill px-4 fw-bold shadow-sm">
                <i class="fa-solid fa-user-doctor me-1"></i> Add Doctor
            </a>
        </div>
    </div>
</div>

<!-- Primary KPIs -->
<div class="row g-4 mb-4">
    <div class="col-xl-3 col-md-6">
        <div class="card border-0 shadow-sm p-4 h-100 bg-white" style="border-radius: var(--radius-lg); border-left: 5px solid var(--primary) !important;">
            <span class="text-muted text-xs uppercase fw-bold d-block mb-1">Total Patients</span>
            <div class="fs-2 fw-bold text-dark mb-1">@ViewBag.TotalPatients</div>
            <div class="text-muted small"><i class="fa-solid fa-hospital-user text-primary me-1"></i> Clinic patient profiles</div>
        </div>
    </div>
    <div class="col-xl-3 col-md-6">
        <div class="card border-0 shadow-sm p-4 h-100 bg-white" style="border-radius: var(--radius-lg); border-left: 5px solid var(--success) !important;">
            <span class="text-muted text-xs uppercase fw-bold d-block mb-1">Active Specialists</span>
            <div class="fs-2 fw-bold text-dark mb-1">@ViewBag.TotalDoctors</div>
            <div class="text-muted small"><i class="fa-solid fa-user-md text-success me-1"></i> Board-certified staff</div>
        </div>
    </div>
    <div class="col-xl-3 col-md-6">
        <div class="card border-0 shadow-sm p-4 h-100 bg-white" style="border-radius: var(--radius-lg); border-left: 5px solid var(--warning) !important;">
            <span class="text-muted text-xs uppercase fw-bold d-block mb-1">Total Bookings</span>
            <div class="fs-2 fw-bold text-dark mb-1">@ViewBag.TotalAppointments</div>
            <div class="text-muted small"><i class="fa-solid fa-calendar-check text-warning me-1"></i> Scheduled logs</div>
        </div>
    </div>
    <div class="col-xl-3 col-md-6">
        <div class="card border-0 shadow-sm p-4 h-100 bg-white" style="border-radius: var(--radius-lg); border-left: 5px solid var(--danger) !important;">
            <span class="text-muted text-xs uppercase fw-bold d-block mb-1">Clinic Revenue</span>
            <div class="fs-2 fw-bold text-dark mb-1">$@(((decimal)ViewBag.TotalRevenue).ToString("N2"))</div>
            <div class="text-muted small"><i class="fa-solid fa-credit-card text-danger me-1"></i> Gross revenue settled</div>
        </div>
    </div>
</div>

<!-- Secondary Stats Row -->
<div class="row g-3 mb-5">
    <div class="col-md-4">
        <div class="card border-0 shadow-sm p-3 bg-white" style="border-radius: var(--radius-md);">
            <div class="d-flex align-items-center gap-3">
                <div class="avatar-sm bg-light-primary text-primary rounded d-flex align-items-center justify-content-center" style="width: 44px; height: 44px; font-size: 1.25rem;">
                    <i class="fa-solid fa-calendar-day"></i>
                </div>
                <div>
                    <span class="text-muted text-xs uppercase d-block">Today's Visits</span>
                    <span class="fw-bold fs-4 text-dark">@ViewBag.TodayAppointmentsCount</span>
                </div>
            </div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card border-0 shadow-sm p-3 bg-white" style="border-radius: var(--radius-md);">
            <div class="d-flex align-items-center gap-3">
                <div class="avatar-sm bg-light-danger text-danger rounded d-flex align-items-center justify-content-center" style="width: 44px; height: 44px; font-size: 1.25rem;">
                    <i class="fa-solid fa-hand-holding-medical"></i>
                </div>
                <div>
                    <span class="text-muted text-xs uppercase d-block">Surgeries Scheduled</span>
                    <span class="fw-bold fs-4 text-dark">@ViewBag.TotalSurgeries</span>
                </div>
            </div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card border-0 shadow-sm p-3 bg-white" style="border-radius: var(--radius-md);">
            <div class="d-flex align-items-center gap-3">
                <div class="avatar-sm bg-light-warning text-warning rounded d-flex align-items-center justify-content-center" style="width: 44px; height: 44px; font-size: 1.25rem;">
                    <i class="fa-solid fa-receipt"></i>
                </div>
                <div>
                    <span class="text-muted text-xs uppercase d-block">Unpaid Invoices</span>
                    <span class="fw-bold fs-4 text-dark">@ViewBag.UnpaidInvoicesCount</span>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Tabs for Admin Management views -->
<div class="card border-0 shadow-sm rounded-4 bg-white mb-5">
    <div class="card-header bg-transparent border-0 px-4 pt-4">
        <ul class="nav nav-pills gap-2" id="adminTab" role="tablist">
            <li class="nav-item" role="presentation">
                <button class="nav-link active rounded-pill px-4 fw-bold" id="doc-tab" data-bs-toggle="tab" data-bs-target="#doc-pane" type="button" role="tab"><i class="fa-solid fa-user-doctor me-2"></i>Doctors</button>
            </li>
            <li class="nav-item" role="presentation">
                <button class="nav-link rounded-pill px-4 fw-bold" id="pat-tab" data-bs-toggle="tab" data-bs-target="#pat-pane" type="button" role="tab"><i class="fa-solid fa-users me-2"></i>Patients</button>
            </li>
            <li class="nav-item" role="presentation">
                <button class="nav-link rounded-pill px-4 fw-bold" id="app-tab" data-bs-toggle="tab" data-bs-target="#app-pane" type="button" role="tab"><i class="fa-solid fa-calendar-days me-2"></i>Appointments</button>
            </li>
            <li class="nav-item" role="presentation">
                <button class="nav-link rounded-pill px-4 fw-bold" id="dep-tab" data-bs-toggle="tab" data-bs-target="#dep-pane" type="button" role="tab"><i class="fa-solid fa-wallet me-2"></i>Deposits</button>
            </li>
            <li class="nav-item" role="presentation">
                <button class="nav-link rounded-pill px-4 fw-bold" id="notif-tab" data-bs-toggle="tab" data-bs-target="#notif-pane" type="button" role="tab"><i class="fa-solid fa-bell me-2"></i>System Alerts</button>
            </li>
            <li class="nav-item" role="presentation">
                <button class="nav-link rounded-pill px-4 fw-bold text-info" id="seed-tab" data-bs-toggle="tab" data-bs-target="#seed-pane" type="button" role="tab"><i class="fa-solid fa-bug me-2"></i>Seed Logs</button>
            </li>
        </ul>
    </div>
    
    <div class="card-body p-4 tab-content" id="adminTabContent">
        
        <!-- PANE 1: Doctors -->
        <div class="tab-pane fade show active" id="doc-pane" role="tabpanel" aria-labelledby="doc-tab">
            <div class="d-flex justify-content-between align-items-center mb-4">
                <h5 class="fw-bold text-dark mb-0">Doctors List</h5>
                <a asp-controller="Doctor" asp-action="Index" class="btn btn-sm btn-light border rounded-pill px-3">Doctor CRUD Flow</a>
            </div>
            <div class="table-responsive">
                <table class="table align-middle">
                    <thead>
                        <tr>
                            <th>Doctor</th>
                            <th>Specialty</th>
                            <th>License</th>
                            <th>Fee</th>
                            <th>Phone</th>
                            <th class="text-end">Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var doc in doctorsList)
                        {
                            <tr>
                                <td><span class="fw-bold text-dark">Dr. @doc.User?.FullName</span></td>
                                <td><span class="badge bg-light text-primary border border-info rounded-pill">@doc.Specialization?.Name</span></td>
                                <td><span class="font-monospace text-xs text-muted">@doc.LicenseNumber</span></td>
                                <td><span class="fw-bold text-dark">$@doc.ConsultationFee</span></td>
                                <td><span class="text-muted text-sm">@doc.User?.PhoneNumber</span></td>
                                <td class="text-end">
                                    <a asp-controller="Doctor" asp-action="Details" asp-route-id="@doc.Id" class="btn btn-outline-primary btn-xs rounded-pill">View</a>
                                    <a asp-controller="Doctor" asp-action="Edit" asp-route-id="@doc.Id" class="btn btn-light btn-xs border rounded-pill text-warning"><i class="fa-solid fa-edit"></i></a>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>

        <!-- PANE 2: Patients -->
        <div class="tab-pane fade" id="pat-pane" role="tabpanel" aria-labelledby="pat-tab">
            <div class="d-flex justify-content-between align-items-center mb-4">
                <h5 class="fw-bold text-dark mb-0">Patients Directory</h5>
                <a asp-controller="Patient" asp-action="Index" class="btn btn-sm btn-light border rounded-pill px-3">Patients CRUD Flow</a>
            </div>
            <div class="table-responsive">
                <table class="table align-middle">
                    <thead>
                        <tr>
                            <th>Patient Name</th>
                            <th>Email</th>
                            <th>National ID</th>
                            <th>Contact</th>
                            <th class="text-end">Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var pat in patientsList)
                        {
                            <tr>
                                <td><span class="fw-bold text-dark">@pat.User?.FullName</span></td>
                                <td><span class="text-sm text-muted">@pat.User?.Email</span></td>
                                <td><span class="font-monospace text-sm text-dark">@pat.NationalId</span></td>
                                <td><span class="text-muted text-sm">@pat.User?.PhoneNumber</span></td>
                                <td class="text-end">
                                    <a asp-controller="Patient" asp-action="Details" asp-route-id="@pat.Id" class="btn btn-outline-primary btn-xs rounded-pill">Profile</a>
                                    <a asp-controller="Patient" asp-action="Edit" asp-route-id="@pat.Id" class="btn btn-light btn-xs border rounded-pill text-warning"><i class="fa-solid fa-edit"></i></a>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>

        <!-- PANE 3: Appointments -->
        <div class="tab-pane fade" id="app-pane" role="tabpanel" aria-labelledby="app-tab">
            <h5 class="fw-bold text-dark mb-4">Appointments Logs</h5>
            <div class="table-responsive">
                <table class="table align-middle">
                    <thead>
                        <tr>
                            <th>Patient</th>
                            <th>Doctor</th>
                            <th>Date &amp; Time</th>
                            <th>Status</th>
                            <th>Deposit Status</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var app in appointmentsList)
                        {
                            var appBadge = app.Status switch
                            {
                                "Approved" => "bg-success text-white",
                                "Pending Doctor Approval" => "bg-warning text-dark",
                                "Pending Deposit" => "bg-info text-white",
                                "Completed" => "bg-secondary text-white",
                                _ => "bg-light text-dark"
                            };
                            <tr>
                                <td><span class="fw-bold text-dark">@app.Patient?.User?.FullName</span></td>
                                <td>Dr. @app.Doctor?.User?.FullName</td>
                                <td>
                                    <span class="fw-bold text-dark d-block">@app.AppointmentDateTime.ToString("dd MMM yyyy")</span>
                                    <span class="text-muted text-xs">@app.AppointmentDateTime.ToString("hh:mm tt")</span>
                                </td>
                                <td><span class="badge rounded-pill px-3 py-1 @appBadge">@app.Status</span></td>
                                <td>
                                    @if(app.DepositStatus == "Paid") {
                                        <span class="badge bg-light-success text-success px-2 py-1 rounded-pill"><i class="fa-solid fa-circle-check"></i> Paid ($@app.DepositAmount)</span>
                                    } else {
                                        <span class="badge bg-light-danger text-danger px-2 py-1 rounded-pill"><i class="fa-solid fa-circle-exclamation"></i> Pending ($@app.DepositAmount)</span>
                                    }
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>

        <!-- PANE 4: Deposits -->
        <div class="tab-pane fade" id="dep-pane" role="tabpanel" aria-labelledby="dep-tab">
            <h5 class="fw-bold text-dark mb-4">Deposit Payments Log</h5>
            <div class="table-responsive">
                <table class="table align-middle">
                    <thead>
                        <tr>
                            <th>Patient</th>
                            <th>Doctor</th>
                            <th>Booking Date</th>
                            <th>Deposit Amount</th>
                            <th>Paid Status</th>
                            <th>Payment Date</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var app in depositsList)
                        {
                            <tr>
                                <td><span class="fw-bold text-dark">@app.Patient?.User?.FullName</span></td>
                                <td>Dr. @app.Doctor?.User?.FullName</td>
                                <td><span class="text-muted text-sm">@app.AppointmentDateTime.ToString("g")</span></td>
                                <td><span class="fw-bold text-dark">$@app.DepositAmount.ToString("F2")</span></td>
                                <td>
                                    <span class="badge rounded-pill px-3 py-1 @(app.DepositStatus == "Paid" ? "bg-success" : "bg-danger")">
                                        @app.DepositStatus
                                    </span>
                                </td>
                                <td><span class="text-muted text-xs">@(app.PaymentDate?.ToString("g") ?? "N/A")</span></td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>

        <!-- PANE 5: System Alerts -->
        <div class="tab-pane fade" id="notif-pane" role="tabpanel" aria-labelledby="notif-tab">
            <h5 class="fw-bold text-dark mb-4">System-Wide Logged Notifications</h5>
            <div class="table-responsive" style="max-height: 400px; overflow-y: auto;">
                <table class="table table-sm align-middle">
                    <thead>
                        <tr>
                            <th>Recipient</th>
                            <th>Alert Title</th>
                            <th>Alert Message</th>
                            <th>Sent Time</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var n in notificationsList)
                        {
                            <tr>
                                <td><span class="fw-bold text-dark text-xs">@n.UserId</span></td>
                                <td><span class="badge bg-light text-primary border rounded-pill">@n.Title</span></td>
                                <td><span class="text-muted text-xs">@n.Message</span></td>
                                <td><span class="text-muted text-xs">@n.SentAt?.ToString("g")</span></td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>

        <!-- PANE 6: Seed Logs / Doctor Accounts -->
        <div class="tab-pane fade" id="seed-pane" role="tabpanel" aria-labelledby="seed-tab">
            <div class="alert alert-info border-0 p-4 rounded-3" style="background: rgba(14,165,233,0.05);">
                <h6 class="fw-bold text-dark"><i class="fa-solid fa-circle-info me-2 text-primary"></i>Developer Seed Catalog</h6>
                <p class="text-muted text-sm mb-3">Below are the credentials for the generated ophthalmologists used to log in and inspect clinical workflows.</p>
                <a href="/Home/DoctorAccountsReport" class="btn btn-primary btn-sm rounded-pill fw-bold px-4" target="_blank">
                    Open Accounts Reference Report <i class="fa-solid fa-arrow-up-right-from-square ms-1"></i>
                </a>
            </div>
            
            <div class="table-responsive">
                <table class="table table-sm align-middle">
                    <thead>
                        <tr class="table-light">
                            <th>Doctor Name</th>
                            <th>Email Address</th>
                            <th>Password</th>
                            <th>Specialty</th>
                        </tr>
                    </thead>
                    <tbody>
                        @for (int j = 1; j <= 10; j++)
                        {
                            var email = $"doctor{j}@@smarteye.com";
                            var docObj = doctorsList.FirstOrDefault(d => d.User != null && d.User.Email == email);
                            <tr>
                                <td><span class="fw-bold text-dark">@(docObj?.User?.FullName ?? $"Doctor {j}")</span></td>
                                <td><span class="font-monospace text-xs text-dark">@email</span></td>
                                <td><span class="font-monospace text-primary text-xs fw-bold">Doctor@@123</span></td>
                                <td><span class="badge bg-light text-primary border border-info text-xs">@(docObj?.Specialization?.Name ?? "Specialist")</span></td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>

    </div>
</div>

<!-- Recent Audits & Payments Lists in Footer Grid -->
<div class="row g-4">
    <!-- Audit Logs -->
    <div class="col-lg-6">
        <div class="card border-0 shadow-sm rounded-4 bg-white p-4">
            <h5 class="fw-bold text-dark mb-4"><i class="fa-solid fa-receipt text-muted me-2"></i>Recent System Audit Activity</h5>
            <div class="table-responsive" style="max-height: 300px; overflow-y: auto;">
                <table class="table table-sm align-middle table-hover">
                    <thead>
                        <tr>
                            <th>User</th>
                            <th>Action</th>
                            <th>Table</th>
                            <th>Time</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var audit in audits)
                        {
                            <tr>
                                <td><span class="fw-bold text-dark text-xs">@audit.User?.FullName</span></td>
                                <td><span class="badge bg-light-info text-info text-xs">@audit.Action</span></td>
                                <td><span class="text-muted text-xs">@audit.TableName</span></td>
                                <td><span class="text-muted text-xs">@(audit.CreatedAt?.ToString("g") ?? "N/A")</span></td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
    
    <!-- Billing Transactions -->
    <div class="col-lg-6">
        <div class="card border-0 shadow-sm rounded-4 bg-white p-4">
            <h5 class="fw-bold text-dark mb-4"><i class="fa-solid fa-cash-register text-success me-2"></i>Recent Transaction Activity</h5>
            <div class="table-responsive" style="max-height: 300px; overflow-y: auto;">
                <table class="table table-sm align-middle table-hover">
                    <thead>
                        <tr>
                            <th>Patient</th>
                            <th>Amount</th>
                            <th>Method</th>
                            <th>Date</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var p in payments)
                        {
                            <tr>
                                <td><span class="fw-bold text-dark text-xs">@p.Invoice?.Patient?.User?.FullName</span></td>
                                <td><span class="fw-bold text-success text-xs">$@p.Amount</span></td>
                                <td><span class="badge bg-light text-primary border border-info text-xs">@p.PaymentMethod?.Name</span></td>
                                <td><span class="text-muted text-xs">@(p.PaidAt?.ToString("g") ?? "N/A")</span></td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>
