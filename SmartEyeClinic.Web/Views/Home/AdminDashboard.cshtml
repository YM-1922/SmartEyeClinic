@{
    ViewData["Title"] = "Admin Dashboard - Smart Eye Clinic";
    var audits = ViewBag.RecentAudits as List<SmartEyeClinic.Models.AuditLog>;
    var payments = ViewBag.RecentPayments as List<SmartEyeClinic.Models.Payment>;
}

<div class="container-fluid py-4">
    <!-- Header -->
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h3 class="fw-bold text-dark mb-1">Administrative Intelligence</h3>
            <p class="text-muted small mb-0">Clinic operations control room and performance KPIs.</p>
        </div>
        <div class="d-flex gap-2">
            <a asp-controller="Patient" asp-action="Create" class="btn btn-primary btn-sm px-3 py-2 border-0" style="background: var(--primary-color); border-radius: 8px;">
                <i class="fa-solid fa-user-plus me-1"></i> New Patient
            </a>
            <a asp-controller="Doctor" asp-action="Create" class="btn btn-success btn-sm px-3 py-2 border-0" style="background: var(--success-color); border-radius: 8px;">
                <i class="fa-solid fa-user-doctor me-1"></i> Add Doctor
            </a>
        </div>
    </div>

    <!-- Stats row -->
    <div class="row g-4 mb-4">
        <div class="col-xl-3 col-md-6">
            <div class="card metric-card metric-gradient-primary h-100 shadow-sm">
                <div class="card-body">
                    <div class="text-uppercase text-white-50 small fw-bold mb-1">Total Patients</div>
                    <div class="fs-2 fw-bold text-white mb-2">@ViewBag.TotalPatients</div>
                    <div class="small text-white-50"><i class="fa-solid fa-users"></i> Registered clinic cases</div>
                </div>
                <div class="icon-wrapper">
                    <i class="fa-solid fa-hospital-user"></i>
                </div>
            </div>
        </div>

        <div class="col-xl-3 col-md-6">
            <div class="card metric-card metric-gradient-secondary h-100 shadow-sm">
                <div class="card-body">
                    <div class="text-uppercase text-white-50 small fw-bold mb-1">Active Specialists</div>
                    <div class="fs-2 fw-bold text-white mb-2">@ViewBag.TotalDoctors</div>
                    <div class="small text-white-50"><i class="fa-solid fa-user-md"></i> Clinical staff</div>
                </div>
                <div class="icon-wrapper">
                    <i class="fa-solid fa-user-doctor"></i>
                </div>
            </div>
        </div>

        <div class="col-xl-3 col-md-6">
            <div class="card metric-card metric-gradient-accent h-100 shadow-sm">
                <div class="card-body">
                    <div class="text-uppercase text-white-50 small fw-bold mb-1">Total Bookings</div>
                    <div class="fs-2 fw-bold text-white mb-2">@ViewBag.TotalAppointments</div>
                    <div class="small text-white-50"><i class="fa-solid fa-calendar-check"></i> Consultations logged</div>
                </div>
                <div class="icon-wrapper">
                    <i class="fa-solid fa-calendar-check"></i>
                </div>
            </div>
        </div>

        <div class="col-xl-3 col-md-6">
            <div class="card metric-card metric-gradient-success h-100 shadow-sm">
                <div class="card-body">
                    <div class="text-uppercase text-white-50 small fw-bold mb-1">Total Revenue</div>
                    <div class="fs-2 fw-bold text-white mb-2">$@(((decimal)ViewBag.TotalRevenue).ToString("N2"))</div>
                    <div class="small text-white-50"><i class="fa-solid fa-wallet"></i> Gross settlement payments</div>
                </div>
                <div class="icon-wrapper">
                    <i class="fa-solid fa-dollar-sign"></i>
                </div>
            </div>
        </div>
    </div>

    <!-- Secondary Stats Row -->
    <div class="row g-4 mb-4">
        <div class="col-md-4">
            <div class="card border-0 shadow-sm p-3 d-flex flex-row align-items-center justify-content-between" style="background: var(--card-bg); border-radius: 12px;">
                <div>
                    <span class="text-muted small d-block">Today's Visits</span>
                    <strong class="fs-4 text-dark">@ViewBag.TodayAppointmentsCount</strong>
                </div>
                <div class="p-3 rounded-circle bg-light-primary text-primary"><i class="fa-solid fa-calendar-day fs-4"></i></div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card border-0 shadow-sm p-3 d-flex flex-row align-items-center justify-content-between" style="background: var(--card-bg); border-radius: 12px;">
                <div>
                    <span class="text-muted small d-block">Surgeries Scheduled</span>
                    <strong class="fs-4 text-dark">@ViewBag.TotalSurgeries</strong>
                </div>
                <div class="p-3 rounded-circle bg-light-danger text-danger"><i class="fa-solid fa-syringe fs-4"></i></div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card border-0 shadow-sm p-3 d-flex flex-row align-items-center justify-content-between" style="background: var(--card-bg); border-radius: 12px;">
                <div>
                    <span class="text-muted small d-block">Unpaid Invoices</span>
                    <strong class="fs-4 text-dark">@ViewBag.UnpaidInvoicesCount</strong>
                </div>
                <div class="p-3 rounded-circle bg-light-warning text-warning"><i class="fa-solid fa-file-invoice-dollar fs-4"></i></div>
            </div>
        </div>
    </div>

    <!-- Main Section -->
    <div class="row g-4">
        <!-- Revenue Analytics & Audit Log -->
        <div class="col-lg-7">
            <!-- Chart Card -->
            <div class="card border-0 shadow-sm rounded-4 mb-4" style="background: var(--card-bg);">
                <div class="card-header-clean">
                    <h5 class="mb-0"><i class="fa-solid fa-chart-line text-primary me-2"></i>Revenue Flow & Patient Traffic</h5>
                </div>
                <div class="card-body p-4">
                    <div style="height: 250px;">
                        <canvas id="revenueChart"></canvas>
                    </div>
                </div>
            </div>

            <!-- Recent Payments -->
            <div class="card border-0 shadow-sm rounded-4" style="background: var(--card-bg);">
                <div class="card-header-clean">
                    <h5 class="mb-0"><i class="fa-solid fa-dollar-sign text-success me-2"></i>Recent Payments Settled</h5>
                    <a asp-controller="Payment" asp-action="Index" class="btn btn-sm btn-link text-decoration-none">View All</a>
                </div>
                <div class="card-body p-4">
                    @if (payments == null || !payments.Any())
                    {
                        <div class="text-center py-4 text-muted">
                            <i class="fa-regular fa-folder-open fs-2 mb-2 d-block"></i>
                            No recent payments found.
                        </div>
                    }
                    else
                    {
                        <div class="table-responsive">
                            <table class="table custom-table small">
                                <thead>
                                    <tr>
                                        <th>Patient</th>
                                        <th>Amount</th>
                                        <th>Method</th>
                                        <th>Date</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var p in payments)
                                    {
                                        <tr>
                                            <td><strong>@p.Invoice.Patient.User.FullName</strong></td>
                                            <td class="text-success fw-bold">$@p.Amount.ToString("F2")</td>
                                            <td><span class="badge bg-light text-dark border">@p.PaymentMethod.Name</span></td>
                                            <td class="text-muted">@(p.PaidAt.HasValue ? p.PaidAt.Value.ToString("dd MMM yyyy") : "N/A")</td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    }
                </div>
            </div>
        </div>

        <!-- Audit log and Quick actions -->
        <div class="col-lg-5">
            <!-- Audit Logs -->
            <div class="card border-0 shadow-sm rounded-4 mb-4" style="background: var(--card-bg);">
                <div class="card-header-clean">
                    <h5 class="mb-0"><i class="fa-solid fa-clock-rotate-left text-danger me-2"></i>Security Audit Log</h5>
                </div>
                <div class="card-body p-4">
                    @if (audits == null || !audits.Any())
                    {
                        <div class="text-center py-5 text-muted">
                            <i class="fa-solid fa-shield-halved fs-1 mb-3 d-block"></i>
                            No recent events captured.
                        </div>
                    }
                    else
                    {
                        <div class="timeline-container">
                            <ul class="list-unstyled mb-0" style="position: relative; padding-left: 20px;">
                                @foreach (var audit in audits)
                                {
                                    <li class="mb-3" style="position: relative;">
                                        <!-- timeline dot -->
                                        <span class="bg-primary rounded-circle" style="position: absolute; left: -25px; top: 4px; width: 10px; height: 10px; border: 2px solid white; box-shadow: 0 0 0 2px rgba(15,76,129,0.15);"></span>
                                        <div class="d-flex justify-content-between align-items-start">
                                            <div>
                                                <strong class="text-dark small d-block">@audit.Action</strong>
                                                <span class="text-muted" style="font-size: 0.78rem;">
                                                    Table: @(string.IsNullOrEmpty(audit.TableName) ? "N/A" : audit.TableName) | By: @(audit.User?.FullName ?? "System")
                                                </span>
                                            </div>
                                            <span class="text-muted small" style="font-size: 0.72rem;">@audit.CreatedAt?.ToString("hh:mm tt")</span>
                                        </div>
                                    </li>
                                }
                            </ul>
                        </div>
                    }
                </div>
            </div>

            <!-- Quick Management Shortcuts -->
            <div class="card border-0 shadow-sm rounded-4" style="background: var(--card-bg);">
                <div class="card-header-clean">
                    <h5 class="mb-0"><i class="fa-solid fa-sliders text-secondary me-2"></i>Management Modules</h5>
                </div>
                <div class="card-body p-4">
                    <div class="row g-2">
                        <div class="col-6">
                            <a asp-controller="Branch" asp-action="Index" class="btn btn-light w-100 text-start py-3 border rounded-3 hover-shadow transition-all">
                                <i class="fa-solid fa-hospital text-info fs-4 mb-2 d-block"></i>
                                <span class="fw-bold text-dark small d-block">Branches</span>
                                <span class="text-muted" style="font-size: 0.7rem;">Clinic Sites</span>
                            </a>
                        </div>
                        <div class="col-6">
                            <a asp-controller="Specialization" asp-action="Index" class="btn btn-light w-100 text-start py-3 border rounded-3 hover-shadow transition-all">
                                <i class="fa-solid fa-tags text-warning fs-4 mb-2 d-block"></i>
                                <span class="fw-bold text-dark small d-block">Specializations</span>
                                <span class="text-muted" style="font-size: 0.7rem;">Ocular Fields</span>
                            </a>
                        </div>
                        <div class="col-6">
                            <a asp-controller="Medicine" asp-action="Index" class="btn btn-light w-100 text-start py-3 border rounded-3 hover-shadow transition-all">
                                <i class="fa-solid fa-pills text-success fs-4 mb-2 d-block"></i>
                                <span class="fw-bold text-dark small d-block">Medicines</span>
                                <span class="text-muted" style="font-size: 0.7rem;">Pharmacy</span>
                            </a>
                        </div>
                        <div class="col-6">
                            <a asp-controller="Payment" asp-action="Methods" class="btn btn-light w-100 text-start py-3 border rounded-3 hover-shadow transition-all">
                                <i class="fa-solid fa-credit-card text-primary fs-4 mb-2 d-block"></i>
                                <span class="fw-bold text-dark small d-block">Pay Methods</span>
                                <span class="text-muted" style="font-size: 0.7rem;">Settlements</span>
                            </a>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <!-- Include ChartJS -->
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <script>
        document.addEventListener("DOMContentLoaded", function () {
            var ctx = document.getElementById('revenueChart').getContext('2d');
            
            // Linear Gradient
            var purpleGrad = ctx.createLinearGradient(0, 0, 0, 220);
            purpleGrad.addColorStop(0, 'rgba(15, 76, 129, 0.4)');
            purpleGrad.addColorStop(1, 'rgba(15, 76, 129, 0.01)');

            var blueGrad = ctx.createLinearGradient(0, 0, 0, 220);
            blueGrad.addColorStop(0, 'rgba(0, 180, 216, 0.3)');
            blueGrad.addColorStop(1, 'rgba(0, 180, 216, 0.01)');

            new Chart(ctx, {
                type: 'line',
                data: {
                    labels: ['Jan', 'Feb', 'Mar', 'Apr', 'May', 'Jun', 'Jul', 'Aug'],
                    datasets: [
                        {
                            label: 'Revenue ($)',
                            data: [3100, 4200, 3900, 5100, 5800, 6200, @(ViewBag.TotalRevenue > 0 ? ViewBag.TotalRevenue : 6500), @(ViewBag.TotalRevenue > 0 ? ViewBag.TotalRevenue + 500 : 7000)],
                            borderColor: '#0F4C81',
                            backgroundColor: purpleGrad,
                            fill: true,
                            tension: 0.3,
                            borderWidth: 3
                        },
                        {
                            label: 'Appointments',
                            data: [110, 140, 130, 180, 210, 240, @(ViewBag.TotalAppointments > 0 ? ViewBag.TotalAppointments : 250), @(ViewBag.TotalAppointments > 0 ? ViewBag.TotalAppointments + 20 : 270)],
                            borderColor: '#00B4D8',
                            backgroundColor: blueGrad,
                            fill: true,
                            tension: 0.3,
                            borderWidth: 2,
                            yAxisID: 'y1'
                        }
                    ]
                },
                options: {
                    responsive: true,
                    maintainAspectRatio: false,
                    scales: {
                        y: {
                            type: 'linear',
                            display: true,
                            position: 'left',
                            grid: { drawOnChartArea: true }
                        },
                        y1: {
                            type: 'linear',
                            display: true,
                            position: 'right',
                            grid: { drawOnChartArea: false }
                        }
                    }
                }
            });
        });
    </script>
}
