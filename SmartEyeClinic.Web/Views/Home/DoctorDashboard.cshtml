@{
    ViewData["Title"] = "Doctor Dashboard";
    var appointments = ViewBag.TodayAppointments as List<SmartEyeClinic.Models.Appointment>;
    var surgeries    = ViewBag.UpcomingSurgeries  as List<SmartEyeClinic.Models.Surgery>;
}

<!-- Page Header -->
<div class="page-header">
    <div class="page-header-left">
        <div class="breadcrumb-nav">
            <a href="/"><i class="bi bi-house-door"></i> Home</a>
            <span class="separator">/</span>
            <span class="current">Doctor Dashboard</span>
        </div>
        <h1 class="page-title"><i class="bi bi-heart-pulse text-secondary-custom me-2"></i>Clinical Control Center</h1>
        <p class="page-subtitle">
            Welcome back, <strong>@User.Identity?.Name</strong>. Today is @DateTime.Today.ToString("dddd, dd MMMM yyyy").
        </p>
    </div>
    <div class="d-flex gap-2 flex-wrap">
        <a asp-controller="Examination"  asp-action="Create" class="btn btn-outline-primary btn-sm">
            <i class="bi bi-file-medical"></i> Log Examination
        </a>
        <a asp-controller="Prescription" asp-action="Create" class="btn btn-primary btn-sm">
            <i class="bi bi-prescription2"></i> New Prescription
        </a>
    </div>
</div>

<!-- KPI Row -->
<div class="row g-4 mb-4">
    <div class="col-md-4">
        <div class="metric-card metric-gradient-primary">
            <div class="metric-label">My Patients</div>
            <div class="metric-value">@ViewBag.TotalMyPatients</div>
            <div class="metric-sub"><i class="bi bi-person-check"></i> Distinct consultations</div>
            <div class="metric-icon"><i class="bi bi-hospital"></i></div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="metric-card metric-gradient-secondary">
            <div class="metric-label">Pending Consults</div>
            <div class="metric-value">@ViewBag.MyPendingAppointments</div>
            <div class="metric-sub"><i class="bi bi-hourglass-split"></i> Upcoming visits</div>
            <div class="metric-icon"><i class="bi bi-calendar-check"></i></div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="metric-card metric-gradient-danger">
            <div class="metric-label">Ocular Surgeries</div>
            <div class="metric-value">@ViewBag.MySurgeries</div>
            <div class="metric-sub"><i class="bi bi-scissors"></i> Operating theater</div>
            <div class="metric-icon"><i class="bi bi-activity"></i></div>
        </div>
    </div>
</div>

<!-- Main Content -->
<div class="row g-4">
    <!-- Today's Consultations -->
    <div class="col-lg-8">
        <div class="table-card h-100">
            <div class="table-card-header">
                <h5 class="table-title"><i class="bi bi-calendar-day"></i> Today's Consultations</h5>
                <span class="badge-status badge-primary">@DateTime.Today.ToString("dd MMMM yyyy")</span>
            </div>
            @if (appointments == null || !appointments.Any())
            {
                <div class="empty-state">
                    <div class="empty-state-icon"><i class="bi bi-calendar-x"></i></div>
                    <h5>No Appointments Today</h5>
                    <p>You have no consultations scheduled for today. All your upcoming appointments will appear here.</p>
                    <a asp-controller="Appointment" asp-action="Index" class="btn btn-primary btn-sm">
                        <i class="bi bi-calendar2-week"></i> View All Appointments
                    </a>
                </div>
            }
            else
            {
                <div class="table-responsive-custom">
                    <table class="custom-table">
                        <thead>
                            <tr>
                                <th>Patient</th>
                                <th>Time</th>
                                <th>Branch</th>
                                <th>Status</th>
                                <th>Actions</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var app in appointments)
                            {
                                var aBadge = "";
                                switch (app.Status)
                                {
                                    case "Completed": aBadge = "badge-success"; break;
                                    case "Pending": aBadge = "badge-warning"; break;
                                    case "Confirmed": aBadge = "badge-info"; break;
                                    case "Cancelled": aBadge = "badge-danger"; break;
                                    default: aBadge = "badge-neutral"; break;
                                }
                                <tr>
                                    <td>
                                        <div class="d-flex align-items-center gap-2">
                                            <div class="avatar-initials avatar-sm">
                                                @(app.Patient?.User?.FullName?.Length > 0 ? app.Patient.User.FullName[0].ToString().ToUpper() : "P")
                                            </div>
                                            <div>
                                                <a asp-controller="Patient" asp-action="Details" asp-route-id="@app.PatientId"
                                                   class="fw-600 text-sm d-block" style="color:var(--text);">
                                                    @app.Patient?.User?.FullName
                                                </a>
                                                <span class="text-xs text-muted">ID: #@app.PatientId</span>
                                            </div>
                                        </div>
                                    </td>
                                    <td><span class="fw-600 text-sm">@app.AppointmentDateTime.ToString("hh:mm tt")</span></td>
                                    <td><span class="text-muted text-sm">@app.Branch?.Name</span></td>
                                    <td><span class="badge-status @aBadge">@app.Status</span></td>
                                    <td>
                                        <div class="dropdown">
                                            <button class="btn btn-light btn-icon btn-sm border" type="button"
                                                    data-bs-toggle="dropdown" aria-expanded="false">
                                                <i class="bi bi-three-dots-vertical"></i>
                                            </button>
                                            <ul class="dropdown-menu dropdown-menu-end premium-dropdown shadow">
                                                <li>
                                                    <a class="dropdown-item" asp-controller="Examination" asp-action="Create"
                                                       asp-route-appointmentId="@app.Id">
                                                        <i class="bi bi-file-medical"></i> Add Exam
                                                    </a>
                                                </li>
                                                <li>
                                                    <a class="dropdown-item" asp-controller="Patient" asp-action="Details"
                                                       asp-route-id="@app.PatientId">
                                                        <i class="bi bi-person-vcard"></i> Patient File
                                                    </a>
                                                </li>
                                                <li><hr class="dropdown-divider"></li>
                                                <li>
                                                    <a class="dropdown-item" asp-controller="Appointment" asp-action="Edit"
                                                       asp-route-id="@app.Id">
                                                        <i class="bi bi-clock"></i> Reschedule
                                                    </a>
                                                </li>
                                            </ul>
                                        </div>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
        </div>
    </div>

    <!-- Sidebar -->
    <div class="col-lg-4">
        <!-- Surgery Queue -->
        <div class="table-card mb-4">
            <div class="table-card-header">
                <h5 class="table-title"><i class="bi bi-activity"></i> Upcoming Surgeries</h5>
                <span class="badge-status badge-danger">Scheduled</span>
            </div>
            <div class="card-body-clean" style="max-height:260px; overflow-y:auto;">
                @if (surgeries == null || !surgeries.Any())
                {
                    <div class="empty-state" style="padding:30px 20px;">
                        <div class="empty-state-icon"><i class="bi bi-check-circle"></i></div>
                        <h5>No Surgeries Scheduled</h5>
                        <p>Your upcoming operating theater cases will appear here.</p>
                    </div>
                }
                else
                {
                    <div class="d-flex flex-column gap-2">
                        @foreach (var s in surgeries)
                        {
                            <div class="p-3 rounded-3 border hover-shadow transition-all" style="background:var(--bg);">
                                <div class="d-flex justify-content-between align-items-start mb-1">
                                    <span class="badge-status badge-danger">@s.SurgeryType?.Name</span>
                                    <span class="text-xs text-muted">@s.SurgeryDate.ToString("dd MMM")</span>
                                </div>
                                <div class="fw-600 text-sm mb-1">@s.Patient?.User?.FullName</div>
                                <div class="text-xs text-muted">
                                    <i class="bi bi-clock"></i> @s.SurgeryDate.ToString("hh:mm tt") &nbsp;·&nbsp;
                                    OT-@s.Id
                                </div>
                            </div>
                        }
                    </div>
                }
            </div>
        </div>

        <!-- Calendar shortcut -->
        <div class="custom-card overflow-hidden">
            <div class="p-4 text-white"
                 style="background: linear-gradient(135deg, var(--primary) 0%, var(--primary-light) 100%);">
                <div class="d-flex align-items-center justify-content-between mb-3">
                    <h6 class="fw-700 mb-0">My Clinical Calendar</h6>
                    <i class="bi bi-calendar-week fs-4"></i>
                </div>
                <p class="text-sm mb-3" style="color:rgba(255,255,255,0.7);">
                    View your full appointment schedule, working hours, and surgical blocks.
                </p>
                <a asp-controller="Home" asp-action="Calendar"
                   class="btn btn-sm w-100 fw-700"
                   style="background:#fff; color:var(--primary); border-radius:8px;">
                    <i class="bi bi-calendar-range"></i> Open Planner
                </a>
            </div>
        </div>
    </div>
</div>
