@{
    ViewData["Title"] = "Doctor Dashboard - Smart Eye Clinic";
    var appointments = ViewBag.TodayAppointments as List<SmartEyeClinic.Models.Appointment>;
    var surgeries = ViewBag.UpcomingSurgeries as List<SmartEyeClinic.Models.Surgery>;
}

<div class="container-fluid py-4">
    <!-- Header -->
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h3 class="fw-bold text-dark mb-1">Clinical Control Center</h3>
            <p class="text-muted small mb-0">Welcome back, @User.Identity?.Name. Access patient records and schedule visits.</p>
        </div>
        <div class="d-flex gap-2">
            <a asp-controller="Examination" asp-action="Create" class="btn btn-primary btn-sm px-3 py-2 border-0" style="background: var(--primary-color); border-radius: 8px;">
                <i class="fa-solid fa-notes-medical me-1"></i> Log Examination
            </a>
            <a asp-controller="Prescription" asp-action="Create" class="btn btn-success btn-sm px-3 py-2 border-0" style="background: var(--success-color); border-radius: 8px;">
                <i class="fa-solid fa-file-prescription me-1"></i> New Prescription
            </a>
        </div>
    </div>

    <!-- Stats row -->
    <div class="row g-4 mb-4">
        <div class="col-md-4">
            <div class="card metric-card metric-gradient-primary h-100 shadow-sm">
                <div class="card-body">
                    <div class="text-uppercase text-white-50 small fw-bold mb-1">My Patients</div>
                    <div class="fs-2 fw-bold text-white mb-2">@ViewBag.TotalMyPatients</div>
                    <div class="small text-white-50"><i class="fa-solid fa-user-injured"></i> Distinct consult patients</div>
                </div>
                <div class="icon-wrapper">
                    <i class="fa-solid fa-hospital-user"></i>
                </div>
            </div>
        </div>

        <div class="col-md-4">
            <div class="card metric-card metric-gradient-secondary h-100 shadow-sm">
                <div class="card-body">
                    <div class="text-uppercase text-white-50 small fw-bold mb-1">Pending Consuls</div>
                    <div class="fs-2 fw-bold text-white mb-2">@ViewBag.MyPendingAppointments</div>
                    <div class="small text-white-50"><i class="fa-solid fa-hourglass-half"></i> Upcoming booked visits</div>
                </div>
                <div class="icon-wrapper">
                    <i class="fa-solid fa-calendar-check"></i>
                </div>
            </div>
        </div>

        <div class="col-md-4">
            <div class="card metric-card metric-gradient-danger h-100 shadow-sm">
                <div class="card-body">
                    <div class="text-uppercase text-white-50 small fw-bold mb-1">Ocular Surgeries</div>
                    <div class="fs-2 fw-bold text-white mb-2">@ViewBag.MySurgeries</div>
                    <div class="small text-white-50"><i class="fa-solid fa-scissors"></i> Operating theater files</div>
                </div>
                <div class="icon-wrapper">
                    <i class="fa-solid fa-syringe"></i>
                </div>
            </div>
        </div>
    </div>

    <div class="row g-4">
        <!-- Today's consultations -->
        <div class="col-lg-8">
            <div class="card border-0 shadow-sm rounded-4 h-100" style="background: var(--card-bg);">
                <div class="card-header-clean">
                    <h5 class="mb-0"><i class="fa-solid fa-calendar-day text-primary me-2"></i>Today's Consultations</h5>
                    <span class="badge bg-light-primary text-primary px-2.5 py-1.5 rounded-pill small fw-600">@DateTime.Today.ToString("dd MMMM yyyy")</span>
                </div>
                <div class="card-body p-4">
                    @if (appointments == null || !appointments.Any())
                    {
                        <div class="text-center py-5">
                            <i class="fa-regular fa-calendar-check fs-1 text-muted mb-3 d-block"></i>
                            <h6 class="text-muted fw-normal">You have no appointments scheduled for today.</h6>
                            <p class="text-muted small">Use the search to inspect patient records manually.</p>
                        </div>
                    }
                    else
                    {
                        <div class="table-responsive-custom">
                            <table class="table custom-table">
                                <thead>
                                    <tr>
                                        <th>Patient</th>
                                        <th>Time</th>
                                        <th>Branch</th>
                                        <th>Status</th>
                                        <th>Actions</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var app in appointments)
                                    {
                                        <tr>
                                            <td>
                                                <div class="d-flex align-items-center">
                                                    <div class="avatar-circle me-2 bg-light-primary text-primary fw-bold text-center" style="width: 32px; height: 32px; border-radius: 50%; line-height: 32px; font-size: 0.85rem;">
                                                        @(app.Patient.User.FullName.Length > 0 ? app.Patient.User.FullName[0].ToString().ToUpper() : "P")
                                                    </div>
                                                    <div>
                                                        <a asp-controller="Patient" asp-action="Details" asp-route-id="@app.PatientId" class="fw-bold d-block text-dark text-decoration-none">@app.Patient.User.FullName</a>
                                                        <span class="text-muted small">ID: #@app.PatientId</span>
                                                    </div>
                                                </div>
                                            </td>
                                            <td>
                                                <span class="text-dark fw-500">@app.AppointmentDateTime.ToString("hh:mm tt")</span>
                                            </td>
                                            <td>
                                                <span class="text-muted">@app.Branch.Name</span>
                                            </td>
                                            <td>
                                                @if (app.Status == "Completed")
                                                {
                                                    <span class="badge-custom badge-custom-success">Completed</span>
                                                }
                                                else if (app.Status == "Pending")
                                                {
                                                    <span class="badge-custom badge-custom-warning">Pending</span>
                                                }
                                                else
                                                {
                                                    <span class="badge-custom badge-custom-danger">@app.Status</span>
                                                }
                                            </td>
                                            <td>
                                                <div class="dropdown">
                                                    <button class="btn btn-light btn-sm border-0 dropdown-toggle" type="button" data-bs-toggle="dropdown" aria-expanded="false">
                                                        <i class="fa-solid fa-ellipsis-vertical"></i>
                                                    </button>
                                                    <ul class="dropdown-menu dropdown-menu-end shadow border-0">
                                                        <li><a class="dropdown-item py-2" asp-controller="Examination" asp-action="Create" asp-route-appointmentId="@app.Id"><i class="fa-solid fa-file-medical me-2 text-muted"></i>Add Exam</a></li>
                                                        <li><a class="dropdown-item py-2" asp-controller="Patient" asp-action="Details" asp-route-id="@app.PatientId"><i class="fa-solid fa-id-card me-2 text-muted"></i>Patient File</a></li>
                                                        <li><hr class="dropdown-divider"></li>
                                                        <li><a class="dropdown-item py-2" asp-controller="Appointment" asp-action="Edit" asp-route-id="@app.Id"><i class="fa-solid fa-clock me-2 text-muted"></i>Reschedule</a></li>
                                                    </ul>
                                                </div>
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    }
                </div>
            </div>
        </div>

        <!-- Operating theater queue & availability -->
        <div class="col-lg-4">
            <!-- Surgery schedule -->
            <div class="card border-0 shadow-sm rounded-4 mb-4" style="background: var(--card-bg);">
                <div class="card-header-clean">
                    <h5 class="mb-0"><i class="fa-solid fa-bed-pulse text-danger me-2"></i>Operating Room Queue</h5>
                </div>
                <div class="card-body p-4">
                    @if (surgeries == null || !surgeries.Any())
                    {
                        <div class="text-center py-5 text-muted">
                            <i class="fa-solid fa-circle-check fs-1 text-success mb-3 d-block"></i>
                            No surgeries scheduled for today.
                        </div>
                    }
                    else
                    {
                        <div class="list-group list-group-flush">
                            @foreach (var s in surgeries)
                            {
                                <div class="list-group-item px-0 border-0 mb-3 bg-light p-3 rounded-3 hover-shadow transition-all">
                                    <div class="d-flex justify-content-between align-items-start mb-2">
                                        <span class="badge bg-danger px-2.5 py-1 rounded-pill small">@s.SurgeryType.Name</span>
                                        <span class="text-muted small">@s.SurgeryDate.ToString("dd MMM hh:mm tt")</span>
                                    </div>
                                    <div class="small mb-1">
                                        <strong class="text-dark">Patient:</strong> @s.Patient.User.FullName
                                    </div>
                                    <div class="small text-muted mb-0">
                                        <i class="fa-solid fa-hospital-user me-1"></i> ID: #@s.PatientId | Theater: OT-@s.Id
                                    </div>
                                </div>
                            }
                        </div>
                    }
                </div>
            </div>

            <!-- Clinic Calendar shortcut card -->
            <div class="card border-0 shadow-sm rounded-4" style="background: var(--card-bg); overflow: hidden;">
                <div class="p-4 text-white" style="background: linear-gradient(135deg, #0F4C81 0%, #1D70B8 100%);">
                    <div class="d-flex align-items-center justify-content-between mb-3">
                        <h6 class="fw-bold mb-0">My Clinical Calendar</h6>
                        <i class="fa-regular fa-calendar-days fs-4"></i>
                    </div>
                    <p class="small text-white-50 mb-3">Check doctor schedules, working days, shifts, and leaves at once.</p>
                    <a asp-controller="Home" asp-action="Calendar" class="btn btn-light btn-sm w-100 fw-bold border-0" style="color: #0F4C81; border-radius: 8px;">
                        Open Planner
                    </a>
                </div>
            </div>
        </div>
    </div>
</div>
