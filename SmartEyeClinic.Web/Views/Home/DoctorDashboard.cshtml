@{
    ViewData["Title"] = "Doctor Dashboard";
    var todayAppointments = ViewBag.TodayAppointments as List<SmartEyeClinic.Models.Appointment>;
    var pendingApprovals = ViewBag.PendingApprovals as List<SmartEyeClinic.Models.Appointment>;
    var confirmedDeposits = ViewBag.ConfirmedDeposits as List<SmartEyeClinic.Models.Appointment>;
    var patientHistory = ViewBag.PatientHistory as List<SmartEyeClinic.Models.Appointment>;
    var surgeries = ViewBag.UpcomingSurgeries as List<SmartEyeClinic.Models.Surgery>;
}

<!-- Page Header -->
<div class="page-header py-4 mb-4 border-bottom">
    <div class="d-flex justify-content-between align-items-center flex-wrap gap-3">
        <div>
            <div class="breadcrumb-nav small text-muted mb-2">
                <a href="/" class="text-decoration-none text-muted"><i class="fa-solid fa-house"></i> Home</a>
                <span class="mx-2">/</span>
                <span class="text-primary font-weight-bold">Doctor Control Center</span>
            </div>
            <h1 class="page-title fw-800 text-dark mb-1"><i class="fa-solid fa-user-md text-primary me-2"></i>Clinical Control Center</h1>
            <p class="text-muted mb-0">Welcome back, <strong>@User.Identity?.Name</strong>. Manage schedules, requests, and clinical profiles.</p>
        </div>
        <div class="d-flex gap-2">
            <a asp-controller="Examination" asp-action="Create" class="btn btn-outline-primary rounded-pill px-4 fw-bold">
                <i class="fa-solid fa-notes-medical me-1"></i> Log Examination
            </a>
            <a asp-controller="Prescription" asp-action="Create" class="btn btn-primary rounded-pill px-4 fw-bold shadow-sm">
                <i class="fa-solid fa-prescription-bottle-medical me-1"></i> New Prescription
            </a>
        </div>
    </div>
</div>

<!-- KPIs -->
<div class="row g-4 mb-5">
    <div class="col-lg-4 col-md-6">
        <div class="card border-0 shadow-sm p-4 h-100 bg-white" style="border-radius: var(--radius-lg); border-left: 5px solid var(--primary) !important;">
            <span class="text-muted text-xs uppercase fw-bold d-block mb-1">Total Consultation Patients</span>
            <div class="fs-2 fw-bold text-dark mb-2">@ViewBag.TotalMyPatients</div>
            <div class="text-muted small"><i class="fa-solid fa-user-tag text-primary me-1"></i> Registered unique cases</div>
        </div>
    </div>
    <div class="col-lg-4 col-md-6">
        <div class="card border-0 shadow-sm p-4 h-100 bg-white" style="border-radius: var(--radius-lg); border-left: 5px solid var(--warning) !important;">
            <span class="text-muted text-xs uppercase fw-bold d-block mb-1">My Pending Approvals</span>
            <div class="fs-2 fw-bold text-dark mb-2">@ViewBag.MyPendingAppointments</div>
            <div class="text-muted small"><i class="fa-solid fa-hourglass-half text-warning me-1"></i> Waiting your review</div>
        </div>
    </div>
    <div class="col-lg-4 col-md-6">
        <div class="card border-0 shadow-sm p-4 h-100 bg-white" style="border-radius: var(--radius-lg); border-left: 5px solid var(--danger) !important;">
            <span class="text-muted text-xs uppercase fw-bold d-block mb-1">Ocular Surgeries Scheduled</span>
            <div class="fs-2 fw-bold text-dark mb-2">@ViewBag.MySurgeries</div>
            <div class="text-muted small"><i class="fa-solid fa-shield-halved text-danger me-1"></i> Operating theater logs</div>
        </div>
    </div>
</div>

<div class="row g-4 mb-5">
    <!-- Left Column: Tasks, Approvals, Deposits -->
    <div class="col-lg-8">
        
        <!-- Today's Consultations -->
        <div class="card border-0 shadow-sm rounded-4 mb-4 bg-white">
            <div class="card-header bg-transparent border-0 d-flex justify-content-between align-items-center px-4 pt-4">
                <h5 class="fw-bold text-dark mb-0"><i class="fa-solid fa-user-injured text-primary me-2"></i>Today's Consultations</h5>
                <span class="badge bg-light-primary text-primary px-3 py-1 rounded-pill">@DateTime.Today.ToString("dd MMM yyyy")</span>
            </div>
            <div class="card-body px-4 pb-4">
                @if (todayAppointments == null || !todayAppointments.Any())
                {
                    <div class="text-center py-4 text-muted">
                        <i class="fa-solid fa-calendar-times fs-2 mb-2 text-light"></i>
                        <p class="small mb-0">No consultations scheduled for today.</p>
                    </div>
                }
                else
                {
                    <div class="table-responsive">
                        <table class="table align-middle">
                            <thead>
                                <tr>
                                    <th>Patient</th>
                                    <th>Time</th>
                                    <th>Status</th>
                                    <th class="text-end">Actions</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var app in todayAppointments)
                                {
                                    var appBadge = app.Status switch
                                    {
                                        "Completed" => "bg-success text-white",
                                        "Approved" => "bg-primary text-white",
                                        "Pending Doctor Approval" => "bg-warning text-dark",
                                        _ => "bg-secondary text-white"
                                    };
                                    <tr>
                                        <td>
                                            <div class="d-flex align-items-center gap-2">
                                                <div class="avatar-sm bg-light-primary text-primary rounded-circle d-flex align-items-center justify-content-center fw-bold" style="width: 32px; height: 32px;">
                                                    @(app.Patient?.User?.FullName?.Length > 0 ? app.Patient.User.FullName[0].ToString().ToUpper() : "P")
                                                </div>
                                                <div>
                                                    <span class="fw-bold text-dark d-block">@app.Patient?.User?.FullName</span>
                                                    <span class="text-muted text-xs">ID: #@app.PatientId</span>
                                                </div>
                                            </div>
                                        </td>
                                        <td><span class="fw-bold text-dark">@app.AppointmentDateTime.ToString("hh:mm tt")</span></td>
                                        <td><span class="badge rounded-pill px-3 py-1 @appBadge">@app.Status</span></td>
                                        <td class="text-end">
                                            <div class="d-flex justify-content-end gap-1">
                                                @if (app.Status == "Approved")
                                                {
                                                    <form asp-controller="Appointment" asp-action="Complete" asp-route-id="@app.Id" method="post" class="d-inline">
                                                        <button type="submit" class="btn btn-success btn-xs rounded-pill px-3"><i class="fa-solid fa-check"></i> Complete</button>
                                                    </form>
                                                }
                                                <a asp-controller="Examination" asp-action="Create" asp-route-appointmentId="@app.Id" class="btn btn-outline-primary btn-xs rounded-pill px-3">Exam</a>
                                                <a asp-controller="Patient" asp-action="Details" asp-route-id="@app.PatientId" class="btn btn-light btn-xs border rounded-pill px-3">File</a>
                                            </div>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }
            </div>
        </div>

        <!-- Pending Approvals (Requires Accept/Reject) -->
        <div class="card border-0 shadow-sm rounded-4 mb-4 bg-white">
            <div class="card-header bg-transparent border-0 px-4 pt-4">
                <h5 class="fw-bold text-dark mb-0"><i class="fa-solid fa-user-plus text-warning me-2"></i>Pending Approvals (Deposit Paid)</h5>
            </div>
            <div class="card-body px-4 pb-4">
                @if (pendingApprovals == null || !pendingApprovals.Any())
                {
                    <div class="text-center py-4 text-muted">
                        <i class="fa-solid fa-circle-check fs-3 mb-2 text-light"></i>
                        <p class="small mb-0">No pending appointment requests waiting for approval.</p>
                    </div>
                }
                else
                {
                    <div class="table-responsive">
                        <table class="table align-middle">
                            <thead>
                                <tr>
                                    <th>Patient</th>
                                    <th>Requested Date &amp; Time</th>
                                    <th>Deposit</th>
                                    <th class="text-end">Review Actions</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var app in pendingApprovals)
                                {
                                    <tr>
                                        <td>
                                            <span class="fw-bold text-dark d-block">@app.Patient?.User?.FullName</span>
                                            <span class="text-muted text-xs">Type: @app.Type</span>
                                        </td>
                                        <td>
                                            <span class="fw-bold text-dark d-block">@app.AppointmentDateTime.ToString("dd MMM yyyy")</span>
                                            <span class="text-muted text-xs">@app.AppointmentDateTime.ToString("hh:mm tt") (@app.Branch?.Name)</span>
                                        </td>
                                        <td>
                                            <span class="badge bg-light-success text-success px-2 py-1 rounded-pill"><i class="fa-solid fa-circle-check"></i> Paid ($@app.DepositAmount)</span>
                                        </td>
                                        <td class="text-end">
                                            <form asp-controller="Appointment" asp-action="Approve" asp-route-id="@app.Id" method="post" class="d-inline">
                                                <button type="submit" class="btn btn-success btn-sm rounded-pill px-3 fw-bold me-1">
                                                    <i class="fa-solid fa-check"></i> Accept
                                                </button>
                                            </form>
                                            <form asp-controller="Appointment" asp-action="Reject" asp-route-id="@app.Id" method="post" class="d-inline">
                                                <button type="submit" class="btn btn-danger btn-sm rounded-pill px-3 fw-bold">
                                                    <i class="fa-solid fa-xmark"></i> Reject
                                                </button>
                                            </form>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }
            </div>
        </div>

        <!-- Deposit Confirmations -->
        <div class="card border-0 shadow-sm rounded-4 bg-white mb-4">
            <div class="card-header bg-transparent border-0 px-4 pt-4">
                <h5 class="fw-bold text-dark mb-0"><i class="fa-solid fa-wallet text-success me-2"></i>My Deposit Payments Activity</h5>
            </div>
            <div class="card-body px-4 pb-4">
                @if (confirmedDeposits == null || !confirmedDeposits.Any())
                {
                    <p class="text-muted text-center py-3 text-sm mb-0">No deposit payments logged on your clinics cases.</p>
                }
                else
                {
                    <div class="table-responsive">
                        <table class="table align-middle table-sm">
                            <thead>
                                <tr>
                                    <th>Patient</th>
                                    <th>Appointment Date</th>
                                    <th>Deposit Amount</th>
                                    <th>Payment Time</th>
                                    <th>Status</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var app in confirmedDeposits)
                                {
                                    <tr>
                                        <td><span class="fw-bold text-dark">@app.Patient?.User?.FullName</span></td>
                                        <td><span class="text-muted text-xs">@app.AppointmentDateTime.ToString("dd MMM yyyy, hh:mm tt")</span></td>
                                        <td><span class="fw-bold text-dark">$@app.DepositAmount.ToString("F2")</span></td>
                                        <td><span class="text-muted text-xs">@(app.PaymentDate?.ToString("g") ?? "N/A")</span></td>
                                        <td><span class="badge bg-success rounded-pill px-2 py-1">Paid</span></td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }
            </div>
        </div>

        <!-- Patient History -->
        <div class="card border-0 shadow-sm rounded-4 bg-white">
            <div class="card-header bg-transparent border-0 px-4 pt-4">
                <h5 class="fw-bold text-dark mb-0"><i class="fa-solid fa-folder-open text-info me-2"></i>My Consultation Cases History</h5>
            </div>
            <div class="card-body px-4 pb-4">
                @if (patientHistory == null || !patientHistory.Any())
                {
                    <p class="text-muted text-center py-3 text-sm mb-0">No past clinical cases completed.</p>
                }
                else
                {
                    <div class="table-responsive">
                        <table class="table align-middle table-sm">
                            <thead>
                                <tr>
                                    <th>Patient</th>
                                    <th>Date Completed</th>
                                    <th>Clinic Notes</th>
                                    <th class="text-end">Actions</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var app in patientHistory)
                                {
                                    <tr>
                                        <td><span class="fw-bold text-dark">@app.Patient?.User?.FullName</span></td>
                                        <td><span class="text-muted text-xs">@app.AppointmentDateTime.ToString("dd MMM yyyy")</span></td>
                                        <td><span class="text-muted text-xs text-truncate d-block" style="max-width: 250px;">@(app.Notes ?? "No clinical notes.")</span></td>
                                        <td class="text-end">
                                            <a asp-controller="Patient" asp-action="Details" asp-route-id="@app.PatientId" class="btn btn-outline-info btn-xs rounded-pill"><i class="fa-solid fa-eye"></i> View File</a>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }
            </div>
        </div>

    </div>

    <!-- Right Column: Sidebar Alerts, Surgeries, Calendar -->
    <div class="col-lg-4">
        
        <!-- Alerts -->
        <div class="card border-0 shadow-sm rounded-4 mb-4 bg-white">
            <div class="card-header bg-transparent border-0 px-4 pt-4 d-flex justify-content-between align-items-center">
                <h5 class="fw-bold text-dark mb-0"><i class="fa-solid fa-bell text-warning me-2"></i>Clinical Alerts</h5>
                <span class="badge bg-light text-primary border small">Logs</span>
            </div>
            <div class="card-body px-4 pb-4" style="max-height: 280px; overflow-y: auto;">
                @{
                    var notifications = ViewBag.RecentNotifications as List<SmartEyeClinic.Models.Notification>;
                }
                @if (notifications == null || !notifications.Any())
                {
                    <div class="text-center py-4 text-muted">
                        <i class="fa-solid fa-bell-slash fs-4 mb-2"></i>
                        <p class="small mb-0">No alerts or notifications.</p>
                    </div>
                }
                else
                {
                    <div class="d-flex flex-column gap-2">
                        @foreach (var n in notifications)
                        {
                            <div class="p-3 rounded border-start border-3 border-primary bg-light" style="font-size: 0.8rem;">
                                <div class="d-flex justify-content-between align-items-center mb-1">
                                    <strong class="text-dark">@n.Title</strong>
                                    <span class="text-muted text-xs" style="font-size: 0.7rem;">@n.SentAt?.ToString("g")</span>
                                </div>
                                <div class="text-muted">@n.Message</div>
                            </div>
                        }
                    </div>
                }
            </div>
        </div>

        <!-- Surgery Schedule -->
        <div class="card border-0 shadow-sm rounded-4 mb-4 bg-white">
            <div class="card-header bg-transparent border-0 px-4 pt-4">
                <h5 class="fw-bold text-dark mb-0"><i class="fa-solid fa-laptop-medical text-danger me-2"></i>Upcoming Surgeries</h5>
            </div>
            <div class="card-body px-4 pb-4" style="max-height: 280px; overflow-y: auto;">
                @if (surgeries == null || !surgeries.Any())
                {
                    <div class="text-center py-4 text-muted">
                        <i class="fa-solid fa-heart-circle-check fs-3 mb-2 text-light"></i>
                        <p class="small mb-0">No operations scheduled.</p>
                    </div>
                }
                else
                {
                    <div class="d-flex flex-column gap-2">
                        @foreach (var s in surgeries)
                        {
                            <div class="p-3 rounded border bg-light-danger" style="background: rgba(239, 68, 68, 0.02);">
                                <div class="d-flex justify-content-between align-items-start mb-1">
                                    <span class="badge bg-danger text-white text-xs px-2 py-0.5 rounded-pill">@s.SurgeryType?.Name</span>
                                    <span class="text-xs text-muted">@s.SurgeryDate.ToString("dd MMM")</span>
                                </div>
                                <div class="fw-bold text-dark text-sm mb-1">@s.Patient?.User?.FullName</div>
                                <div class="text-xs text-muted"><i class="fa-solid fa-clock"></i> @s.SurgeryDate.ToString("hh:mm tt")</div>
                            </div>
                        }
                    </div>
                }
            </div>
        </div>

        <!-- Planner link -->
        <div class="card border-0 shadow-sm rounded-4 overflow-hidden bg-white">
            <div class="p-4 text-white" style="background: linear-gradient(135deg, var(--primary) 0%, var(--primary-dark) 100%);">
                <div class="d-flex align-items-center justify-content-between mb-3">
                    <h6 class="fw-bold mb-0">My Clinical Planner</h6>
                    <i class="fa-solid fa-calendar-week fs-4"></i>
                </div>
                <p class="text-xs mb-3 text-white-50">View all clinical appointments, surgery blocks, and manage schedules dynamically.</p>
                <a asp-controller="Home" asp-action="Calendar" class="btn btn-sm w-100 fw-bold bg-white text-primary border-0 rounded-pill py-2">
                    Open Planner
                </a>
            </div>
        </div>

    </div>
</div>
