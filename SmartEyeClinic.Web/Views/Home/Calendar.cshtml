@inject SmartEyeClinic.Data.AppDbContext DbContext
@using Microsoft.EntityFrameworkCore
@{
    ViewData["Title"] = "Clinical Calendar - Smart Eye Clinic";

    // Load appointments for calendar view
    var appointments = DbContext.Appointments
        .Include(a => a.Patient).ThenInclude(p => p.User)
        .Include(a => a.Doctor).ThenInclude(d => d.User)
        .Include(a => a.Branch)
        .OrderBy(a => a.AppointmentDateTime)
        .ToList();
}

<!-- Page Header -->
<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <ul class="breadcrumb-custom mb-1">
            <li><a asp-controller="Home" asp-action="Index">Home</a></li>
            <li>Schedule Calendar</li>
        </ul>
        <h3 class="fw-bold text-dark mb-0">Clinical Calendar Schedule</h3>
    </div>
    <a asp-controller="Appointment" asp-action="Create" class="btn btn-custom btn-custom-primary">
        <i class="fa-solid fa-calendar-plus"></i> Schedule Appointment
    </a>
</div>

<div class="row g-4">
    <!-- Left Column: Appointment List Panel -->
    <div class="col-lg-4">
        <div class="card custom-card">
            <div class="card-header-clean">
                <h6 class="mb-0 fw-bold"><i class="fa-solid fa-clipboard-list text-primary me-2"></i>Consultations Quick List</h6>
            </div>
            <div class="card-body-clean" style="max-height: 600px; overflow-y: auto;">
                @if (!appointments.Any())
                {
                    <div class="text-center py-5">
                        <i class="fa-regular fa-calendar-times text-muted fs-2 mb-2 d-block"></i>
                        <span class="text-muted small">No scheduled visits.</span>
                    </div>
                }
                else
                {
                    <div class="d-flex flex-column gap-3">
                        @foreach (var app in appointments)
                        {
                            <div class="p-3 border rounded shadow-sm hover-shadow cursor-pointer bg-light-subtle" onclick="focusAppointment('@app.Id')">
                                <div class="d-flex justify-content-between align-items-center mb-2">
                                    <span class="badge-custom badge-custom-success">@app.Status</span>
                                    <span class="text-muted font-monospace small">#@app.Id</span>
                                </div>
                                <h6 class="fw-bold text-dark mb-1">@app.Patient?.User?.FullName</h6>
                                <p class="text-muted small mb-2"><i class="fa-solid fa-user-md text-info me-1"></i>Dr. @app.Doctor?.User?.FullName</p>
                                <div class="d-flex justify-content-between text-muted small border-top pt-2">
                                    <span><i class="fa-regular fa-calendar me-1"></i>@app.AppointmentDateTime.ToString("dd MMM yyyy")</span>
                                    <span><i class="fa-regular fa-clock me-1"></i>@app.AppointmentDateTime.ToString("hh:mm tt")</span>
                                </div>
                            </div>
                        }
                    </div>
                }
            </div>
        </div>
    </div>

    <!-- Right Column: Interactive Monthly CSS Grid Calendar -->
    <div class="col-lg-8">
        <div class="card custom-card">
            <div class="card-header-clean d-flex justify-content-between align-items-center">
                <h5 class="mb-0"><i class="fa-solid fa-calendar-days text-primary me-2"></i>Clinical Planner</h5>
                <div class="d-flex gap-2">
                    <button class="btn btn-sm btn-outline-secondary" onclick="alert('Previous month clicked!')"><i class="fa-solid fa-chevron-left"></i></button>
                    <span class="fw-bold text-dark my-auto px-2">@DateTime.Today.ToString("MMMM yyyy")</span>
                    <button class="btn btn-sm btn-outline-secondary" onclick="alert('Next month clicked!')"><i class="fa-solid fa-chevron-right"></i></button>
                </div>
            </div>
            <div class="card-body-clean">
                <!-- Days Header -->
                <div class="row text-center fw-bold text-muted mb-2 g-1" style="font-size: 0.85rem;">
                    <div class="col">Sun</div>
                    <div class="col">Mon</div>
                    <div class="col">Tue</div>
                    <div class="col">Wed</div>
                    <div class="col">Thu</div>
                    <div class="col">Fri</div>
                    <div class="col">Sat</div>
                </div>

                <!-- Calendar Grid Logic -->
                <div class="row g-1 text-center" style="min-height: 450px;">
                    @{
                        // Simple calendar generator matching heliotherapy days
                        var startOfMonth = new DateTime(DateTime.Today.Year, DateTime.Today.Month, 1);
                        var startDay = (int)startOfMonth.DayOfWeek;
                        var totalDays = DateTime.DaysInMonth(DateTime.Today.Year, DateTime.Today.Month);
                        
                        // Output empty spots for padding
                        for (int i = 0; i < startDay; i++)
                        {
                            <div class="col border rounded p-2 bg-light opacity-50" style="min-height: 90px;"></div>
                        }

                        // Output actual days of the month
                        for (int day = 1; day <= totalDays; day++)
                        {
                            var currentDay = new DateTime(DateTime.Today.Year, DateTime.Today.Month, day);
                            var dayApps = appointments.Where(a => a.AppointmentDateTime.Date == currentDay.Date).ToList();
                            var isToday = currentDay.Date == DateTime.Today.Date;

                            <div class="col border rounded p-2 text-start position-relative d-flex flex-column justify-content-between @(isToday ? "border-primary bg-primary-subtle" : "bg-white")" style="min-height: 90px; width: 14%; flex-grow: 0; flex-shrink: 0;">
                                <div class="d-flex justify-content-between align-items-center">
                                    <span class="fw-bold @(isToday ? "text-primary fs-5" : "text-dark")">@day</span>
                                    @if (dayApps.Any())
                                    {
                                        <span class="badge bg-primary rounded-circle" style="font-size: 0.72rem; width: 18px; height: 18px; line-height: 18px; text-align: center; padding: 0;">@dayApps.Count</span>
                                    }
                                </div>
                                <div class="mt-1" style="overflow: hidden; max-height: 50px;">
                                    @foreach (var app in dayApps.Take(2))
                                    {
                                        <div class="badge bg-secondary-subtle text-primary border border-primary-subtle text-truncate w-100 p-1 mb-1 font-size-xs" style="font-size: 0.68rem; cursor: pointer;" title="Patient: @app.Patient?.User?.FullName" onclick="focusAppointment('@app.Id')">
                                            @app.Patient?.User?.FullName
                                        </div>
                                    }
                                    @if (dayApps.Count > 2)
                                    {
                                        <span class="text-muted small" style="font-size: 0.65rem;">+@(dayApps.Count - 2) more</span>
                                    }
                                </div>
                            </div>
                        }
                    }
                </div>
            </div>
        </div>
    </div>
</div>

<script>
    function focusAppointment(id) {
        alert("Selected consultation schedule item ID #" + id);
    }
</script>
