@{
    ViewData["Title"] = "Receptionist Dashboard - Smart Eye Clinic";
    var queue = ViewBag.ActiveQueue as List<SmartEyeClinic.Models.Queue>;
    var appointments = ViewBag.TodayAppointments as List<SmartEyeClinic.Models.Appointment>;
}

<div class="container-fluid py-4">
    <!-- Header -->
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h3 class="fw-bold text-dark mb-1">Front Desk Operations</h3>
            <p class="text-muted small mb-0">Clinic receptionist panel for managing patient check-ins and queue tokens.</p>
        </div>
        <div class="d-flex gap-2">
            <a asp-controller="Patient" asp-action="Create" class="btn btn-primary btn-sm px-3 py-2 border-0" style="background: var(--primary-color); border-radius: 8px;">
                <i class="fa-solid fa-user-plus me-1"></i> Register Patient
            </a>
            <a asp-controller="Appointment" asp-action="Create" class="btn btn-success btn-sm px-3 py-2 border-0" style="background: var(--success-color); border-radius: 8px;">
                <i class="fa-solid fa-calendar-plus me-1"></i> Book Appointment
            </a>
        </div>
    </div>

    <!-- Stats row -->
    <div class="row g-4 mb-4">
        <div class="col-md-4">
            <div class="card border-0 shadow-sm p-3 d-flex flex-row align-items-center justify-content-between" style="background: var(--card-bg); border-radius: 12px;">
                <div>
                    <span class="text-muted small d-block">Today's Total Queue</span>
                    <strong class="fs-4 text-dark">@ViewBag.QueueTotal</strong>
                </div>
                <div class="p-3 rounded-circle bg-light-primary text-primary"><i class="fa-solid fa-users fs-4"></i></div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card border-0 shadow-sm p-3 d-flex flex-row align-items-center justify-content-between" style="background: var(--card-bg); border-radius: 12px;">
                <div>
                    <span class="text-muted small d-block">Waiting Patients</span>
                    <strong class="fs-4 text-warning">@ViewBag.QueueWaiting</strong>
                </div>
                <div class="p-3 rounded-circle bg-light-warning text-warning"><i class="fa-solid fa-user-clock fs-4"></i></div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card border-0 shadow-sm p-3 d-flex flex-row align-items-center justify-content-between" style="background: var(--card-bg); border-radius: 12px;">
                <div>
                    <span class="text-muted small d-block">Unpaid Invoices</span>
                    <strong class="fs-4 text-danger">@ViewBag.UnpaidInvoices</strong>
                </div>
                <div class="p-3 rounded-circle bg-light-danger text-danger"><i class="fa-solid fa-file-invoice-dollar fs-4"></i></div>
            </div>
        </div>
    </div>

    <div class="row g-4">
        <!-- Waiting list queue -->
        <div class="col-lg-7">
            <div class="card border-0 shadow-sm rounded-4 h-100" style="background: var(--card-bg);">
                <div class="card-header-clean">
                    <h5 class="mb-0"><i class="fa-solid fa-list-ol text-primary me-2"></i>Active Clinic Queue</h5>
                </div>
                <div class="card-body p-4">
                    @if (queue == null || !queue.Any())
                    {
                        <div class="text-center py-5">
                            <i class="fa-solid fa-ticket fs-1 text-muted mb-3 d-block"></i>
                            <h6 class="text-muted fw-normal">The clinic queue is currently empty.</h6>
                            <p class="text-muted small">Check in patients from today's appointments list.</p>
                        </div>
                    }
                    else
                    {
                        <div class="table-responsive-custom">
                            <table class="table custom-table small">
                                <thead>
                                    <tr>
                                        <th>Token</th>
                                        <th>Patient</th>
                                        <th>Target Doctor</th>
                                        <th>Status</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var item in queue)
                                    {
                                        <tr>
                                            <td><span class="badge bg-dark rounded px-2.5 py-1.5 fw-bold">#@item.QueueNumber</span></td>
                                            <td><strong>@item.Appointment.Patient.User.FullName</strong></td>
                                            <td>Dr. @item.Appointment.Doctor.User.FullName</td>
                                            <td>
                                                @if (item.Status == "Waiting")
                                                {
                                                    <span class="badge-custom badge-custom-warning">Waiting</span>
                                                }
                                                else
                                                {
                                                    <span class="badge-custom badge-custom-success">@item.Status</span>
                                                }
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    }
                </div>
            </div>
        </div>

        <!-- Today's check-ins -->
        <div class="col-lg-5">
            <div class="card border-0 shadow-sm rounded-4 h-100" style="background: var(--card-bg);">
                <div class="card-header-clean">
                    <h5 class="mb-0"><i class="fa-solid fa-calendar-check text-success me-2"></i>Today's Bookings</h5>
                </div>
                <div class="card-body p-4">
                    @if (appointments == null || !appointments.Any())
                    {
                        <div class="text-center py-4 text-muted">
                            No appointments logged for today.
                        </div>
                    }
                    else
                    {
                        <div class="list-group list-group-flush">
                            @foreach (var app in appointments)
                            {
                                <div class="list-group-item px-0 border-0 mb-3 bg-light p-3 rounded-3 hover-shadow transition-all">
                                    <div class="d-flex justify-content-between align-items-start mb-2">
                                        <strong>@app.Patient.User.FullName</strong>
                                        <span class="text-muted small">@app.AppointmentDateTime.ToString("hh:mm tt")</span>
                                    </div>
                                    <div class="small text-muted mb-2">
                                        <i class="fa-solid fa-user-doctor me-1"></i> Doctor: Dr. @app.Doctor.User.FullName
                                    </div>
                                    <div class="d-flex justify-content-between align-items-center">
                                        <span class="badge bg-light text-dark border">@app.Status</span>
                                        <a asp-controller="Appointment" asp-action="Details" asp-route-id="@app.Id" class="btn btn-outline-primary btn-sm border-0 py-1" style="font-size: 0.78rem;">
                                            Check-In / Details
                                        </a>
                                    </div>
                                </div>
                            }
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>
</div>
