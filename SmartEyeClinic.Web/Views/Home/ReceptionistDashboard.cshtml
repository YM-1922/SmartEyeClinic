@{
    ViewData["Title"] = "Receptionist Dashboard";
    var queue        = ViewBag.ActiveQueue       as List<SmartEyeClinic.Models.Queue>;
    var appointments = ViewBag.TodayAppointments as List<SmartEyeClinic.Models.Appointment>;
}

<!-- Page Header -->
<div class="page-header">
    <div class="page-header-left">
        <div class="breadcrumb-nav">
            <a href="/"><i class="bi bi-house-door"></i> Home</a>
            <span class="separator">/</span>
            <span class="current">Receptionist Dashboard</span>
        </div>
        <h1 class="page-title"><i class="bi bi-person-lines-fill text-secondary-custom me-2"></i>Front Desk Operations</h1>
        <p class="page-subtitle">Real-time patient queue, check-in management, and today's booking schedule.</p>
    </div>
    <div class="d-flex gap-2 flex-wrap">
        <a asp-controller="Patient"     asp-action="Create" class="btn btn-outline-primary btn-sm">
            <i class="bi bi-person-plus"></i> Register Patient
        </a>
        <a asp-controller="Appointment" asp-action="Create" class="btn btn-primary btn-sm">
            <i class="bi bi-calendar-plus"></i> Book Appointment
        </a>
    </div>
</div>

<!-- KPI Stats -->
<div class="row g-4 mb-4">
    <div class="col-md-4">
        <div class="metric-card metric-gradient-primary">
            <div class="metric-label">Today's Queue Total</div>
            <div class="metric-value">@ViewBag.QueueTotal</div>
            <div class="metric-sub"><i class="bi bi-people"></i> Patients checked in</div>
            <div class="metric-icon"><i class="bi bi-people"></i></div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="metric-card metric-gradient-warning">
            <div class="metric-label">Waiting Patients</div>
            <div class="metric-value">@ViewBag.QueueWaiting</div>
            <div class="metric-sub"><i class="bi bi-hourglass-split"></i> In the queue</div>
            <div class="metric-icon"><i class="bi bi-person-waiting"></i></div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="metric-card metric-gradient-danger">
            <div class="metric-label">Unpaid Invoices</div>
            <div class="metric-value">@ViewBag.UnpaidInvoices</div>
            <div class="metric-sub"><i class="bi bi-receipt"></i> Pending settlement</div>
            <div class="metric-icon"><i class="bi bi-file-earmark-text"></i></div>
        </div>
    </div>
</div>

<!-- Main Content -->
<div class="row g-4">
    <!-- Active Queue -->
    <div class="col-lg-7">
        <div class="table-card h-100">
            <div class="table-card-header">
                <h5 class="table-title"><i class="bi bi-list-ol"></i> Active Clinic Queue</h5>
                <span class="badge-status badge-success">Live</span>
            </div>
            @if (queue == null || !queue.Any())
            {
                <div class="empty-state">
                    <div class="empty-state-icon"><i class="bi bi-ticket-perforated"></i></div>
                    <h5>Queue Is Empty</h5>
                    <p>No patients are currently checked in. Check-in patients from today's appointments below.</p>
                    <a asp-controller="Appointment" asp-action="Index" class="btn btn-primary btn-sm">
                        <i class="bi bi-calendar2-week"></i> View Appointments
                    </a>
                </div>
            }
            else
            {
                <div class="table-responsive-custom">
                    <table class="custom-table">
                        <thead>
                            <tr>
                                <th>Token</th>
                                <th>Patient</th>
                                <th>Doctor</th>
                                <th>Check-In</th>
                                <th>Status</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var item in queue)
                            {
                                <tr>
                                    <td>
                                        <span class="fw-800 px-3 py-1 rounded-2 text-white text-sm"
                                              style="background: linear-gradient(135deg,var(--primary),var(--secondary));">
                                            #@item.QueueNumber
                                        </span>
                                    </td>
                                    <td>
                                        <div class="d-flex align-items-center gap-2">
                                            <div class="avatar-initials avatar-sm">
                                                @(item.Appointment?.Patient?.User?.FullName?.Length > 0 ? item.Appointment.Patient.User.FullName[0].ToString().ToUpper() : "P")
                                            </div>
                                            <span class="fw-600">@item.Appointment?.Patient?.User?.FullName</span>
                                        </div>
                                    </td>
                                    <td>Dr. @item.Appointment?.Doctor?.User?.FullName</td>
                                    <td class="text-sm text-muted">@item.CheckInTime?.ToString("hh:mm tt")</td>
                                    <td>
                                        @{
                                            var qBadge = item.Status switch {
                                                "Waiting"   => "badge-warning",
                                                "InProgress"=> "badge-info",
                                                "Completed" => "badge-success",
                                                _           => "badge-neutral"
                                            };
                                        }
                                        <span class="badge-status @qBadge">@item.Status</span>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
        </div>
    </div>

    <!-- Today's Appointments -->
    <div class="col-lg-5 d-flex flex-column gap-4">
        <div class="table-card">
            <div class="table-card-header">
                <h5 class="table-title"><i class="bi bi-calendar-check"></i> Today's Bookings</h5>
                <a asp-controller="Appointment" asp-action="Index" class="btn btn-light btn-sm">View All</a>
            </div>
            <div class="card-body-clean" style="max-height: 380px; overflow-y: auto; padding: 15px;">
                @if (appointments == null || !appointments.Any())
                {
                    <div class="empty-state" style="padding:40px 20px;">
                        <div class="empty-state-icon"><i class="bi bi-calendar-x"></i></div>
                        <h5>No Appointments Today</h5>
                        <p>No appointments have been scheduled for today.</p>
                    </div>
                }
                else
                {
                    <div class="d-flex flex-column gap-2">
                        @foreach (var app in appointments)
                        {
                            var appBadge = app.Status switch {
                                "Confirmed" => "badge-success",
                                "Pending"   => "badge-warning",
                                "Cancelled" => "badge-danger",
                                "Completed" => "badge-secondary",
                                _           => "badge-neutral"
                            };
                            <div class="p-3 rounded-3 border hover-shadow transition-all bg-white">
                                <div class="d-flex justify-content-between align-items-start mb-2">
                                    <div class="d-flex align-items-center gap-2">
                                        <div class="avatar-initials avatar-sm">
                                            @(app.Patient?.User?.FullName?.Length > 0 ? app.Patient.User.FullName[0].ToString().ToUpper() : "P")
                                        </div>
                                        <div>
                                            <div class="fw-600 text-sm">@app.Patient?.User?.FullName</div>
                                            <div class="text-xs text-muted font-monospace" style="font-size: 0.72rem;">Dr. @app.Doctor?.User?.FullName</div>
                                        </div>
                                    </div>
                                    <span class="text-xs text-muted fw-600">@app.AppointmentDateTime.ToString("hh:mm tt")</span>
                                </div>
                                <div class="d-flex justify-content-between align-items-center">
                                    <span class="badge-status @appBadge">@app.Status</span>
                                    <div class="d-flex gap-1">
                                        @if (app.Status == "Pending")
                                        {
                                            <form asp-controller="Appointment" asp-action="Approve" asp-route-id="@app.Id" method="post" class="d-inline">
                                                @Html.AntiForgeryToken()
                                                <button type="submit" class="btn btn-success btn-xs py-1 px-2 text-xs" style="font-size: 0.72rem;" title="Confirm Appointment">
                                                    <i class="bi bi-check-lg"></i> Approve
                                                </button>
                                            </form>
                                            <form asp-controller="Appointment" asp-action="Cancel" asp-route-id="@app.Id" method="post" class="d-inline">
                                                @Html.AntiForgeryToken()
                                                <button type="submit" class="btn btn-outline-danger btn-xs py-1 px-2 text-xs" style="font-size: 0.72rem;" title="Cancel Appointment">
                                                    <i class="bi bi-x-lg"></i>
                                                </button>
                                            </form>
                                        }
                                        <a asp-controller="Appointment" asp-action="Details" asp-route-id="@app.Id"
                                           class="btn btn-outline-primary btn-xs py-1 px-2 text-xs" style="font-size: 0.72rem;">
                                            <i class="bi bi-eye"></i> Details
                                        </a>
                                    </div>
                                </div>
                            </div>
                        }
                    </div>
                }
            </div>
        </div>

        <!-- Receptionist Alerts -->
        <div class="table-card">
            <div class="table-card-header">
                <h5 class="table-title"><i class="bi bi-bell-fill text-warning"></i> Front Desk Alerts</h5>
                <span class="badge bg-light text-primary border small font-size-xs">Logs</span>
            </div>
            <div class="card-body-clean" style="max-height: 250px; overflow-y: auto; padding: 15px;">
                @{
                    var notifications = ViewBag.RecentNotifications as List<SmartEyeClinic.Models.Notification>;
                }
                @if (notifications == null || !notifications.Any())
                {
                    <div class="text-center py-4">
                        <i class="bi bi-bell-slash text-muted fs-4"></i>
                        <p class="small text-muted mb-0 mt-2">No front desk alerts.</p>
                    </div>
                }
                else
                {
                    <div class="d-flex flex-column gap-2">
                        @foreach (var n in notifications)
                        {
                            var hasBeenRead = n.IsRead ?? false;
                            <div class="p-2 rounded-3" style="font-size: 0.82rem; background: var(--bg); border-left: 3.5px solid @(hasBeenRead ? "var(--text-light)" : "var(--primary)");">
                                <div class="d-flex justify-content-between align-items-center mb-1">
                                    <strong class="text-dark">@n.Title</strong>
                                    <span class="text-muted" style="font-size: 0.72rem;">@n.SentAt?.ToString("g")</span>
                                </div>
                                <div class="text-muted text-xs">@n.Message</div>
                            </div>
                        }
                    </div>
                }
            </div>
        </div>
    </div>
</div>
