@inject SmartEyeClinic.Data.AppDbContext DbContext
@using Microsoft.EntityFrameworkCore
@{
    ViewData["Title"] = "Dashboard - Smart Eye Clinic";

    // Dynamic stats from real database
    var totalPatients = DbContext.Patients.Count();
    var totalDoctors = DbContext.Doctors.Count();
    var totalAppointments = DbContext.Appointments.Count();
    var totalRevenue = DbContext.Payments.Sum(p => (decimal?)p.Amount) ?? 0;
    var totalSurgeries = DbContext.Surgeries.Count();
    var today = DateTime.Today;
    var todayVisits = DbContext.Appointments.Count(a => a.AppointmentDateTime.Date == today);
    var pendingPayments = DbContext.Invoices.Count(i => i.Status != "Paid");

    // Retrieve recent appointments with patient and doctor details
    var upcomingAppointments = DbContext.Appointments
        .Include(a => a.Patient).ThenInclude(p => p.User)
        .Include(a => a.Doctor).ThenInclude(d => d.User)
        .OrderByDescending(a => a.AppointmentDateTime)
        .Take(5)
        .ToList();
}

<!-- Page Header -->
<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h3 class="fw-bold text-dark mb-1">Clinic Dashboard</h3>
        <p class="text-muted small mb-0">Welcome back, Dr. Alexander. Here's what's happening today.</p>
    </div>
    <div class="d-flex gap-2">
        <a asp-controller="Appointment" asp-action="Create" class="btn btn-custom btn-custom-primary">
            <i class="fa-solid fa-calendar-plus"></i> Book Appointment
        </a>
        <a asp-controller="Patient" asp-action="Create" class="btn btn-custom btn-custom-success">
            <i class="fa-solid fa-user-plus"></i> Register Patient
        </a>
    </div>
</div>

<!-- Stats Row 1 -->
<div class="row g-4 mb-4">
    <!-- Total Patients -->
    <div class="col-xl-3 col-md-6">
        <div class="card metric-card metric-gradient-primary h-100 shadow-sm">
            <div class="card-body">
                <div class="text-uppercase text-white-50 small fw-bold mb-1">Total Patients</div>
                <div class="fs-2 fw-bold text-white mb-2">@totalPatients</div>
                <div class="small text-white-50"><i class="fa-solid fa-arrow-trend-up"></i> Active clinical cases</div>
            </div>
            <div class="icon-wrapper">
                <i class="fa-solid fa-hospital-user"></i>
            </div>
        </div>
    </div>

    <!-- Doctors -->
    <div class="col-xl-3 col-md-6">
        <div class="card metric-card metric-gradient-secondary h-100 shadow-sm">
            <div class="card-body">
                <div class="text-uppercase text-white-50 small fw-bold mb-1">Active Doctors</div>
                <div class="fs-2 fw-bold text-white mb-2">@totalDoctors</div>
                <div class="small text-white-50"><i class="fa-solid fa-user-doctor"></i> Qualified specialists</div>
            </div>
            <div class="icon-wrapper">
                <i class="fa-solid fa-user-md"></i>
            </div>
        </div>
    </div>

    <!-- Appointments -->
    <div class="col-xl-3 col-md-6">
        <div class="card metric-card metric-gradient-accent h-100 shadow-sm">
            <div class="card-body">
                <div class="text-uppercase text-white-50 small fw-bold mb-1">Appointments</div>
                <div class="fs-2 fw-bold text-white mb-2">@totalAppointments</div>
                <div class="small text-white-50"><i class="fa-solid fa-clock"></i> Booked consultations</div>
            </div>
            <div class="icon-wrapper">
                <i class="fa-solid fa-calendar-check"></i>
            </div>
        </div>
    </div>

    <!-- Revenue -->
    <div class="col-xl-3 col-md-6">
        <div class="card metric-card metric-gradient-success h-100 shadow-sm">
            <div class="card-body">
                <div class="text-uppercase text-white-50 small fw-bold mb-1">Total Revenue</div>
                <div class="fs-2 fw-bold text-white mb-2">$@totalRevenue.ToString("N2")</div>
                <div class="small text-white-50"><i class="fa-solid fa-wallet"></i> Clinic net earnings</div>
            </div>
            <div class="icon-wrapper">
                <i class="fa-solid fa-dollar-sign"></i>
            </div>
        </div>
    </div>
</div>

<!-- Stats Row 2 -->
<div class="row g-4 mb-4">
    <!-- Today Visits -->
    <div class="col-md-4">
        <div class="card metric-card metric-gradient-warning h-100 shadow-sm">
            <div class="card-body">
                <div class="text-uppercase text-white-50 small fw-bold mb-1">Today's Visits</div>
                <div class="fs-2 fw-bold text-white mb-2">@todayVisits</div>
                <div class="small text-white-50"><i class="fa-solid fa-calendar-day"></i> Scheduled for today</div>
            </div>
            <div class="icon-wrapper">
                <i class="fa-solid fa-user-clock"></i>
            </div>
        </div>
    </div>

    <!-- Surgeries -->
    <div class="col-md-4">
        <div class="card metric-card metric-gradient-danger h-100 shadow-sm">
            <div class="card-body">
                <div class="text-uppercase text-white-50 small fw-bold mb-1">Surgeries Scheduled</div>
                <div class="fs-2 fw-bold text-white mb-2">@totalSurgeries</div>
                <div class="small text-white-50"><i class="fa-solid fa-bed-pulse"></i> Operating theater queue</div>
            </div>
            <div class="icon-wrapper">
                <i class="fa-solid fa-syringe"></i>
            </div>
        </div>
    </div>

    <!-- Pending Invoices -->
    <div class="col-md-4">
        <div class="card metric-card metric-gradient-primary h-100 shadow-sm" style="background: linear-gradient(135deg, #475569 0%, #334155 100%);">
            <div class="card-body">
                <div class="text-uppercase text-white-50 small fw-bold mb-1">Unpaid Invoices</div>
                <div class="fs-2 fw-bold text-white mb-2">@pendingPayments</div>
                <div class="small text-white-50"><i class="fa-solid fa-file-invoice"></i> Pending accounting settlement</div>
            </div>
            <div class="icon-wrapper">
                <i class="fa-solid fa-file-invoice-dollar"></i>
            </div>
        </div>
    </div>
</div>

<!-- Main Panels -->
<div class="row g-4">
    <!-- Upcoming Appointments Table -->
    <div class="col-lg-8">
        <div class="card custom-card h-100">
            <div class="card-header-clean">
                <div class="d-flex align-items-center">
                    <i class="fa-solid fa-calendar-check text-primary me-2 fs-5"></i>
                    <h5 class="mb-0">Recent Scheduled Consultations</h5>
                </div>
                <a asp-controller="Appointment" asp-action="Index" class="btn btn-sm btn-link text-decoration-none fw-600">View All</a>
            </div>
            <div class="card-body-clean">
                @if (upcomingAppointments == null || !upcomingAppointments.Any())
                {
                    <div class="text-center py-5">
                        <i class="fa-regular fa-calendar text-muted fs-1 mb-3 d-block"></i>
                        <h6 class="text-muted fw-normal">No upcoming appointments found.</h6>
                        <a asp-controller="Appointment" asp-action="Create" class="btn btn-sm btn-custom btn-custom-primary mt-2">Book Now</a>
                    </div>
                }
                else
                {
                    <div class="table-responsive-custom">
                        <table class="table custom-table">
                            <thead>
                                <tr>
                                    <th>Patient</th>
                                    <th>Doctor</th>
                                    <th>Date & Time</th>
                                    <th>Status</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var appointment in upcomingAppointments)
                                {
                                    <tr>
                                        <td>
                                            <div class="d-flex align-items-center">
                                                <div class="avatar-circle me-2 bg-light-primary text-primary fw-bold text-center" style="width: 32px; height: 32px; border-radius: 50%; line-height: 32px; font-size: 0.85rem;">
                                                    @(appointment.Patient?.User?.FullName?.Length > 0 ? appointment.Patient.User.FullName[0].ToString().ToUpper() : "P")
                                                </div>
                                                <div>
                                                    <a asp-controller="Patient" asp-action="Details" asp-route-id="@appointment.PatientId" class="fw-bold d-block text-dark text-decoration-none" onmouseover="this.style.color='#0F4C81'" onmouseout="this.style.color=''">@appointment.Patient?.User?.FullName</a>
                                                    <span class="text-muted small">ID: #@appointment.PatientId</span>
                                                </div>
                                            </div>
                                        </td>
                                        <td>
                                            <span class="text-dark fw-500">Dr. @appointment.Doctor?.User?.FullName</span>
                                        </td>
                                        <td>
                                            <div class="d-flex flex-column">
                                                <span class="text-dark">@appointment.AppointmentDateTime.ToString("dd MMM yyyy")</span>
                                                <span class="text-muted small">@appointment.AppointmentDateTime.ToString("hh:mm tt")</span>
                                            </div>
                                        </td>
                                        <td>
                                            @if (appointment.Status == "Completed")
                                            {
                                                <span class="badge-custom badge-custom-success">Completed</span>
                                            }
                                            else if (appointment.Status == "Pending")
                                            {
                                                <span class="badge-custom badge-custom-warning">Pending</span>
                                            }
                                            else
                                            {
                                                <span class="badge-custom badge-custom-danger">@appointment.Status</span>
                                            }
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }
            </div>
        </div>
    </div>

    <!-- Quick Shortcuts Panel -->
    <div class="col-lg-4">
        <div class="card custom-card h-100">
            <div class="card-header-clean">
                <div class="d-flex align-items-center">
                    <i class="fa-solid fa-list-check text-primary me-2 fs-5"></i>
                    <h5 class="mb-0">Quick Modules</h5>
                </div>
            </div>
            <div class="card-body-clean">
                <div class="d-flex flex-column gap-3">
                    <a asp-controller="Patient" asp-action="Index" class="btn btn-light d-flex align-items-center justify-content-between p-3 border rounded text-decoration-none hover-shadow transition-all">
                        <div class="d-flex align-items-center">
                            <div class="p-2 bg-primary text-white rounded me-3" style="width: 40px; height: 40px; display: flex; align-items: center; justify-content: center;">
                                <i class="fa-solid fa-user-injured"></i>
                            </div>
                            <div class="text-start">
                                <span class="fw-bold text-dark d-block">Patients Directory</span>
                                <span class="text-muted small">Manage clinic patients list</span>
                            </div>
                        </div>
                        <i class="fa-solid fa-chevron-right text-muted"></i>
                    </a>

                    <a asp-controller="Doctor" asp-action="Index" class="btn btn-light d-flex align-items-center justify-content-between p-3 border rounded text-decoration-none hover-shadow transition-all">
                        <div class="d-flex align-items-center">
                            <div class="p-2 bg-success text-white rounded me-3" style="width: 40px; height: 40px; display: flex; align-items: center; justify-content: center;">
                                <i class="fa-solid fa-user-md"></i>
                            </div>
                            <div class="text-start">
                                <span class="fw-bold text-dark d-block">Specialist Staff</span>
                                <span class="text-muted small">Add and review active doctors</span>
                            </div>
                        </div>
                        <i class="fa-solid fa-chevron-right text-muted"></i>
                    </a>

                    <a asp-controller="Home" asp-action="PatientPortal" class="btn btn-light d-flex align-items-center justify-content-between p-3 border rounded text-decoration-none hover-shadow transition-all">
                        <div class="d-flex align-items-center">
                            <div class="p-2 text-white rounded me-3" style="width: 40px; height: 40px; display: flex; align-items: center; justify-content: center; background: #00B4D8;">
                                <i class="fa-solid fa-hospital-user"></i>
                            </div>
                            <div class="text-start">
                                <span class="fw-bold text-dark d-block">Patient Portal</span>
                                <span class="text-muted small">Self-service patient dashboard</span>
                            </div>
                        </div>
                        <i class="fa-solid fa-chevron-right text-muted"></i>
                    </a>

                    <a asp-controller="Home" asp-action="Calendar" class="btn btn-light d-flex align-items-center justify-content-between p-3 border rounded text-decoration-none hover-shadow transition-all">
                        <div class="d-flex align-items-center">
                            <div class="p-2 text-white rounded me-3" style="width: 40px; height: 40px; display: flex; align-items: center; justify-content: center; background: #8B5CF6;">
                                <i class="fa-solid fa-calendar-days"></i>
                            </div>
                            <div class="text-start">
                                <span class="fw-bold text-dark d-block">Clinical Calendar</span>
                                <span class="text-muted small">Visual schedule planner</span>
                            </div>
                        </div>
                        <i class="fa-solid fa-chevron-right text-muted"></i>
                    </a>

                    <a asp-controller="Invoice" asp-action="Index" class="btn btn-light d-flex align-items-center justify-content-between p-3 border rounded text-decoration-none hover-shadow transition-all">
                        <div class="d-flex align-items-center">
                            <div class="p-2 bg-info text-white rounded me-3" style="width: 40px; height: 40px; display: flex; align-items: center; justify-content: center;">
                                <i class="fa-solid fa-file-invoice-dollar"></i>
                            </div>
                            <div class="text-start">
                                <span class="fw-bold text-dark d-block">Billing & Invoices</span>
                                <span class="text-muted small">Manage patient invoices</span>
                            </div>
                        </div>
                        <i class="fa-solid fa-chevron-right text-muted"></i>
                    </a>

                    <a asp-controller="Medicine" asp-action="Index" class="btn btn-light d-flex align-items-center justify-content-between p-3 border rounded text-decoration-none hover-shadow transition-all">
                        <div class="d-flex align-items-center">
                            <div class="p-2 bg-warning text-white rounded me-3" style="width: 40px; height: 40px; display: flex; align-items: center; justify-content: center;">
                                <i class="fa-solid fa-pills"></i>
                            </div>
                            <div class="text-start">
                                <span class="fw-bold text-dark d-block">Pharmacy Catalog</span>
                                <span class="text-muted small">Medicines stock & database</span>
                            </div>
                        </div>
                        <i class="fa-solid fa-chevron-right text-muted"></i>
                    </a>
                </div>
            </div>
        </div>
    </div>
</div>
