@{
    Layout = "_LandingLayout";
    ViewData["Title"] = "About Us — Premium Eye Care";
}

<!-- Header banner -->
<section class="py-5 bg-light-primary text-center" style="background: linear-gradient(135deg, rgba(14,165,233,0.05) 0%, rgba(6,182,212,0.05) 100%); margin-top: 64px;">
    <div class="container py-4">
        <div class="section-badge mx-auto">About SmartEye</div>
        <h1 class="fw-bold text-dark display-5 mt-2">Empowering Vision, Enhancing Life</h1>
        <p class="text-muted col-lg-7 mx-auto leading-relaxed mt-3">Smart Eye Clinic combines clinical expertise, cutting-edge diagnostics, and personalized vision correction therapies to restore and protect your sight.</p>
    </div>
</section>

<!-- Clinic Intro, Mission, Vision -->
<section class="py-5">
    <div class="container">
        <div class="row align-items-center g-5">
            <div class="col-lg-6">
                <h2 class="fw-bold text-dark mb-4">Dedicated to Optical Excellence Since 2018</h2>
                <p class="text-muted">Smart Eye Clinic began with a simple but profound mission: to deliver world-class ophthalmic care with a compassionate, patient-centered approach. Over the years, we have grown into a leading optical health network, serving thousands of families with standard diagnostic screenings, complex refractive procedures, and premium vitreoretinal surgeries.</p>
                <p class="text-muted">We believe that clear vision is a fundamental right. That is why our modern facility is equipped with state-of-the-art diagnostic imaging, advanced surgical suites, and staffed by board-certified ophthalmologists dedicated to clinical leadership and educational research.</p>
            </div>
            <div class="col-lg-6">
                <!-- Mission Card -->
                <div class="card border-0 shadow-sm rounded-4 p-4 mb-4" style="background: var(--card-bg);">
                    <div class="d-flex gap-3 align-items-start">
                        <div class="bg-primary text-white rounded-3 p-3 d-flex align-items-center justify-content-center" style="width: 48px; height: 48px;">
                            <i class="fa-solid fa-bullseye fs-5"></i>
                        </div>
                        <div>
                            <h5 class="fw-bold text-dark mb-1">Our Mission</h5>
                            <p class="text-muted small mb-0">To protect and enhance patients' sight by providing premium, integrated eye care through innovative clinical practices, leading diagnostic systems, and specialized surgical therapies.</p>
                        </div>
                    </div>
                </div>

                <!-- Vision Card -->
                <div class="card border-0 shadow-sm rounded-4 p-4" style="background: var(--card-bg);">
                    <div class="d-flex gap-3 align-items-start">
                        <div class="bg-info text-white rounded-3 p-3 d-flex align-items-center justify-content-center" style="width: 48px; height: 48px;">
                            <i class="fa-solid fa-eye fs-5"></i>
                        </div>
                        <div>
                            <h5 class="fw-bold text-dark mb-1">Our Vision</h5>
                            <p class="text-muted small mb-0">To be the preferred premium center for ophthalmic care, recognized globally for optical diagnostic precision, advanced surgical safety records, and medical technology integration.</p>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- Why Choose Us -->
<section class="py-5 bg-light-primary" style="background: rgba(14,165,233,0.02); border-top: 1px solid var(--border); border-bottom: 1px solid var(--border);">
    <div class="container">
        <div class="text-center mb-5">
            <div class="section-badge">Why Choose Us</div>
            <h2 class="fw-bold text-dark mt-2">What Sets SmartEye Apart</h2>
        </div>

        <div class="row g-4">
            <div class="col-md-4 text-center">
                <div class="p-4 bg-white rounded-4 shadow-sm h-100 border border-light">
                    <i class="fa-solid fa-user-doctor text-primary fs-1 mb-3"></i>
                    <h5 class="fw-bold text-dark mb-2">Expert Specialists</h5>
                    <p class="text-muted small mb-0">Our clinical team consists of board-certified ophthalmologists with fellowships in pediatric, retinal, and cornea specialties.</p>
                </div>
            </div>
            <div class="col-md-4 text-center">
                <div class="p-4 bg-white rounded-4 shadow-sm h-100 border border-light">
                    <i class="fa-solid fa-microscope text-info fs-1 mb-3"></i>
                    <h5 class="fw-bold text-dark mb-2">Advanced Diagnostics</h5>
                    <p class="text-muted small mb-0">We utilize high-resolution OCT scans, topography, and visual field analysis to capture optical health markers accurately.</p>
                </div>
            </div>
            <div class="col-md-4 text-center">
                <div class="p-4 bg-white rounded-4 shadow-sm h-100 border border-light">
                    <i class="fa-solid fa-heart-pulse text-success fs-1 mb-3"></i>
                    <h5 class="fw-bold text-dark mb-2">Patient Safety Focus</h5>
                    <p class="text-muted small mb-0">We adhere to international sterile surgical procedures and post-operative monitoring to ensure optimal safety outcomes.</p>
                </div>
            </div>
        </div>
    </div>
</section>
