@model SmartEyeClinic.Models.Patient
@{
    ViewData["Title"] = "Patient Portal";
    var appointments = ViewBag.UpcomingAppointments as List<SmartEyeClinic.Models.Appointment>;
    var prescriptions = ViewBag.Prescriptions as List<SmartEyeClinic.Models.PrescriptionHeader>;
    var invoices = ViewBag.Invoices as List<SmartEyeClinic.Models.Invoice>;
}

<!-- Page Header -->
<div class="page-header">
    <div class="page-header-left">
        <div class="breadcrumb-nav">
            <a href="/"><i class="bi bi-house-door"></i> Home</a>
            <span class="separator">/</span>
            <span class="current">Patient Portal</span>
        </div>
        <h1 class="page-title"><i class="bi bi-person-workspace text-secondary-custom me-2"></i>My Patient Portal</h1>
        <p class="page-subtitle">Welcome back, <strong>@Model.User?.FullName</strong>. Access your prescriptions, invoices, and scheduling.</p>
    </div>
    <div class="d-flex gap-2 flex-wrap">
        <a asp-controller="Home" asp-action="Calendar" class="btn btn-primary btn-sm">
            <i class="bi bi-calendar-plus"></i> Book New Consult
        </a>
    </div>
</div>

<!-- KPI Cards -->
<div class="row g-4 mb-4">
    <!-- Next Appointment -->
    <div class="col-md-4">
        <div class="metric-card metric-gradient-primary">
            <div class="metric-label">Next Appointment</div>
            <div class="metric-value" style="font-size: 1.25rem; font-weight: 700; line-height: 1.4; padding: 6px 0;">
                @(appointments != null && appointments.Any() ? appointments.First().AppointmentDateTime.ToString("dd MMM yyyy - hh:mm tt") : "No Scheduled Visits")
            </div>
            <div class="metric-sub">
                <i class="bi bi-clock"></i> 
                @(appointments != null && appointments.Any() ? $"with Dr. {appointments.First().Doctor?.User?.FullName}" : "Book a slot anytime")
            </div>
            <div class="metric-icon"><i class="bi bi-calendar2-heart"></i></div>
        </div>
    </div>

    <!-- Active Prescriptions -->
    <div class="col-md-4">
        <div class="metric-card metric-gradient-success">
            <div class="metric-label">Active Prescriptions</div>
            <div class="metric-value">@(prescriptions?.Count ?? 0)</div>
            <div class="metric-sub"><i class="bi bi-prescription"></i> Issued by your specialists</div>
            <div class="metric-icon"><i class="bi bi-prescription2"></i></div>
        </div>
    </div>

    <!-- Outstanding Balance -->
    <div class="col-md-4">
        <div class="metric-card metric-gradient-danger">
            <div class="metric-label">Outstanding Balance</div>
            <div class="metric-value">$@(invoices != null ? invoices.Where(i => i.Status != "Paid").Sum(i => i.TotalAmount).ToString("N2") : "0.00")</div>
            <div class="metric-sub"><i class="bi bi-credit-card"></i> Invoices pending payment</div>
            <div class="metric-icon"><i class="bi bi-file-earmark-medical"></i></div>
        </div>
    </div>
</div>

<!-- Main Panels -->
<div class="row g-4">
    <!-- Left Column: Appointments & Billing -->
    <div class="col-lg-7">
        
        <!-- Scheduled Consultations -->
        <div class="table-card mb-4">
            <div class="table-card-header">
                <h5 class="table-title"><i class="bi bi-calendar3"></i> My Scheduled Consultations</h5>
                <span class="badge-status badge-primary">Upcoming</span>
            </div>
            @if (appointments == null || !appointments.Any())
            {
                <div class="empty-state">
                    <div class="empty-state-icon"><i class="bi bi-calendar-x"></i></div>
                    <h5>No Upcoming Visits</h5>
                    <p>You do not have any scheduled appointments at this time.</p>
                </div>
            }
            else
            {
                <div class="table-responsive-custom">
                    <table class="custom-table">
                        <thead>
                            <tr>
                                <th>Doctor</th>
                                <th>Date &amp; Time</th>
                                <th>Branch</th>
                                <th>Status</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var app in appointments)
                            {
                                var aBadge = "";
                                switch (app.Status)
                                {
                                    case "Confirmed": aBadge = "badge-success"; break;
                                    case "Pending": aBadge = "badge-warning"; break;
                                    case "Cancelled": aBadge = "badge-danger"; break;
                                    default: aBadge = "badge-neutral"; break;
                                }
                                <tr>
                                    <td>
                                        <div class="d-flex align-items-center gap-2">
                                            <div class="avatar-initials avatar-sm">
                                                @(app.Doctor?.User?.FullName?.Length > 0 ? app.Doctor.User.FullName[0].ToString().ToUpper() : "D")
                                            </div>
                                            <strong>Dr. @app.Doctor?.User?.FullName</strong>
                                        </div>
                                    </td>
                                    <td><span class="fw-600 text-sm">@app.AppointmentDateTime.ToString("dd MMM yyyy, hh:mm tt")</span></td>
                                    <td><span class="text-muted text-sm">@app.Branch?.Name</span></td>
                                    <td><span class="badge-status @aBadge">@app.Status</span></td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
        </div>

        <!-- Billing & Receipts -->
        <div class="table-card">
            <div class="table-card-header">
                <h5 class="table-title"><i class="bi bi-credit-card-2-front"></i> Billing &amp; Invoices</h5>
                <span class="badge-status badge-secondary">Invoicing</span>
            </div>
            @if (invoices == null || !invoices.Any())
            {
                <div class="empty-state">
                    <div class="empty-state-icon"><i class="bi bi-receipt"></i></div>
                    <h5>No Invoices Found</h5>
                    <p>No bills or receipts have been logged on your account yet.</p>
                </div>
            }
            else
            {
                <div class="table-responsive-custom">
                    <table class="custom-table">
                        <thead>
                            <tr>
                                <th>Invoice #</th>
                                <th>Total</th>
                                <th>Issued Date</th>
                                <th>Status</th>
                                <th class="text-end">Actions</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var i in invoices)
                            {
                                var statusBadge = i.Status == "Paid" ? "badge-success" : "badge-danger";
                                <tr>
                                    <td><span class="fw-700">#INV-@i.Id</span></td>
                                    <td><span class="fw-700 text-dark">$@i.TotalAmount.ToString("N2")</span></td>
                                    <td><span class="text-muted text-sm">@(i.IssuedAt.HasValue ? i.IssuedAt.Value.ToString("dd MMM yyyy") : "N/A")</span></td>
                                    <td><span class="badge-status @statusBadge">@i.Status</span></td>
                                    <td class="text-end">
                                        <a asp-controller="Invoice" asp-action="Details" asp-route-id="@i.Id" class="btn btn-light btn-sm border">
                                            <i class="bi bi-eye"></i> View Detail
                                        </a>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
        </div>
    </div>

    <!-- Right Column: Alerts & Recent Prescriptions -->
    <div class="col-lg-5">
        <!-- Notifications Panel -->
        <div class="table-card mb-4">
            <div class="table-card-header">
                <h5 class="table-title"><i class="bi bi-bell-fill text-warning"></i> Recent Alerts</h5>
                <span class="badge bg-light text-primary border small font-size-xs">Logs</span>
            </div>
            <div class="card-body-clean" style="max-height: 300px; overflow-y: auto; padding: 15px;">
                @{
                    var notifications = ViewBag.RecentNotifications as List<SmartEyeClinic.Models.Notification>;
                }
                @if (notifications == null || !notifications.Any())
                {
                    <div class="text-center py-4">
                        <i class="bi bi-bell-slash text-muted fs-4"></i>
                        <p class="small text-muted mb-0 mt-2">No new alerts or reminders.</p>
                    </div>
                }
                else
                {
                    <div class="d-flex flex-column gap-2">
                        @foreach (var n in notifications)
                        {
                            var hasBeenRead = n.IsRead ?? false;
                            <div class="p-2 rounded-3" style="font-size: 0.82rem; background: var(--bg); border-left: 3.5px solid @(hasBeenRead ? "var(--text-light)" : "var(--primary)");">
                                <div class="d-flex justify-content-between align-items-center mb-1">
                                    <strong class="text-dark">@n.Title</strong>
                                    <span class="text-muted" style="font-size: 0.72rem;">@n.SentAt?.ToString("g")</span>
                                </div>
                                <div class="text-muted text-xs">@n.Message</div>
                            </div>
                        }
                    </div>
                }
            </div>
        </div>

        <!-- Recent Prescriptions -->
        <div class="table-card">
            <div class="table-card-header">
                <h5 class="table-title"><i class="bi bi-prescription2 text-success"></i> Recent Prescriptions</h5>
            </div>
            <div class="card-body-clean" style="max-height: 580px; overflow-y: auto;">
                @if (prescriptions == null || !prescriptions.Any())
                {
                    <div class="empty-state" style="padding: 40px 20px;">
                        <div class="empty-state-icon"><i class="bi bi-capsule-therapeutic"></i></div>
                        <h5>No Prescriptions</h5>
                        <p>No prescriptions have been issued to your account yet.</p>
                    </div>
                }
                else
                {
                    <div class="d-flex flex-column gap-3">
                        @foreach (var rx in prescriptions)
                        {
                            <div class="p-3 rounded-3 border hover-shadow transition-all" style="background: var(--bg);">
                                <div class="d-flex justify-content-between align-items-start mb-2">
                                    <h6 class="fw-800 text-sm mb-0 text-dark">Prescription #RX-@rx.Id</h6>
                                    <span class="text-xs text-muted">@(rx.CreatedAt.HasValue ? rx.CreatedAt.Value.ToString("dd MMM yyyy") : "N/A")</span>
                                </div>
                                <div class="text-xs text-muted mb-2">
                                    <i class="bi bi-person-badge"></i> Prescribed by: <strong>Dr. @rx.Examination?.Appointment?.Doctor?.User?.FullName</strong>
                                </div>
                                
                                <div class="p-3 bg-white rounded border mb-3">
                                    <span class="text-xs text-muted fw-700 uppercase tracking-wide d-block mb-1">Medication Instructions:</span>
                                    <ul class="mb-0 ps-3 small text-muted">
                                        @foreach (var item in rx.PrescriptionItems)
                                        {
                                            <li>
                                                <strong class="text-dark">@item.Medicine?.Name</strong> - @item.Dosage 
                                                <span class="text-xs text-light-primary">(@item.DurationDays days)</span>
                                            </li>
                                        }
                                    </ul>
                                </div>

                                <div class="text-end">
                                    <a asp-controller="Prescription" asp-action="Details" asp-route-id="@rx.Id" class="btn btn-light btn-sm border">
                                        <i class="bi bi-printer"></i> View / Print Prescription
                                    </a>
                                </div>
                            </div>
                        }
                    </div>
                }
            </div>
        </div>
    </div>
</div>
