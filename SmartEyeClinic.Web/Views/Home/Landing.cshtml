                    <div class="d-flex gap-3 align-items-start">
                        <div class="bg-primary text-white rounded-3 p-3 d-flex align-items-center justify-content-center" style="width: 48px; height: 48px; flex-shrink:0;">
                            <i class="fa-solid fa-bullseye fs-5"></i>
                        </div>
