                        </div>
                    </div>
                </div>

                <!-- Vision Card -->
                <div class="card border-0 shadow-sm rounded-4 p-4 bg-white" style="border: 1px solid var(--border) !important;">
                    <div class="d-flex gap-3 align-items-start">
                        <div class="bg-info text-white rounded-3 p-3 d-flex align-items-center justify-content-center" style="width: 48px; height: 48px; flex-shrink:0;">
                            <i class="fa-solid fa-eye fs-5"></i>
                        </div>
                        <div>
                            <h5 class="fw-bold text-dark mb-1">Our Vision</h5>
                            <p class="text-muted small mb-0">To be the preferred premium center for ophthalmic care, recognized globally for optical diagnostic precision, advanced surgical safety records, and medical technology integration.</p>
