<!-- Contact Form Section (Merged from Contact.cshtml) -->
<section id="contact" class="landing-section">
    <div class="container">
        @if (TempData["Success"] != null)
        {
            <div class="alert alert-success alert-dismissible fade show rounded-3 mb-4" role="alert">
                <i class="fa-solid fa-circle-check me-2"></i> @TempData["Success"]
                <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
            </div>
        }
        @if (TempData["Error"] != null)
        {
            <div class="alert alert-danger alert-dismissible fade show rounded-3 mb-4" role="alert">
                <i class="fa-solid fa-triangle-exclamation me-2"></i> @TempData["Error"]
                <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
            </div>
        }
        <div class="card border-0 shadow-lg p-5 rounded-4 bg-white" style="box-shadow: 0 10px 30px rgba(15,76,129,0.04) !important; border: 1px solid var(--border) !important;">
            <div class="row g-5">
                <div class="col-lg-6">
                    <div class="section-badge">Contact Us</div>
                    <h2 class="section-title text-dark">Schedule Your Visit Today</h2>
                    <p class="section-subtitle mb-5 text-muted">Fill out the contact query form, or register a profile directly to book your appointment online immediately.</p>
                    <div class="d-flex flex-column gap-3">
                        <div class="d-flex align-items-center gap-3">
                            <div class="avatar-sm bg-light-primary text-primary" style="width: 40px; height: 40px; border-radius: 10px; display: flex; align-items: center; justify-content: center;">
                                <i class="fa-solid fa-map-pin"></i>
                            </div>
                            <span class="text-sm font-weight-500 text-dark">101 Medical Center Way, Suite A</span>
                        </div>
                        <div class="d-flex align-items-center gap-3">
                            <div class="avatar-sm bg-light-success text-success" style="width: 40px; height: 40px; border-radius: 10px; display: flex; align-items: center; justify-content: center;">
                                <i class="fa-solid fa-phone"></i>
                            </div>
                            <span class="text-sm font-weight-500 text-dark">+1 (555) 900-0000</span>
                        </div>
                        <div class="d-flex align-items-center gap-3">
                            <div class="avatar-sm bg-light-info text-info" style="width: 40px; height: 40px; border-radius: 10px; display: flex; align-items: center; justify-content: center;">
                                <i class="fa-solid fa-envelope"></i>
                            </div>
                            <span class="text-sm font-weight-500 text-dark">info@smarteyeclinic.com</span>
                        </div>
                    </div>
                </div>
                <div class="col-lg-6">
                    <form asp-controller="Home" asp-action="Contact" method="post" class="needs-validation" novalidate>
                        @Html.AntiForgeryToken()
                        <div class="row g-3">
                            <div class="col-sm-6">
                                <label class="form-label text-xs fw-600 text-muted">Full Name *</label>
                                <input type="text" name="name" class="form-control" placeholder="Jane Doe" required />
                                <div class="invalid-feedback text-xs">Name is required.</div>
                            </div>
                            <div class="col-sm-6">
                                <label class="form-label text-xs fw-600 text-muted">Email Address *</label>
                                <input type="email" name="email" class="form-control" placeholder="jane@example.com" required />
                                <div class="invalid-feedback text-xs">A valid email is required.</div>
                            </div>
                            <div class="col-12">
                                <label class="form-label text-xs fw-600 text-muted">Subject *</label>
                                <input type="text" name="subject" class="form-control" placeholder="Clinical inquiry" required />
                                <div class="invalid-feedback text-xs">Subject is required.</div>
                            </div>
                            <div class="col-12">
                                <label class="form-label text-xs fw-600 text-muted">Your Message *</label>
                                <textarea name="message" class="form-control" placeholder="Describe your query..." style="min-height: 120px;" required></textarea>
                                <div class="invalid-feedback text-xs">Message is required.</div>
                            </div>
                            <div class="col-12">
                                <button type="submit" class="btn btn-primary btn-lg w-100 justify-content-center">
                                    <i class="fa-solid fa-paper-plane me-1"></i> Send Online Inquiry
                                </button>
                            </div>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</section>

@section Scripts {
    <script>
        document.addEventListener("DOMContentLoaded", function () {
            // Live Search Filter for Doctors
            const searchInput = document.getElementById("doctorSearchInput");
            const docItems = document.querySelectorAll(".doctor-item-col");

            if (searchInput) {
                searchInput.addEventListener("input", function () {
                    const query = this.value.toLowerCase().trim();
                    docItems.forEach(item => {
                        const name = item.getAttribute("data-search-name").toLowerCase();
                        const spec = item.getAttribute("data-search-spec").toLowerCase();
                        if (name.includes(query) || spec.includes(query)) {
                            item.style.display = "";
                        } else {
                            item.style.display = "none";
                        }
                    });
                });
            }

            // Form Validation
            'use strict'
            var forms = document.querySelectorAll('.needs-validation')
            Array.prototype.slice.call(forms)
                .forEach(function (form) {
                    form.addEventListener('submit', function (event) {
                        if (!form.checkValidity()) {
                            event.preventDefault()
                            event.stopPropagation()
                        }
                        form.classList.add('was-validated')
                    }, false)
                })
        });
    </script>
}
