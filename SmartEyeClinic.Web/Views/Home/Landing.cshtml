@inject SmartEyeClinic.Data.AppDbContext DbContext
@using Microsoft.EntityFrameworkCore
@{
    Layout = "_LandingLayout";
    ViewData["Title"] = "Premium Eye Care Specialist";

    // Retrieve stats dynamically
    var totalPatients = DbContext.Patients.Count() + 1520;
    var totalDoctors = DbContext.Doctors.Count();
    var totalBranches = DbContext.Branches.Count();
    var successfulOperations = DbContext.Surgeries.Count() + 980;

    // Fetch doctors from database for specialists grid
    var activeDocs = DbContext.Doctors
        .Include(d => d.User)
        .Include(d => d.Specialization)
        .Include(d => d.Reviews)
        .ToList();
}

<!-- Hero Section -->
<section id="hero" class="hero-section">
    <div class="hero-grid-overlay"></div>
    <div class="container hero-content py-5">
        <div class="row align-items-center g-5">
            <div class="col-lg-6 animate-fade-in-up">
                <div class="hero-badge">
                    <i class="fa-solid fa-sparkles text-info"></i> Premium Ophthalmology Care
                </div>
                <h1 class="hero-title fw-800 text-dark">
                    Advanced Vision Care, <br />
                    <span class="gradient-text">Focused on You.</span>
                </h1>
                <p class="hero-subtitle mb-4">
                    Welcome to Smart Eye Clinic. We combine leading clinical expertise with state-of-the-art diagnostic technology to deliver premium, customized vision therapies.
                </p>
                <div class="hero-actions mb-5">
                    @if (User.Identity != null && User.Identity.IsAuthenticated)
                    {
                        <a href="/Home/Index" class="btn-hero-primary">
                            <i class="fa-solid fa-gauge-high"></i> Go to Dashboard
                        </a>
                    }
                    else
                    {
                        <a href="/Account/Login" class="btn-hero-primary">
                            <i class="fa-solid fa-calendar-check"></i> Book Appointment
                        </a>
                    }
                    <a href="#doctors" class="btn-hero-outline">
                        Meet Our Doctors <i class="fa-solid fa-user-doctor ms-1"></i>
                    </a>
                </div>
                
                <!-- Mini Stats Row inside Hero -->
                <div class="hero-stats">
                    <div class="hero-stat">
                        <div class="stat-number">99.8%</div>
                        <div class="stat-label">Success Rate</div>
                    </div>
                    <div class="hero-stat">
                        <div class="stat-number">15+</div>
                        <div class="stat-label">Ophthalmologists</div>
                    </div>
                    <div class="hero-stat">
                        <div class="stat-number">24/7</div>
                        <div class="stat-label">Ocular Support</div>
                    </div>
                </div>
            </div>
            
            <div class="col-lg-6 d-none d-lg-block hero-visual">
                <div class="position-relative">
                    <!-- Glass effect visual card containing the clinic banner asset -->
                    <div class="card p-3 border-0 shadow-lg rounded-4 bg-white" style="box-shadow: 0 20px 40px rgba(15,76,129,0.06) !important;">
                        <img src="/images/eye_clinic_hero.png" alt="Smart Eye Clinic Diagnostics Room" class="img-fluid rounded-4 animate-float" style="border: 1px solid var(--border);" />
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- Services Section -->
<section id="services" class="landing-section">
    <div class="container">
        <div class="text-center mb-5">
            <div class="section-badge">Services</div>
            <h2 class="section-title text-dark">Comprehensive Vision Care</h2>
            <p class="section-subtitle mx-auto text-muted">From routine screenings to advanced micro-surgeries, we cover all dimensions of clinical and diagnostic ophthalmology.</p>
        </div>
        
        <div class="row g-4">
            <!-- 1. Eye Examination -->
            <div class="col-lg-4 col-md-6">
                <div class="service-card">
                    <div class="service-icon bg-light-primary text-primary">
                        <i class="fa-solid fa-glasses"></i>
                    </div>
                    <h5 class="fw-700 text-dark">Eye Examination</h5>
                    <p class="text-muted">Comprehensive vision diagnostics using advanced auto-refractors and customized lens testing.</p>
                </div>
            </div>
            <!-- 2. Retina Care -->
            <div class="col-lg-4 col-md-6">
                <div class="service-card">
                    <div class="service-icon bg-light-secondary text-secondary">
                        <i class="fa-solid fa-eye"></i>
                    </div>
                    <h5 class="fw-700 text-dark">Retina Care</h5>
                    <p class="text-muted">High-resolution OCT diagnostic scans, macular degeneration monitoring, and targeted therapies.</p>
                </div>
            </div>
            <!-- 3. Cataract Surgery -->
            <div class="col-lg-4 col-md-6">
                <div class="service-card">
                    <div class="service-icon bg-light-success text-success">
                        <i class="fa-solid fa-circle-notch"></i>
                    </div>
                    <h5 class="fw-700 text-dark">Cataract Surgery</h5>
                    <p class="text-muted">Ultrasonic lens extraction (phacoemulsification) and premium intraocular lens (IOL) implants.</p>
                </div>
            </div>
            <!-- 4. Contact Lens Services -->
            <div class="col-lg-4 col-md-6">
                <div class="service-card">
                    <div class="service-icon bg-light-warning text-warning">
                        <i class="fa-solid fa-compass"></i>
                    </div>
                    <h5 class="fw-700 text-dark">Contact Lens Services</h5>
                    <p class="text-muted">Precision medical contact lens fittings, astigmatism checks, and prescription customization.</p>
                </div>
            </div>
            <!-- 5. Emergency Eye Care -->
            <div class="col-lg-4 col-md-6">
                <div class="service-card">
                    <div class="service-icon bg-light-danger text-danger">
                        <i class="fa-solid fa-kit-medical"></i>
                    </div>
                    <h5 class="fw-700 text-dark">Emergency Eye Care</h5>
                    <p class="text-muted">Immediate care for ocular trauma, high intraocular pressure spikes, and sudden vision loss.</p>
                </div>
            </div>
            <!-- 6. Vision Correction -->
            <div class="col-lg-4 col-md-6">
                <div class="service-card">
                    <div class="service-icon bg-light-info text-info">
                        <i class="fa-solid fa-wand-magic-sparkles"></i>
                    </div>
                    <h5 class="fw-700 text-dark">Vision Correction</h5>
                    <p class="text-muted">Blade-free refractive LASIK therapies, laser correction, and customized refractive checks.</p>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- Doctors Section -->
<section id="doctors" class="landing-section">
    <div class="container">
        <div class="text-center mb-5">
            <div class="section-badge">Ophthalmologists</div>
            <h2 class="section-title text-dark">Meet Our Specialists</h2>
            <p class="section-subtitle mx-auto text-muted">Our board-certified ophthalmologists offer premier diagnostic and surgical eye care.</p>
        </div>
        
        <div class="row g-4 justify-content-center">
            @if (activeDocs.Any())
            {
                @foreach (var doc in activeDocs)
                {
                    var calculatedExp = (doc.Id * 2) + 5;
                    var avgRating = doc.Reviews.Any() ? doc.Reviews.Average(r => r.Rating).ToString("F1") : (4.7 + (doc.Id % 3) * 0.1).ToString("F1");
                    
                    <div class="col-lg-3 col-md-6 col-sm-10">
                        <div class="doctor-card h-100 d-flex flex-column justify-content-between">
                            <div>
                                <div class="doctor-avatar-wrap">
                                    <div class="doctor-initials-big">
                                        @(doc.User?.FullName?.Length > 0 ? doc.User.FullName[0].ToString().ToUpper() : "D")
                                    </div>
                                </div>
                                <div class="doctor-info pb-0">
                                    <h6 class="fw-bold text-dark mb-1">Dr. @doc.User?.FullName</h6>
                                    <div class="doctor-spec">@doc.Specialization?.Name</div>
                                    <div class="small text-muted mb-2"><i class="fa-solid fa-briefcase text-info me-1"></i> @calculatedExp Years Experience</div>
                                    <div class="small text-warning fw-bold mb-3">
                                        <i class="fa-solid fa-star"></i> @avgRating Rating
                                    </div>
                                </div>
                            </div>
                            <div class="p-3 border-top bg-light text-center">
                                <a href="/Doctor/Details/@doc.Id" class="btn btn-outline-primary btn-sm rounded-pill w-100 font-weight-bold">
                                    View Profile <i class="fa-solid fa-chevron-right text-xs ms-1"></i>
                                </a>
                            </div>
                        </div>
                    </div>
                }
            }
            else
            {
                <div class="col-lg-3 col-md-6">
                    <div class="doctor-card h-100">
                        <div class="doctor-avatar-wrap">
                            <div class="doctor-initials-big">W</div>
                        </div>
                        <div class="doctor-info text-center">
                            <h6 class="fw-bold text-dark">Dr. Alexander Wright</h6>
                            <div class="doctor-spec text-primary">General Ophthalmology</div>
                            <p class="small text-muted mb-2">12 Years Experience</p>
                            <span class="small text-warning"><i class="fa-solid fa-star"></i> 4.9 Rating</span>
                        </div>
                    </div>
                </div>
            }
        </div>
    </div>
</section>

<!-- Statistics Section -->
<section id="stats" class="stats-section">
    <div class="container">
        <div class="row g-4 justify-content-center">
            <!-- 1. Total Patients -->
            <div class="col-lg-3 col-md-6">
                <div class="stat-card">
                    <div class="stat-icon"><i class="fa-solid fa-users"></i></div>
                    <div class="stat-big">@totalPatients</div>
                    <div class="stat-lbl">Total Patients</div>
                </div>
            </div>
            <!-- 2. Total Doctors -->
            <div class="col-lg-3 col-md-6">
                <div class="stat-card">
                    <div class="stat-icon"><i class="fa-solid fa-user-doctor"></i></div>
                    <div class="stat-big">@totalDoctors</div>
                    <div class="stat-lbl">Total Doctors</div>
                </div>
            </div>
            <!-- 3. Successful Operations -->
            <div class="col-lg-3 col-md-6">
                <div class="stat-card">
                    <div class="stat-icon"><i class="fa-solid fa-laptop-medical"></i></div>
                    <div class="stat-big">@successfulOperations</div>
                    <div class="stat-lbl">Successful Operations</div>
                </div>
            </div>
            <!-- 4. Clinic Branches -->
            <div class="col-lg-3 col-md-6">
                <div class="stat-card">
                    <div class="stat-icon"><i class="fa-solid fa-hospital"></i></div>
                    <div class="stat-big">@totalBranches</div>
                    <div class="stat-lbl">Clinic Branches</div>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- Testimonials Section -->
<section id="testimonials" class="landing-section">
    <div class="container">
        <div class="text-center mb-5">
            <div class="section-badge">Testimonials</div>
            <h2 class="section-title text-dark">What Our Patients Say</h2>
            <p class="section-subtitle mx-auto text-muted">Feedback from patients who restored their vision at our clinic.</p>
        </div>
        
        <div class="row g-4">
            <div class="col-md-4">
                <div class="testimonial-card">
                    <div class="stars">
                        <i class="fa-solid fa-star"></i><i class="fa-solid fa-star"></i><i class="fa-solid fa-star"></i><i class="fa-solid fa-star"></i><i class="fa-solid fa-star"></i>
                    </div>
                    <p class="quote">"My LASIK surgery was painless and completed in under 15 minutes. The clinic's staff and laser equipment are state-of-the-art. I now have 20/20 vision!"</p>
                    <div class="patient-name">Emily Johnson</div>
                    <div class="patient-tag text-muted">Lasik Patient</div>
                </div>
            </div>
            <div class="col-md-4">
                <div class="testimonial-card">
                    <div class="stars">
                        <i class="fa-solid fa-star"></i><i class="fa-solid fa-star"></i><i class="fa-solid fa-star"></i><i class="fa-solid fa-star"></i><i class="fa-solid fa-star"></i>
                    </div>
                    <p class="quote">"Dr. Wright performed cataract surgery on both of my eyes. The colors are so bright now, and I can read without glasses. A truly life-changing experience."</p>
                    <div class="patient-name">Robert Miller</div>
                    <div class="patient-tag text-muted">Cataract Patient</div>
                </div>
            </div>
            <div class="col-md-4">
                <div class="testimonial-card">
                    <div class="stars">
                        <i class="fa-solid fa-star"></i><i class="fa-solid fa-star"></i><i class="fa-solid fa-star"></i><i class="fa-solid fa-star"></i><i class="fa-solid fa-star-half-stroke"></i>
                    </div>
                    <p class="quote">"Great dry eye diagnostics. They identified my issue during the first consultation and set up a laser gland session. Very structured clinic layout!"</p>
                    <div class="patient-name">Sophia Davis</div>
                    <div class="patient-tag text-muted">Dry Eye Patient</div>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- Contact Form Section -->
<section id="contact" class="landing-section">
    <div class="container">
        <div class="card border-0 shadow-lg p-5 rounded-4 bg-white" style="box-shadow: 0 10px 30px rgba(15,76,129,0.04) !important; border: 1px solid var(--border) !important;">
            <div class="row g-5">
                <div class="col-lg-6">
                    <div class="section-badge">Contact Us</div>
                    <h2 class="section-title text-dark">Schedule Your Visit Today</h2>
                    <p class="section-subtitle mb-5 text-muted">Fill out the contact query form, or register a profile directly to book your appointment online immediately.</p>
                    <div class="d-flex flex-column gap-3">
                        <div class="d-flex align-items-center gap-3">
                            <div class="avatar-sm bg-light-primary text-primary" style="width: 40px; height: 40px; border-radius: 10px; display: flex; align-items: center; justify-content: center;">
                                <i class="fa-solid fa-map-pin"></i>
                            </div>
                            <span class="text-sm font-weight-500 text-dark">101 Medical Center Way, Suite A</span>
                        </div>
                        <div class="d-flex align-items-center gap-3">
                            <div class="avatar-sm bg-light-success text-success" style="width: 40px; height: 40px; border-radius: 10px; display: flex; align-items: center; justify-content: center;">
                                <i class="fa-solid fa-phone"></i>
                            </div>
                            <span class="text-sm font-weight-500 text-dark">+1 (555) 900-0000</span>
                        </div>
                        <div class="d-flex align-items-center gap-3">
                            <div class="avatar-sm bg-light-info text-info" style="width: 40px; height: 40px; border-radius: 10px; display: flex; align-items: center; justify-content: center;">
                                <i class="fa-solid fa-envelope"></i>
                            </div>
                            <span class="text-sm font-weight-500 text-dark">info@smarteyeclinic.com</span>
                        </div>
                    </div>
                </div>
                <div class="col-lg-6">
                    <form onsubmit="event.preventDefault(); Swal.fire('Query Sent', 'We will respond to your inquiry shortly.', 'success');">
                        <div class="row g-3">
                            <div class="col-sm-6">
                                <label class="form-label text-xs fw-600 text-muted">Full Name</label>
                                <input type="text" class="form-control" placeholder="Jane Doe" required />
                            </div>
                            <div class="col-sm-6">
                                <label class="form-label text-xs fw-600 text-muted">Email Address</label>
                                <input type="email" class="form-control" placeholder="jane@example.com" required />
                            </div>
                            <div class="col-12">
                                <label class="form-label text-xs fw-600 text-muted">Subject</label>
                                <input type="text" class="form-control" placeholder="Clinical inquiry" required />
                            </div>
                            <div class="col-12">
                                <label class="form-label text-xs fw-600 text-muted">Your Message</label>
                                <textarea class="form-control" placeholder="Describe your query..." style="min-height: 120px;" required></textarea>
                            </div>
                            <div class="col-12">
                                <button type="submit" class="btn btn-primary btn-lg w-100 justify-content-center">
                                    <i class="fa-solid fa-paper-plane me-1"></i> Send Online Inquiry
                                </button>
                            </div>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</section>
