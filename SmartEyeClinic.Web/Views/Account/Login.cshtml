@{
    Layout = null; // Clean page without sidebar for login
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Sign In - Smart Eye Clinic</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <style>
        body.login-body {
            background: linear-gradient(135deg, #0F4C81 0%, #0077B6 50%, #00B4D8 100%);
            min-height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
            padding: 20px;
            font-family: 'Poppins', 'Inter', sans-serif;
        }

        .login-card {
            background: rgba(255, 255, 255, 0.9);
            backdrop-filter: blur(10px);
            border-radius: 16px;
            box-shadow: 0 10px 30px rgba(0, 0, 0, 0.2);
            border: 1px solid rgba(255, 255, 255, 0.2);
            overflow: hidden;
            width: 100%;
            max-width: 480px;
            animation: fadeInUp 0.6s ease;
        }

        .login-header {
            background: rgba(15, 76, 129, 0.05);
            padding: 30px 40px 20px 40px;
            text-align: center;
            border-bottom: 1px solid rgba(0,0,0,0.05);
        }

        .login-header i {
            color: #0F4C81;
            font-size: 3rem;
            margin-bottom: 15px;
            animation: pulse 2s infinite;
        }

        .login-header h3 {
            font-weight: 700;
            color: #0F4C81;
            margin-bottom: 5px;
        }

        .login-body-content {
            padding: 30px 40px;
        }

        .form-control-custom {
            border: 1.5px solid #CBD5E1;
            border-radius: 10px;
            padding: 12px 16px 12px 46px;
            font-size: 0.95rem;
            transition: all 0.3s;
            background-color: #F8FAFC;
        }

        .form-control-custom:focus {
            border-color: #0F4C81;
            background-color: #FFF;
            box-shadow: 0 0 0 3px rgba(15, 76, 129, 0.15);
        }

        .input-group-icon {
            position: absolute;
            left: 18px;
            top: 15px;
            color: #64748B;
            font-size: 1.1rem;
            z-index: 10;
        }

        .btn-login {
            background: linear-gradient(135deg, #0F4C81 0%, #1D70B8 100%);
            color: white;
            border: none;
            padding: 12px;
            border-radius: 10px;
            font-weight: 600;
            transition: all 0.3s;
            box-shadow: 0 4px 10px rgba(15, 76, 129, 0.2);
        }

        .btn-login:hover {
            transform: translateY(-2px);
            box-shadow: 0 6px 15px rgba(15, 76, 129, 0.3);
            color: #fff;
            opacity: 0.95;
        }

        .demo-accounts {
            background: rgba(15, 76, 129, 0.05);
            border-radius: 12px;
            padding: 15px 20px;
            margin-top: 20px;
            border: 1px dashed rgba(15, 76, 129, 0.2);
        }

        .demo-accounts h6 {
            color: #0F4C81;
            font-weight: 600;
            font-size: 0.85rem;
            margin-bottom: 8px;
        }

        .demo-badge {
            cursor: pointer;
            font-size: 0.78rem;
            background-color: #FFF;
            border: 1px solid #E2E8F0;
            border-radius: 6px;
            padding: 4px 8px;
            margin: 3px;
            display: inline-block;
            transition: all 0.2s;
        }

        .demo-badge:hover {
            border-color: #0F4C81;
            background-color: #F0F9FF;
            transform: translateY(-1px);
        }

        @@keyframes fadeInUp {
            from {
                opacity: 0;
                transform: translateY(20px);
            }
            to {
                opacity: 1;
                transform: translateY(0);
            }
        }

        @@keyframes pulse {
            0% { transform: scale(1); }
            50% { transform: scale(1.05); }
            100% { transform: scale(1); }
        }
    </style>
</head>
<body class="login-body">

    <div class="login-card">
        <div class="login-header">
            <i class="fa-solid fa-house-medical"></i>
            <h3>Smart Eye Clinic</h3>
            <p class="text-muted small mb-0">Hospital ERP Management System</p>
        </div>
        <div class="login-body-content">
            <form asp-controller="Account" asp-action="Login" asp-route-returnUrl="@ViewBag.ReturnUrl" method="post" class="needs-validation" novalidate>
                @Html.AntiForgeryToken()

                @if (!ViewData.ModelState.IsValid)
                {
                    <div class="alert alert-danger py-2 px-3 small rounded-3 mb-3">
                        <div asp-validation-summary="All" class="text-danger"></div>
                    </div>
                }

                @if (TempData["Success"] != null)
                {
                    <div class="alert alert-success py-2 px-3 small rounded-3 mb-3">
                        <i class="fa-solid fa-circle-check me-2"></i> @TempData["Success"]
                    </div>
                }

                <div class="mb-3 position-relative">
                    <label class="form-label small fw-600 text-secondary-color">Email Address</label>
                    <div class="position-relative">
                        <i class="fa-regular fa-envelope input-group-icon"></i>
                        <input type="email" name="email" id="emailInput" class="form-control form-control-custom" placeholder="name@smarteye.com" required />
                    </div>
                </div>

                <div class="mb-4 position-relative">
                    <label class="form-label small fw-600 text-secondary-color">Password</label>
                    <div class="position-relative">
                        <i class="fa-solid fa-lock input-group-icon"></i>
                        <input type="password" name="password" id="passwordInput" class="form-control form-control-custom" placeholder="••••••••" required />
                    </div>
                </div>

                <button type="submit" class="btn btn-login w-100 mb-3">
                    <i class="fa-solid fa-right-to-bracket me-2"></i> Sign In
                </button>

                <div class="text-center small text-muted mb-2">
                    Don't have a patient account? <a asp-action="Register" class="fw-bold text-decoration-none" style="color: #0F4C81;">Register here</a>
                </div>

                <!-- Demo Accounts Panel -->
                <div class="demo-accounts text-center">
                    <h6><i class="fa-solid fa-key me-1"></i> Quick Test Credentials</h6>
                    <div class="d-flex flex-wrap justify-content-center">
                        <span class="demo-badge" onclick="fillCreds('admin@smarteye.com', 'admin123')">Admin</span>
                        <span class="demo-badge" onclick="fillCreds('doctor@smarteye.com', 'doctor123')">Doctor</span>
                        <span class="demo-badge" onclick="fillCreds('receptionist@smarteye.com', 'recep123')">Receptionist</span>
                        <span class="demo-badge" onclick="fillCreds('patient@smarteye.com', 'patient123')">Patient</span>
                    </div>
                    <span class="text-muted" style="font-size: 0.72rem; display: block; margin-top: 5px;">Click any role to autofill the form</span>
                </div>
            </form>
        </div>
    </div>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script>
        function fillCreds(email, password) {
            document.getElementById('emailInput').value = email;
            document.getElementById('passwordInput').value = password;
        }

        // Bootstrap form validation
        (function () {
            'use strict'
            var forms = document.querySelectorAll('.needs-validation')
            Array.prototype.slice.call(forms)
                .forEach(function (form) {
                    form.addEventListener('submit', function (event) {
                        if (!form.checkValidity()) {
                            event.preventDefault()
                            event.stopPropagation()
                        }
                        form.classList.add('was-validated')
                    }, false)
                })
        })()
    </script>
</body>
</html>
