@{
    Layout = null;
}
@* صفحة تسجيل الدخول لنظام إدارة عيادة سمارت آي *@

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Sign In - Smart Eye Clinic</title>
    <!-- Bootstrap 5 -->
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <!-- Font Awesome CDN -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css" />
    <!-- Custom site CSS (contains auth layout properties) -->
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <style>
        .auth-input-group {
            display: flex !important;
            align-items: stretch !important;
            width: 100% !important;
            border: 1.5px solid #E2E8F0 !important;
            border-radius: var(--radius) !important;
            background: #fff !important;
            overflow: hidden !important;
            transition: border-color 0.2s, box-shadow 0.2s !important;
        }
        .auth-input-group:focus-within {
            border-color: var(--primary) !important;
            box-shadow: 0 0 0 3px rgba(15,76,129,0.1) !important;
        }
        .auth-input-group-icon {
            display: flex !important;
            align-items: center !important;
            padding-left: 14px !important;
            padding-right: 10px !important;
            color: #94A3B8 !important;
            font-size: 0.9rem !important;
            background: transparent !important;
            pointer-events: none;
        }
        .auth-input-group .form-control-auth {
            border: none !important;
            border-radius: 0 !important;
            padding: 11px 14px 11px 0 !important;
            width: 100% !important;
            flex-grow: 1 !important;
            box-shadow: none !important;
            background: transparent !important;
            outline: none !important;
        }
        .auth-input-group .password-toggle {
            display: flex !important;
            align-items: center !important;
            padding-left: 10px !important;
            padding-right: 14px !important;
            color: #94A3B8 !important;
            background: transparent !important;
            border: none !important;
            cursor: pointer !important;
            font-size: 0.95rem !important;
            outline: none !important;
        }
        .auth-input-group .password-toggle:hover {
            color: #475569 !important;
        }
    </style>
</head>
<body>


    <div class="auth-page">
        <!-- اللوحة اليسرى: الهوية والشعار ومميزات المنصة -->
        <div class="auth-panel-left d-none d-lg-flex">
            <div class="hero-grid-overlay"></div>
            <div style="max-width: 440px; position: relative; z-index: 5;">
                <div class="auth-logo">
                    <div class="auth-logo-icon">
                        <i class="fa-solid fa-eye"></i>
                    </div>
                    <div class="auth-logo-text">
                        <div class="clinic-name">SmartEye Clinic</div>
                        <div class="clinic-type">Clinical ERP Platform</div>
                    </div>
                </div>

                <h2 class="text-white fw-bold mb-4" style="line-height:1.25">Your Sight. <br/>Our Lifelong Focus.</h2>
                <p class="text-white-50 small mb-5">Access your medical history, manage appointments, view diagnostic examinations, and communicate with your ophthalmic specialists securely.</p>

                <!-- Features checklist -->
                <div class="auth-feature">
                    <div class="auth-feature-icon"><i class="fa-solid fa-calendar-check"></i></div>
                    <div class="auth-feature-text">
                        <h6>Instant Scheduling</h6>
                        <p>Book eye consultations and review doctor availability schedules dynamically.</p>
                    </div>
                </div>

                <div class="auth-feature">
                    <div class="auth-feature-icon"><i class="fa-solid fa-file-invoice-dollar"></i></div>
                    <div class="auth-feature-text">
                        <h6>Billing & Receipts</h6>
                        <p>Track treatment invoices, clear clinical dues, and access payment reports.</p>
                    </div>
                </div>

                <div class="auth-feature">
                    <div class="auth-feature-icon"><i class="fa-solid fa-user-shield"></i></div>
                    <div class="auth-feature-text">
                        <h6>Secure Medical Files</h6>
                        <p>Access scans, visual acuity sheets, and doctor prescriptions safely.</p>
                    </div>
                </div>
            </div>
        </div>

        <!-- اللوحة اليمنى: نموذج تسجيل الدخول والتحقق -->
        <div class="auth-panel-right">
            <div class="auth-form-container">
                <!-- Back to Home Link -->
                <div class="mb-4 text-start">
                    <a href="/" class="text-decoration-none d-inline-flex align-items-center gap-2 text-muted" style="transition: var(--transition);">
                        <span class="d-flex align-items-center justify-content-center bg-light border rounded-circle" style="width: 32px; height: 32px;">
                            <i class="fa-solid fa-arrow-left text-xs"></i>
                        </span>
                        <span class="fw-semibold small text-dark">Back to Home</span>
                    </a>
                </div>
                <!-- Mobile Logo -->
                <div class="auth-logo d-flex d-lg-none justify-content-center mb-4">
                    <div class="auth-logo-icon" style="width: 40px; height: 40px; font-size:1.15rem;">
                        <i class="fa-solid fa-eye"></i>
                    </div>
                    <div class="auth-logo-text text-start">
                        <div class="clinic-name text-dark">SmartEye</div>
                        <div class="clinic-type" style="color:var(--text-muted)">Clinic ERP</div>
                    </div>
                </div>

                <div class="text-center text-lg-start">
                    <h3 class="auth-title">Welcome Back</h3>
                    <p class="auth-subtitle">Hospital management and patient service portal</p>
                </div>

                <form asp-controller="Account" asp-action="Login" asp-route-returnUrl="@ViewBag.ReturnUrl" method="post" class="needs-validation" novalidate id="loginForm">
                    @Html.AntiForgeryToken()

                    @if (!ViewData.ModelState.IsValid)
                    {
                        <div class="alert alert-danger py-2 px-3 mb-4 animate-fade-in-up">
                            <i class="fa-solid fa-circle-exclamation fs-6"></i>
                            <div asp-validation-summary="All" class="small"></div>
                        </div>
                    }

                    @if (TempData["Success"] != null)
                    {
                        <div class="alert alert-success py-2 px-3 mb-4 animate-fade-in-up">
                            <i class="fa-solid fa-circle-check fs-6"></i>
                            <span class="small">@TempData["Success"]</span>
                        </div>
                    }

                    <!-- حقل إدخال البريد الإلكتروني -->
                    <div class="mb-3">
                        <label class="form-label text-xs">Email Address</label>
                        <div class="auth-input-group">
                            <span class="auth-input-group-icon">
                                <i class="fa-regular fa-envelope"></i>
                            </span>
                            <input type="email" name="email" id="emailInput" class="form-control-auth" placeholder="name@smarteye.com" required autocomplete="email" />
                        </div>
                    </div>

                    <!-- حقل إدخال كلمة المرور مع زر التبديل -->
                    <div class="mb-4">
                        <div class="d-flex justify-content-between mb-1">
                            <label class="form-label text-xs mb-0">Password</label>
                        </div>
                        <div class="auth-input-group">
                            <span class="auth-input-group-icon">
                                <i class="fa-solid fa-lock"></i>
                            </span>
                            <input type="password" name="password" id="passwordInput" class="form-control-auth" placeholder="••••••••" required autocomplete="current-password" />
                            <button type="button" class="password-toggle" id="togglePasswordBtn" aria-label="Toggle password visibility">
                                <i class="fa-regular fa-eye-slash" id="togglePasswordIcon"></i>
                            </button>
                        </div>
                    </div>

                    <!-- زر تقديم النموذج لتسجيل الدخول -->
                    <button type="submit" class="btn-auth btn-auth-primary mb-3" id="signInBtn">
                        <span class="btn-text"><i class="fa-solid fa-right-to-bracket me-1"></i> Sign In</span>
                        <span class="spinner"></span>
                    </button>

                    <div class="text-center small text-muted mb-2">
                        Don't have a patient account? <a asp-action="Register" class="fw-bold text-primary-custom">Register here</a>
                    </div>
                </form>
            </div>
        </div>
    </div>

    <!-- Scripts -->
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script>


        // Toggle Password visibility
        const toggleBtn = document.getElementById('togglePasswordBtn');
        const passInput = document.getElementById('passwordInput');
        const toggleIcon = document.getElementById('togglePasswordIcon');
        if (toggleBtn && passInput) {
            toggleBtn.addEventListener('click', function () {
                const type = passInput.getAttribute('type') === 'password' ? 'text' : 'password';
                passInput.setAttribute('type', type);
                toggleIcon.className = type === 'text' ? 'fa-regular fa-eye' : 'fa-regular fa-eye-slash';
            });
        }

        // Form submit spinner & validation
        (function () {
            'use strict'
            const form = document.getElementById('loginForm');
            const btn = document.getElementById('signInBtn');
            if (form && btn) {
                form.addEventListener('submit', function (event) {
                    if (!form.checkValidity()) {
                        event.preventDefault();
                        event.stopPropagation();
                        form.classList.add('was-validated');
                    } else {
                        btn.classList.add('loading');
                        btn.disabled = true;
                    }
                }, false);
            }
        })();
    </script>
</body>
</html>
