@{
    ViewData["Title"] = "Access Denied - Smart Eye Clinic";
}

<div class="error-page">
    <div class="error-page-content animate-fade-in-up">
        <div class="error-icon-ring">
            <i class="fa-solid fa-shield-halved"></i>
        </div>
        <h1 class="error-code">403</h1>
        <h3 class="fw-bold text-dark mb-2">Access Restriced</h3>
        <p class="text-muted mb-4">You do not have the required role permissions to view this clinic dashboard. If you believe this is in error, please contact the administration desk.</p>
        <div class="d-flex justify-content-center gap-3">
            <a href="javascript:history.back()" class="btn btn-light px-4">
                <i class="fa-solid fa-arrow-left"></i> Go Back
            </a>
            <a asp-controller="Home" asp-action="Index" class="btn btn-primary px-4">
                <i class="fa-solid fa-house"></i> Dashboard
            </a>
        </div>
    </div>
</div>
