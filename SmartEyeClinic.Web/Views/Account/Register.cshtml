@{
    Layout = null;
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Patient Registration - Smart Eye Clinic</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <style>
        body.login-body {
            background: linear-gradient(135deg, #0F4C81 0%, #0077B6 50%, #00B4D8 100%);
            min-height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
            padding: 30px 20px;
            font-family: 'Poppins', 'Inter', sans-serif;
        }

        .login-card {
            background: rgba(255, 255, 255, 0.92);
            backdrop-filter: blur(10px);
            border-radius: 16px;
            box-shadow: 0 10px 30px rgba(0, 0, 0, 0.2);
            border: 1px solid rgba(255, 255, 255, 0.2);
            overflow: hidden;
            width: 100%;
            max-width: 600px;
            animation: fadeInUp 0.6s ease;
        }

        .login-header {
            background: rgba(15, 76, 129, 0.05);
            padding: 25px 40px 15px 40px;
            text-align: center;
            border-bottom: 1px solid rgba(0,0,0,0.05);
        }

        .login-header i {
            color: #0F4C81;
            font-size: 2.5rem;
            margin-bottom: 10px;
        }

        .login-header h3 {
            font-weight: 700;
            color: #0F4C81;
            margin-bottom: 3px;
        }

        .login-body-content {
            padding: 35px 40px;
        }

        .form-control-custom {
            border: 1.5px solid #CBD5E1;
            border-radius: 10px;
            padding: 10px 14px;
            font-size: 0.92rem;
            transition: all 0.3s;
            background-color: #F8FAFC;
        }

        .form-control-custom:focus {
            border-color: #0F4C81;
            background-color: #FFF;
            box-shadow: 0 0 0 3px rgba(15, 76, 129, 0.15);
        }

        .form-select-custom {
            border: 1.5px solid #CBD5E1;
            border-radius: 10px;
            padding: 10px 14px;
            font-size: 0.92rem;
            transition: all 0.3s;
            background-color: #F8FAFC;
        }

        .form-select-custom:focus {
            border-color: #0F4C81;
            background-color: #FFF;
            box-shadow: 0 0 0 3px rgba(15, 76, 129, 0.15);
        }

        .btn-register {
            background: linear-gradient(135deg, #22C55E 0%, #15803D 100%);
            color: white;
            border: none;
            padding: 12px;
            border-radius: 10px;
            font-weight: 600;
            transition: all 0.3s;
            box-shadow: 0 4px 10px rgba(34, 197, 94, 0.2);
        }

        .btn-register:hover {
            transform: translateY(-2px);
            box-shadow: 0 6px 15px rgba(34, 197, 94, 0.3);
            color: #fff;
            opacity: 0.95;
        }

        @@keyframes fadeInUp {
            from {
                opacity: 0;
                transform: translateY(20px);
            }
            to {
                opacity: 1;
                transform: translateY(0);
            }
        }
    </style>
</head>
<body class="login-body">

    <div class="login-card">
        <div class="login-header">
            <i class="fa-solid fa-hospital-user"></i>
            <h3>Register Patient Account</h3>
            <p class="text-muted small mb-0">Join Smart Eye Clinic Patient Portal</p>
        </div>
        <div class="login-body-content">
            <form asp-controller="Account" asp-action="Register" method="post" class="needs-validation" novalidate>
                @Html.AntiForgeryToken()

                @if (!ViewData.ModelState.IsValid)
                {
                    <div class="alert alert-danger py-2 px-3 small rounded-3 mb-3">
                        <div asp-validation-summary="All" class="text-danger"></div>
                    </div>
                }

                <div class="row g-3 mb-3">
                    <div class="col-md-6">
                        <label class="form-label small fw-600">Full Name *</label>
                        <input type="text" name="fullName" class="form-control form-control-custom" placeholder="John Doe" required />
                    </div>
                    <div class="col-md-6">
                        <label class="form-label small fw-600">Email Address *</label>
                        <input type="email" name="email" class="form-control form-control-custom" placeholder="john@example.com" required />
                    </div>
                </div>

                <div class="row g-3 mb-3">
                    <div class="col-md-6">
                        <label class="form-label small fw-600">Password *</label>
                        <input type="password" name="password" class="form-control form-control-custom" placeholder="••••••••" required minlength="6" />
                    </div>
                    <div class="col-md-6">
                        <label class="form-label small fw-600">Phone Number</label>
                        <input type="tel" name="phoneNumber" class="form-control form-control-custom" placeholder="555-0199" />
                    </div>
                </div>

                <div class="row g-3 mb-3">
                    <div class="col-md-6">
                        <label class="form-label small fw-600">National ID / Passport *</label>
                        <input type="text" name="nationalId" class="form-control form-control-custom" placeholder="NID-8877" required />
                    </div>
                    <div class="col-md-6">
                        <label class="form-label small fw-600">Gender *</label>
                        <select name="gender" class="form-select form-select-custom" required>
                            <option value="">Choose...</option>
                            <option value="Male">Male</option>
                            <option value="Female">Female</option>
                            <option value="Other">Other</option>
                        </select>
                    </div>
                </div>

                <div class="row g-3 mb-4">
                    <div class="col-md-6">
                        <label class="form-label small fw-600">Date of Birth *</label>
                        <input type="date" name="dob" class="form-control form-control-custom" required value="2000-01-01" />
                    </div>
                    <div class="col-md-6">
                        <label class="form-label small fw-600">Home Address</label>
                        <input type="text" name="address" class="form-control form-control-custom" placeholder="123 Maple St" />
                    </div>
                </div>

                <button type="submit" class="btn btn-register w-100 mb-3">
                    <i class="fa-solid fa-user-plus me-2"></i> Register Account
                </button>

                <div class="text-center small text-muted">
                    Already have an account? <a asp-action="Login" class="fw-bold text-decoration-none" style="color: #0F4C81;">Sign In here</a>
                </div>
            </form>
        </div>
    </div>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script>
        // Bootstrap form validation
        (function () {
            'use strict'
            var forms = document.querySelectorAll('.needs-validation')
            Array.prototype.slice.call(forms)
                .forEach(function (form) {
                    form.addEventListener('submit', function (event) {
                        if (!form.checkValidity()) {
                            event.preventDefault()
                            event.stopPropagation()
                        }
                        form.classList.add('was-validated')
                    }, false)
                })
        })()
    </script>
</body>
</html>
