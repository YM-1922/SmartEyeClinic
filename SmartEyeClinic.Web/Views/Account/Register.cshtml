@{
    Layout = null;
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Patient Registration - Smart Eye Clinic</title>
    <!-- Bootstrap 5 -->
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <!-- Font Awesome CDN -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css" />
    <!-- Custom site CSS -->
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <style>
        .auth-input-group {
            display: flex !important;
            align-items: stretch !important;
            width: 100% !important;
            border: 1.5px solid #E2E8F0 !important;
            border-radius: var(--radius) !important;
            background: #fff !important;
            overflow: hidden !important;
            transition: border-color 0.2s, box-shadow 0.2s !important;
        }
        .auth-input-group:focus-within {
            border-color: var(--primary) !important;
            box-shadow: 0 0 0 3px rgba(15,76,129,0.1) !important;
        }
        .auth-input-group:has(.is-invalid) {
            border-color: #dc3545 !important;
        }
        .auth-input-group:has(.is-valid) {
            border-color: #198754 !important;
        }
        .auth-input-group-icon {
            display: flex !important;
            align-items: center !important;
            padding-left: 14px !important;
            padding-right: 10px !important;
            color: #94A3B8 !important;
            font-size: 0.9rem !important;
            background: transparent !important;
            pointer-events: none;
        }
        .auth-input-group .form-control-auth {
            border: none !important;
            border-radius: 0 !important;
            padding: 11px 14px 11px 0 !important;
            width: 100% !important;
            flex-grow: 1 !important;
            box-shadow: none !important;
            background: transparent !important;
            outline: none !important;
        }
        .auth-input-group .password-toggle {
            display: flex !important;
            align-items: center !important;
            padding-left: 10px !important;
            padding-right: 14px !important;
            color: #94A3B8 !important;
            background: transparent !important;
            border: none !important;
            cursor: pointer !important;
            font-size: 0.95rem !important;
            outline: none !important;
        }
        .auth-input-group .password-toggle:hover {
            color: #475569 !important;
        }
    </style>
</head>
<body>


    <div class="auth-page">
        <!-- Left Panel: Branding & Features -->
        <div class="auth-panel-left d-none d-lg-flex">
            <div class="hero-grid-overlay"></div>
            <div style="max-width: 440px; position: relative; z-index: 5;">
                <div class="auth-logo">
                    <div class="auth-logo-icon">
                        <i class="fa-solid fa-eye"></i>
                    </div>
                    <div class="auth-logo-text">
                        <div class="clinic-name">SmartEye Clinic</div>
                        <div class="clinic-type">Clinical ERP Platform</div>
                    </div>
                </div>

                <h2 class="text-white fw-bold mb-4" style="line-height:1.25">Join the Future of <br/>Eye Care Service.</h2>
                <p class="text-white-50 small mb-5">Create a patient account to instantly book visual acuity checks, manage medical records, retrieve laser imaging files, and track prescriptions.</p>

                <!-- Features list -->
                <div class="auth-feature">
                    <div class="auth-feature-icon"><i class="fa-solid fa-clock-rotate-left"></i></div>
                    <div class="auth-feature-text">
                        <h6>Medical History Track</h6>
                        <p>Keep a lifetime record of diagnoses, surgeries, and prescriptions.</p>
                    </div>
                </div>

                <div class="auth-feature">
                    <div class="auth-feature-icon"><i class="fa-solid fa-file-invoice-dollar"></i></div>
                    <div class="auth-feature-text">
                        <h6>Zero Paper Billing</h6>
                        <p>Access insurance details, bills, payments, and invoices digitally.</p>
                    </div>
                </div>
            </div>
        </div>

        <!-- Right Panel: Step-by-Step Register Form -->
        <div class="auth-panel-right">
            <div class="auth-form-container" style="max-width: 420px;">
                <!-- Back to Home Link -->
                <div class="mb-4 text-start">
                    <a href="/" class="text-decoration-none d-inline-flex align-items-center gap-2 text-muted" style="transition: var(--transition);">
                        <span class="d-flex align-items-center justify-content-center bg-light border rounded-circle" style="width: 32px; height: 32px;">
                            <i class="fa-solid fa-arrow-left text-xs"></i>
                        </span>
                        <span class="fw-semibold small text-dark">Back to Home</span>
                    </a>
                </div>
                <!-- Mobile Logo -->
                <div class="auth-logo d-flex d-lg-none justify-content-center mb-4">
                    <div class="auth-logo-icon" style="width: 40px; height: 40px; font-size:1.15rem;">
                        <i class="fa-solid fa-eye"></i>
                    </div>
                    <div class="auth-logo-text text-start">
                        <div class="clinic-name text-dark">SmartEye</div>
                        <div class="clinic-type" style="color:var(--text-muted)">Clinic ERP</div>
                    </div>
                </div>

                <div class="text-center text-lg-start">
                    <h3 class="auth-title">Create Account</h3>
                    <p class="auth-subtitle">Register a new patient profile</p>
                </div>

                <!-- Step Progress Indicators -->
                <div class="step-indicator">
                    <div class="step-dot active" id="dot1">1</div>
                    <div class="step-line" id="line1"></div>
                    <div class="step-dot" id="dot2">2</div>
                    <div class="step-line" id="line2"></div>
                    <div class="step-dot" id="dot3">3</div>
                </div>

                <form asp-controller="Account" asp-action="Register" method="post" class="needs-validation" novalidate id="registerForm">
                    @Html.AntiForgeryToken()

                    @if (!ViewData.ModelState.IsValid)
                    {
                        <div class="alert alert-danger py-2 px-3 mb-4 animate-fade-in-up">
                            <i class="fa-solid fa-circle-exclamation fs-6"></i>
                            <div asp-validation-summary="All" class="small"></div>
                        </div>
                    }

                    <!-- STEP 1: Account Information -->
                    <div class="register-step active" id="step1">
                        <h6 class="fw-bold mb-3 text-primary-custom text-xs uppercase tracking-wide">Step 1: Account Details</h6>
                        
                        <div class="mb-3">
                            <label class="form-label text-xs">Full Name *</label>
                            <div class="auth-input-group">
                                <span class="auth-input-group-icon">
                                    <i class="fa-regular fa-user"></i>
                                </span>
                                <input type="text" name="fullName" id="fullNameInput" class="form-control-auth" placeholder="John Doe" required />
                            </div>
                        </div>

                        <div class="mb-3">
                            <label class="form-label text-xs">Email Address *</label>
                            <div class="auth-input-group">
                                <span class="auth-input-group-icon">
                                    <i class="fa-regular fa-envelope"></i>
                                </span>
                                <input type="email" name="email" id="emailInput" class="form-control-auth" placeholder="john@example.com" required />
                            </div>
                            <div class="invalid-feedback text-xs" id="emailFeedback">A valid email address is required.</div>
                        </div>

                        <div class="mb-4">
                            <label class="form-label text-xs">Password *</label>
                            <div class="auth-input-group">
                                <span class="auth-input-group-icon">
                                    <i class="fa-solid fa-lock"></i>
                                </span>
                                <input type="password" name="password" id="passwordInput" class="form-control-auth" placeholder="••••••••" required minlength="6" />
                                <button type="button" class="password-toggle" id="togglePasswordBtn">
                                    <i class="fa-regular fa-eye-slash" id="togglePasswordIcon"></i>
                                </button>
                            </div>
                            <span class="text-muted text-xs d-block mt-1">Minimum 6 characters</span>
                        </div>

                        <div class="d-flex justify-content-end">
                            <button type="button" class="btn btn-primary" onclick="goToStep(2)">
                                Next Step <i class="fa-solid fa-arrow-right"></i>
                            </button>
                        </div>
                    </div>

                    <!-- STEP 2: Identification & Demographics -->
                    <div class="register-step" id="step2">
                        <h6 class="fw-bold mb-3 text-primary-custom text-xs uppercase tracking-wide">Step 2: Profile Identification</h6>

                        <div class="mb-3">
                            <label class="form-label text-xs">National ID / Passport *</label>
                            <div class="auth-input-group">
                                <span class="auth-input-group-icon">
                                    <i class="fa-regular fa-id-card"></i>
                                </span>
                                <input type="text" name="nationalId" id="nidInput" class="form-control-auth" placeholder="NID-8877" required />
                            </div>
                            <div class="invalid-feedback text-xs" id="nidFeedback">National ID is required.</div>
                        </div>

                        <div class="mb-3">
                            <label class="form-label text-xs">Gender *</label>
                            <select name="gender" id="genderInput" class="form-control-auth form-select" required>
                                <option value="">Choose Gender...</option>
                                <option value="Male">Male</option>
                                <option value="Female">Female</option>
                                <option value="Other">Other</option>
                            </select>
                        </div>

                        <div class="mb-4">
                            <label class="form-label text-xs">Date of Birth *</label>
                            <input type="date" name="dob" id="dobInput" class="form-control-auth" required value="2000-01-01" />
                        </div>

                        <div class="d-flex justify-content-between">
                            <button type="button" class="btn btn-light" onclick="goToStep(1)">
                                <i class="fa-solid fa-arrow-left"></i> Previous
                            </button>
                            <button type="button" class="btn btn-primary" onclick="goToStep(3)">
                                Next Step <i class="fa-solid fa-arrow-right"></i>
                            </button>
                        </div>
                    </div>

                    <!-- STEP 3: Contact Details & Confirmation -->
                    <div class="register-step" id="step3">
                        <h6 class="fw-bold mb-3 text-primary-custom text-xs uppercase tracking-wide">Step 3: Contact details</h6>

                        <div class="mb-3">
                            <label class="form-label text-xs">Phone Number</label>
                            <div class="auth-input-group">
                                <span class="auth-input-group-icon">
                                    <i class="fa-solid fa-phone"></i>
                                </span>
                                <input type="tel" name="phoneNumber" id="phoneInput" class="form-control-auth" placeholder="555-0199" />
                            </div>
                            <div class="invalid-feedback text-xs" id="phoneFeedback">This phone number is already registered.</div>
                        </div>

                        <div class="mb-4">
                            <label class="form-label text-xs">Home Address</label>
                            <div class="auth-input-group">
                                <span class="auth-input-group-icon">
                                    <i class="fa-solid fa-house"></i>
                                </span>
                                <input type="text" name="address" class="form-control-auth" placeholder="123 Maple St" />
                            </div>
                        </div>

                        <div class="d-flex justify-content-between gap-2">
                            <button type="button" class="btn btn-light" onclick="goToStep(2)">
                                <i class="fa-solid fa-arrow-left"></i> Previous
                            </button>
                            <button type="submit" class="btn-auth btn-auth-primary w-auto flex-fill" id="registerBtn">
                                <span class="btn-text"><i class="fa-solid fa-user-plus"></i> Register Profile</span>
                                <span class="spinner"></span>
                            </button>
                        </div>
                    </div>

                    <div class="text-center small text-muted mt-4">
                        Already have an account? <a asp-action="Login" class="fw-bold text-primary-custom">Sign In here</a>
                    </div>
                </form>
            </div>
        </div>
    </div>

    <!-- Scripts -->
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script>
        // Toggle Password visibility
        const toggleBtn = document.getElementById('togglePasswordBtn');
        const passInput = document.getElementById('passwordInput');
        const toggleIcon = document.getElementById('togglePasswordIcon');
        if (toggleBtn && passInput) {
            toggleBtn.addEventListener('click', function () {
                const type = passInput.getAttribute('type') === 'password' ? 'text' : 'password';
                passInput.setAttribute('type', type);
                toggleIcon.className = type === 'text' ? 'fa-regular fa-eye' : 'fa-regular fa-eye-slash';
            });
        }

        // Wizard steps navigation
        let currentStep = 1;
        async function goToStep(step) {
            if (step > currentStep) {
                // Validate fields in current step before moving forward
                let isValid = true;
                const container = document.getElementById(`step${currentStep}`);
                const inputs = container.querySelectorAll('input[required], select[required]');
                
                inputs.forEach(input => {
                    if (!input.checkValidity()) {
                        isValid = false;
                        input.classList.add('is-invalid');
                    } else {
                        input.classList.remove('is-invalid');
                        input.classList.add('is-valid');
                    }
                });

                if (!isValid) {
                    return; // block navigation
                }

                // Database Uniqueness AJAX Checks
                if (currentStep === 1) {
                    const emailInput = document.getElementById('emailInput');
                    const emailVal = emailInput.value;
                    const emailFeedback = document.getElementById('emailFeedback');
                    
                    // Show button loading spinner and disable next step button
                    const nextBtn = container.querySelector('button[onclick="goToStep(2)"]');
                    const originalHtml = nextBtn.innerHTML;
                    nextBtn.innerHTML = '<span class="spinner-border spinner-border-sm me-1" role="status" aria-hidden="true"></span> Validating...';
                    nextBtn.disabled = true;
                    emailInput.disabled = true;

                    try {
                        const response = await $.get('/Account/CheckEmail', { email: emailVal });
                        if (!response.available) {
                            emailInput.classList.remove('is-valid');
                            emailInput.classList.add('is-invalid');
                            emailFeedback.textContent = response.message || "This email is already registered.";
                            isValid = false;
                        } else {
                            emailInput.classList.remove('is-invalid');
                            emailInput.classList.add('is-valid');
                        }
                    } catch (err) {
                        console.error(err);
                    } finally {
                        nextBtn.innerHTML = originalHtml;
                        nextBtn.disabled = false;
                        emailInput.disabled = false;
                    }

                    if (!isValid) return;
                }
                else if (currentStep === 2) {
                    const nidInput = document.getElementById('nidInput');
                    const nidVal = nidInput.value;
                    const nidFeedback = document.getElementById('nidFeedback');

                    const nextBtn = container.querySelector('button[onclick="goToStep(3)"]');
                    const originalHtml = nextBtn.innerHTML;
                    nextBtn.innerHTML = '<span class="spinner-border spinner-border-sm me-1" role="status" aria-hidden="true"></span> Validating...';
                    nextBtn.disabled = true;
                    nidInput.disabled = true;

                    try {
                        const response = await $.get('/Account/CheckNationalId', { nationalId: nidVal });
                        if (!response.available) {
                            nidInput.classList.remove('is-valid');
                            nidInput.classList.add('is-invalid');
                            nidFeedback.textContent = response.message || "This National ID is already registered.";
                            isValid = false;
                        } else {
                            nidInput.classList.remove('is-invalid');
                            nidInput.classList.add('is-valid');
                        }
                    } catch (err) {
                        console.error(err);
                    } finally {
                        nextBtn.innerHTML = originalHtml;
                        nextBtn.disabled = false;
                        nidInput.disabled = false;
                    }

                    if (!isValid) return;
                }
            }

            // Move steps
            document.querySelectorAll('.register-step').forEach(el => el.classList.remove('active'));
            document.getElementById(`step${step}`).classList.add('active');

            // Update indicators
            document.querySelectorAll('.step-dot').forEach(el => el.classList.remove('active', 'done'));
            document.querySelectorAll('.step-line').forEach(el => el.classList.remove('done'));

            for (let i = 1; i <= step; i++) {
                const dot = document.getElementById(`dot${i}`);
                if (i < step) {
                    dot.classList.add('done');
                    const line = document.getElementById(`line${i}`);
                    if (line) line.classList.add('done');
                } else if (i === step) {
                    dot.classList.add('active');
                }
            }

            currentStep = step;
        }

        // Form submit spinner & phone number check
        (function () {
            'use strict'
            const form = document.getElementById('registerForm');
            const btn = document.getElementById('registerBtn');
            if (form && btn) {
                form.addEventListener('submit', async function (event) {
                    event.preventDefault();
                    event.stopPropagation();

                    if (!form.checkValidity()) {
                        form.classList.add('was-validated');
                        return;
                    }

                    // Perform phone number check
                    const phoneInput = document.getElementById('phoneInput');
                    const phoneVal = phoneInput.value;
                    const phoneFeedback = document.getElementById('phoneFeedback');
                    
                    if (phoneVal) {
                        btn.classList.add('loading');
                        btn.disabled = true;
                        phoneInput.disabled = true;

                        try {
                            const response = await $.get('/Account/CheckPhoneNumber', { phoneNumber: phoneVal });
                            if (!response.available) {
                                phoneInput.classList.remove('is-valid');
                                phoneInput.classList.add('is-invalid');
                                phoneFeedback.textContent = response.message || "This phone number is already registered.";
                                btn.classList.remove('loading');
                                btn.disabled = false;
                                phoneInput.disabled = false;
                                return; // Block submit
                            } else {
                                phoneInput.classList.remove('is-invalid');
                                phoneInput.classList.add('is-valid');
                            }
                        } catch (err) {
                            console.error(err);
                            btn.classList.remove('loading');
                            btn.disabled = false;
                            phoneInput.disabled = false;
                            return; // Block submit on error
                        }
                    }

                    // If all validation passed, submit the form!
                    btn.classList.add('loading');
                    btn.disabled = true;
                    form.submit();
                }, false);
            }
        })();
    </script>
</body>
</html>
